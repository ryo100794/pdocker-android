diff --git a/src/extension/cow_bind/cow_bind.c b/src/extension/cow_bind/cow_bind.c
new file mode 100644
index 0000000..7173d84
--- /dev/null
+++ b/src/extension/cow_bind/cow_bind.c
@@ -0,0 +1,351 @@
+/*
+ * Experimental cow_bind extension for pdocker.
+ *
+ * Syntax:
+ *   --cow-bind upper:lower:guest_path
+ *
+ * This is intentionally small for the first rollout: open/openat/creat
+ * copy lower files into upper before write-class opens and redirects the
+ * syscall path to upper. TRANSLATED_PATH redirects reads to upper once a
+ * copy exists.
+ */
+
+#include <errno.h>
+#include <fcntl.h>
+#include <limits.h>
+#include <stdio.h>
+#include <stdlib.h>
+#include <string.h>
+#include <sys/stat.h>
+#include <sys/types.h>
+#include <unistd.h>
+#include <utime.h>
+
+#include <talloc.h>
+
+#include "extension/extension.h"
+#include "path/binding.h"
+#include "syscall/syscall.h"
+#include "syscall/sysnum.h"
+#include "tracee/mem.h"
+#include "tracee/reg.h"
+
+typedef struct {
+	char upper[PATH_MAX];
+	char lower[PATH_MAX];
+	char guest[PATH_MAX];
+} CowBindConfig;
+
+static int parse_cow_bind(CowBindConfig *config, const char *cli)
+{
+	char tmp[PATH_MAX * 3];
+	char *lower;
+	char *guest;
+
+	if (cli == NULL || strlen(cli) >= sizeof(tmp))
+		return -EINVAL;
+
+	strcpy(tmp, cli);
+	lower = strchr(tmp, ':');
+	if (lower == NULL)
+		return -EINVAL;
+	*lower++ = '\0';
+
+	guest = strchr(lower, ':');
+	if (guest == NULL)
+		return -EINVAL;
+	*guest++ = '\0';
+
+	if (tmp[0] != '/' || lower[0] != '/' || guest[0] != '/')
+		return -EINVAL;
+
+	if (strlen(tmp) >= PATH_MAX || strlen(lower) >= PATH_MAX || strlen(guest) >= PATH_MAX)
+		return -ENAMETOOLONG;
+
+	strcpy(config->upper, tmp);
+	strcpy(config->lower, lower);
+	strcpy(config->guest, guest);
+
+	return 0;
+}
+
+static int path_starts_with(const char *path, const char *prefix)
+{
+	size_t n = strlen(prefix);
+
+	if (strncmp(path, prefix, n) != 0)
+		return 0;
+	return path[n] == '\0' || path[n] == '/';
+}
+
+static int upper_for_lower(const CowBindConfig *config, const char *path, char out[PATH_MAX])
+{
+	const char *suffix;
+	size_t needed;
+
+	if (!path_starts_with(path, config->lower))
+		return 0;
+
+	suffix = path + strlen(config->lower);
+	needed = strlen(config->upper) + strlen(suffix) + 1;
+	if (needed > PATH_MAX)
+		return -ENAMETOOLONG;
+
+	strcpy(out, config->upper);
+	strcat(out, suffix);
+	return 1;
+}
+
+static int mkdir_p_parent(const char *path)
+{
+	char tmp[PATH_MAX];
+	char *p;
+
+	if (strlen(path) >= PATH_MAX)
+		return -ENAMETOOLONG;
+	strcpy(tmp, path);
+
+	p = strrchr(tmp, '/');
+	if (p == NULL || p == tmp)
+		return 0;
+	*p = '\0';
+
+	for (p = tmp + 1; *p != '\0'; p++) {
+		if (*p != '/')
+			continue;
+		*p = '\0';
+		if (mkdir(tmp, 0755) < 0 && errno != EEXIST)
+			return -errno;
+		*p = '/';
+	}
+
+	if (mkdir(tmp, 0755) < 0 && errno != EEXIST)
+		return -errno;
+	return 0;
+}
+
+static int copy_file_no_xattr(const char *src, const char *dst)
+{
+	char tmp[PATH_MAX];
+	unsigned char buffer[65536];
+	struct stat st;
+	struct utimbuf times;
+	ssize_t nread;
+	int in = -1;
+	int out = -1;
+	int status = 0;
+
+	if (snprintf(tmp, sizeof(tmp), "%s.cowtmp.%ld", dst, (long) getpid()) >= (int) sizeof(tmp))
+		return -ENAMETOOLONG;
+
+	if (lstat(src, &st) < 0)
+		return -errno;
+	if (!S_ISREG(st.st_mode))
+		return 0;
+
+	status = mkdir_p_parent(dst);
+	if (status < 0)
+		return status;
+
+	in = open(src, O_RDONLY | O_CLOEXEC);
+	if (in < 0)
+		return -errno;
+	out = open(tmp, O_WRONLY | O_CREAT | O_TRUNC | O_CLOEXEC, st.st_mode & 07777);
+	if (out < 0) {
+		status = -errno;
+		goto end;
+	}
+
+	while ((nread = read(in, buffer, sizeof(buffer))) > 0) {
+		unsigned char *p = buffer;
+		ssize_t left = nread;
+		while (left > 0) {
+			ssize_t nwritten = write(out, p, left);
+			if (nwritten < 0) {
+				status = -errno;
+				goto end;
+			}
+			p += nwritten;
+			left -= nwritten;
+		}
+	}
+	if (nread < 0) {
+		status = -errno;
+		goto end;
+	}
+
+	(void) fchmod(out, st.st_mode & 07777);
+	if (close(out) < 0 && status == 0)
+		status = -errno;
+	out = -1;
+	if (status < 0)
+		goto end;
+
+	if (rename(tmp, dst) < 0) {
+		status = -errno;
+		goto end;
+	}
+
+	times.actime = st.st_atime;
+	times.modtime = st.st_mtime;
+	(void) utime(dst, &times);
+
+end:
+	if (in >= 0)
+		(void) close(in);
+	if (out >= 0)
+		(void) close(out);
+	if (status < 0)
+		(void) unlink(tmp);
+	return status;
+}
+
+static int ensure_upper_path(const char *lower, const char *upper)
+{
+	struct stat st;
+	int status;
+
+	if (lstat(upper, &st) == 0)
+		return 0;
+	if (errno != ENOENT)
+		return -errno;
+
+	if (lstat(lower, &st) < 0) {
+		if (errno == ENOENT)
+			return mkdir_p_parent(upper);
+		return -errno;
+	}
+
+	if (S_ISDIR(st.st_mode))
+		return mkdir(upper, st.st_mode & 07777) < 0 && errno != EEXIST ? -errno : 0;
+	if (S_ISLNK(st.st_mode)) {
+		char target[PATH_MAX];
+		ssize_t size;
+
+		status = mkdir_p_parent(upper);
+		if (status < 0)
+			return status;
+		size = readlink(lower, target, sizeof(target) - 1);
+		if (size < 0)
+			return -errno;
+		target[size] = '\0';
+		return symlink(target, upper) < 0 && errno != EEXIST ? -errno : 0;
+	}
+
+	return copy_file_no_xattr(lower, upper);
+}
+
+static int is_write_open(word_t flags)
+{
+	return (flags & (O_WRONLY | O_RDWR | O_TRUNC | O_CREAT)) != 0;
+}
+
+static int redirect_write_path(Tracee *tracee, const CowBindConfig *config, Reg path_reg)
+{
+	char lower_path[PATH_MAX];
+	char upper_path[PATH_MAX];
+	ssize_t size;
+	int status;
+
+	size = read_string(tracee, lower_path, peek_reg(tracee, CURRENT, path_reg), PATH_MAX);
+	if (size < 0)
+		return size;
+	if (size >= PATH_MAX)
+		return -ENAMETOOLONG;
+
+	status = upper_for_lower(config, lower_path, upper_path);
+	if (status <= 0)
+		return status;
+
+	status = ensure_upper_path(lower_path, upper_path);
+	if (status < 0)
+		return status;
+
+	return set_sysarg_path(tracee, upper_path, path_reg);
+}
+
+static int handle_sysenter_end(Tracee *tracee, const CowBindConfig *config)
+{
+	word_t sysnum = get_sysnum(tracee, ORIGINAL);
+	word_t flags;
+
+	switch (sysnum) {
+	case PR_open:
+		flags = peek_reg(tracee, CURRENT, SYSARG_2);
+		if (is_write_open(flags))
+			return redirect_write_path(tracee, config, SYSARG_1);
+		break;
+
+	case PR_openat:
+		flags = peek_reg(tracee, CURRENT, SYSARG_3);
+		if (is_write_open(flags))
+			return redirect_write_path(tracee, config, SYSARG_2);
+		break;
+
+	case PR_creat:
+		return redirect_write_path(tracee, config, SYSARG_1);
+	}
+
+	return 0;
+}
+
+static int handle_translated_path(const CowBindConfig *config, char path[PATH_MAX])
+{
+	char upper_path[PATH_MAX];
+	int status;
+
+	status = upper_for_lower(config, path, upper_path);
+	if (status <= 0)
+		return status;
+	if (access(upper_path, F_OK) == 0)
+		strcpy(path, upper_path);
+	return 0;
+}
+
+static FilteredSysnum filtered_sysnums[] = {
+	{ PR_open,   FILTER_SYSEXIT },
+	{ PR_openat, FILTER_SYSEXIT },
+	{ PR_creat,  FILTER_SYSEXIT },
+	FILTERED_SYSNUM_END,
+};
+
+int cow_bind_callback(Extension *extension, ExtensionEvent event, intptr_t data1, intptr_t data2 UNUSED)
+{
+	switch (event) {
+	case INITIALIZATION: {
+		Tracee *tracee = TRACEE(extension);
+		CowBindConfig *config;
+		int status;
+
+		config = talloc_zero(extension, CowBindConfig);
+		if (config == NULL)
+			return -ENOMEM;
+		status = parse_cow_bind(config, (const char *) data1);
+		if (status < 0)
+			return status;
+
+		extension->config = config;
+		extension->filtered_sysnums = filtered_sysnums;
+
+		(void) new_binding(tracee, config->lower, config->guest, true);
+		return 0;
+	}
+
+	case INHERIT_PARENT:
+		return 0;
+
+	case SYSCALL_ENTER_END:
+		if ((int) data1 < 0)
+			return 0;
+		return handle_sysenter_end(TRACEE(extension),
+					talloc_get_type_abort(extension->config, CowBindConfig));
+
+	case TRANSLATED_PATH:
+		return handle_translated_path(
+			talloc_get_type_abort(extension->config, CowBindConfig),
+			(char *) data1);
+
+	default:
+		return 0;
+	}
+}
