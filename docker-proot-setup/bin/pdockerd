#!/usr/bin/env python3
"""
pdockerd — Docker Engine API-compatible daemon for Android userspace runtimes.

Implements a subset of the Docker Engine API v1.43 so that the original
`docker`, `docker compose`, and `docker buildx` CLIs can target this
daemon over a Unix domain socket.

Backend: crane (image pull/export) + pdocker-direct/chroot-style userspace
execution — no kernel namespace / mount / cgroup required.

Usage:
    pdockerd [--socket PATH] [--host HOST:PORT]

Defaults:
    socket: /var/run/docker.sock  (or $XDG_RUNTIME_DIR/docker.sock if set)
    data:   $PDOCKER_HOME or ~/.pdocker

Then:
    export DOCKER_HOST=unix:///var/run/docker.sock
    docker version
    docker run --rm ubuntu:22.04 echo hi
    docker compose up
"""

import argparse
import fnmatch
import hashlib
import json
import os
import re
import shlex
import shutil
import signal
import socket
import socketserver
import stat as stat_mod
import subprocess
import sys
import tarfile
import threading
import time
import traceback
import urllib.parse
import uuid
from http.server import BaseHTTPRequestHandler
from io import BytesIO

# ---- Configuration ----

PDOCKER_HOME = os.environ.get("PDOCKER_HOME", os.path.expanduser("~/.pdocker"))
IMAGES_DIR = os.path.join(PDOCKER_HOME, "images")
LAYERS_DIR = os.path.join(PDOCKER_HOME, "layers")
CONTAINERS_DIR = os.path.join(PDOCKER_HOME, "containers")
META_DIR = os.path.join(PDOCKER_HOME, "meta")
BUILD_CACHE_DIR = os.path.join(META_DIR, "build-cache")
LOGS_DIR = os.path.join(PDOCKER_HOME, "logs")
VOLUMES_DIR = os.path.join(PDOCKER_HOME, "volumes")
NETWORKS_DIR = os.path.join(PDOCKER_HOME, "networks")
# Staging for crane blob downloads, layer tars, image save/load etc. On
# Android the process can't write to /tmp (system read-only); respect
# $PDOCKER_TMP_DIR (or $TMPDIR) so the bridge can point us at the app's
# filesDir. Fall back to /tmp on a regular Linux host.
PDOCKER_TMP = (os.environ.get("PDOCKER_TMP_DIR")
               or os.environ.get("TMPDIR")
               or "/tmp")
os.makedirs(PDOCKER_TMP, exist_ok=True)

_PROJECT_DIR = os.path.dirname(os.path.dirname(os.path.abspath(__file__)))
CRANE = os.path.join(_PROJECT_DIR, "docker-bin", "crane")
LIBCOW = os.path.join(_PROJECT_DIR, "lib", "libcow.so")
LIBCOW_MUSL = os.path.join(_PROJECT_DIR, "lib", "libcow-musl.so")
PLATFORM = os.environ.get("PDOCKER_PLATFORM", "linux/arm64")
FALLBACK_RESOLV_CONF = (
    os.environ.get("PDOCKER_FALLBACK_RESOLV_CONF")
    or "nameserver 8.8.8.8\nnameserver 1.1.1.1\n"
)


def _host_resolv_conf_text():
    runtime_resolv = os.path.join(_PROJECT_DIR, "etc", "resolv.conf")
    try:
        with open(runtime_resolv) as f:
            data = f.read()
            if data.strip():
                return data
    except OSError:
        pass
    try:
        with open("/etc/resolv.conf") as f:
            data = f.read()
            if data.strip():
                return data
    except OSError:
        pass
    return FALLBACK_RESOLV_CONF


def _prepare_rootfs_runtime_files(rootfs):
    etc = os.path.join(rootfs, "etc")
    os.makedirs(etc, exist_ok=True)
    with open(os.path.join(etc, "resolv.conf"), "w") as f:
        f.write(_host_resolv_conf_text())
    if RUNTIME_BACKEND.kind == "direct" and os.environ.get("PDOCKER_APT_SANDBOX_ROOT", "1") != "0":
        apt_conf = os.path.join(etc, "apt", "apt.conf.d")
        os.makedirs(apt_conf, exist_ok=True)
        with open(os.path.join(apt_conf, "00pdocker-direct-sandbox"), "w") as f:
            f.write('APT::Sandbox::User "root";\n')

# Optional prefix injected before every crane invocation. This is an explicit
# developer-supplied diagnostic hook only; the Android app uses the bridge-side
# CONNECT proxy instead of bundling or auto-discovering an external runtime.
# Value is pipe-separated argv.
_CRANE_WRAP_SPEC = os.environ.get("PDOCKER_CRANE_WRAP", "")
CRANE_WRAP = _CRANE_WRAP_SPEC.split("|") if _CRANE_WRAP_SPEC else []

def _crane(args):
    """Build the argv for a crane invocation, prepending CRANE_WRAP so every
    subprocess.run([CRANE, ...]) site uses explicit diagnostics uniformly."""
    crane_path = os.path.realpath(CRANE) if CRANE_WRAP else CRANE
    return CRANE_WRAP + [crane_path] + list(args)


def _run_crane(args, **kw):
    """Wrapper that runs a crane command and, on CalledProcessError, logs
    the captured stderr so container-land failures (DNS, TLS, proot)
    aren't swallowed. Drop-in replacement for subprocess.run at crane
    call sites."""
    argv = _crane(args)
    try:
        return subprocess.run(argv, **kw)
    except subprocess.CalledProcessError as e:
        tail = (e.stderr or b"").decode("utf-8", "replace").strip().splitlines()[-40:]
        log(f"crane failed (rc={e.returncode}): argv={argv}")
        for line in tail:
            log(f"crane stderr: {line}")
        raise

def _proot_runnable(path):
    """Check if this proot binary is executable on the current host.

    The bundled proot is built for Android (bionic, interpreter
    /system/bin/linker64) and will ENOENT at exec time on a regular
    Ubuntu/glibc host even though the file has +x. Probe with --help
    to catch that before we commit to it as the runner.
    """
    if not path or not os.path.isfile(path) or not os.access(path, os.X_OK):
        return False
    try:
        r = subprocess.run([path, "--version"],
                           stdout=subprocess.DEVNULL,
                           stderr=subprocess.DEVNULL,
                           timeout=5)
        return r.returncode == 0
    except (OSError, subprocess.SubprocessError):
        return False


def _find_runner():
    # Explicit override only. pdocker no longer auto-discovers Termux/system
    # proot, because the Android app runtime must not silently depend on an
    # external ptrace backend.
    override = os.environ.get("PDOCKER_RUNNER")
    if override and _proot_runnable(override):
        return override
    return None

RUNNER = _find_runner()
REQUESTED_RUNTIME_BACKEND = os.environ.get("PDOCKER_RUNTIME_BACKEND", "auto").strip().lower()
DIRECT_EXECUTOR = os.environ.get("PDOCKER_DIRECT_EXECUTOR", "").strip()
if os.environ.get("PDOCKER_DIRECT_EXPERIMENTAL_PROCESS_EXEC"):
    os.environ.setdefault("PDOCKER_DIRECT_TRACE_SYSCALLS", "0")
    os.environ.setdefault("PDOCKER_DIRECT_TRACE_MODE", "seccomp")


def _env_flag(name):
    return os.environ.get(name, "").lower() in ("1", "true", "yes", "on")


def _runner_supports_cow_bind():
    if DIRECT_EXECUTOR and os.path.exists(DIRECT_EXECUTOR):
        return True
    if not RUNNER:
        return False
    try:
        r = subprocess.run([RUNNER, "--help"],
                           stdout=subprocess.PIPE,
                           stderr=subprocess.STDOUT,
                           timeout=5)
    except (OSError, subprocess.SubprocessError):
        return False
    return b"--cow-bind" in r.stdout


USE_COW_BIND = _env_flag("PDOCKER_USE_COW_BIND")
COW_BIND_AVAILABLE = USE_COW_BIND and _runner_supports_cow_bind()
if USE_COW_BIND and not COW_BIND_AVAILABLE:
    sys.stderr.write("[pdockerd] PDOCKER_USE_COW_BIND=1 requested but runner lacks --cow-bind; using libcow rootfs materialization\n")
    sys.stderr.flush()


class RuntimeBackend:
    def __init__(self, kind, runner=None):
        self.kind = kind
        self.runner = runner

    @property
    def driver_name(self):
        if self.kind == "proot":
            return "external-cow"
        if self.kind == "direct":
            return "pdocker-direct"
        return "chroot-cow"

    @property
    def operating_system(self):
        if self.kind == "proot":
            return "PRoot Ubuntu"
        if self.kind == "direct":
            return "Android direct runtime"
        return "chroot rootfs"

    @property
    def info_id(self):
        return f"PDOCKER:{self.kind.upper()}"

    def unavailable_message(self):
        if self.kind == "proot" and not self.runner:
            return "pdocker runtime error: PRoot backend selected but no runnable proot binary was found."
        return ""

    def process_unavailable_message(self):
        fault = self.unavailable_message()
        if fault:
            return fault
        if self.kind == "direct" and not direct_executor_can_execute_processes():
            return direct_executor_unavailable_message()
        return ""

    @property
    def can_execute_processes(self):
        return not self.process_unavailable_message()

    def build_argv(self, rootfs, argv, inner_env, workdir="/", binds=None, cow_bind=None, mode="run"):
        fault = self.unavailable_message()
        if fault:
            raise RuntimeError(fault)

        if self.kind == "direct":
            fault = self.process_unavailable_message()
            if fault:
                raise RuntimeError(fault)
            return _direct_runtime_argv(
                rootfs, argv, inner_env, workdir, binds=binds,
                cow_bind=cow_bind, mode=mode,
            )

        if self.kind == "proot":
            bind_args = ["-b", "/proc", "-b", "/sys", "-b", "/dev"]
            for b in (binds or []):
                parts = b.split(":")
                if len(parts) < 2:
                    continue
                host, container = parts[0], parts[1]
                if not host or not container:
                    continue
                if not os.path.exists(host):
                    try:
                        os.makedirs(host, exist_ok=True)
                    except OSError:
                        continue
                bind_args.extend(["-b", f"{host}:{container}"])

            cow_args = []
            if cow_bind:
                cow_args = [
                    "--cow-bind",
                    f"{cow_bind['upper']}:{cow_bind['lower']}:{cow_bind.get('guest_path', '/')}",
                ]
            return [self.runner, "-0", "-r", rootfs,
                    *cow_args,
                    *bind_args,
                    "-w", workdir or "/",
                    "/usr/bin/env", "-i", *inner_env, *argv]

        return ["env", "-i", *inner_env, "chroot", rootfs, *argv]


def _select_runtime_backend():
    """Select the execution backend.

    `auto` preserves today's behavior. `direct`/`no-proot` is intentionally
    selectable before it is complete so the APK and UI can exercise packaging
    and diagnostics without silently falling back to PRoot.
    """
    if REQUESTED_RUNTIME_BACKEND in ("direct", "no-proot", "noproot"):
        return RuntimeBackend("direct")
    if REQUESTED_RUNTIME_BACKEND == "proot":
        return RuntimeBackend("proot", RUNNER)
    if REQUESTED_RUNTIME_BACKEND == "chroot":
        return RuntimeBackend("chroot")
    if DIRECT_EXECUTOR:
        return RuntimeBackend("direct")
    return RuntimeBackend("chroot")


RUNTIME_BACKEND = _select_runtime_backend()


def runtime_backend_kind():
    return RUNTIME_BACKEND.kind


def runtime_driver_name():
    return RUNTIME_BACKEND.driver_name


def runtime_operating_system():
    return RUNTIME_BACKEND.operating_system


def runtime_info_id():
    return RUNTIME_BACKEND.info_id


def runtime_backend_unavailable_message():
    return RUNTIME_BACKEND.unavailable_message()


def runtime_process_unavailable_message():
    return RUNTIME_BACKEND.process_unavailable_message()


_direct_executor_probe_cache = {}


def _direct_rootfs_path(rootfs, path):
    if not path or path == "/":
        return rootfs
    if os.path.isabs(path):
        return os.path.join(rootfs, path.lstrip("/"))
    return os.path.join(rootfs, path)


def _direct_workdir(rootfs, workdir):
    host_wd = _direct_rootfs_path(rootfs, workdir or "/")
    os.makedirs(host_wd, exist_ok=True)
    return host_wd


def direct_executor_unavailable_message():
    if DIRECT_EXECUTOR:
        probe = direct_executor_probe()
        if probe.get("probe_ok") and not probe.get("process_exec"):
            return (
                "pdocker runtime error: the configured no-PRoot/direct Android "
                f"executor {DIRECT_EXECUTOR!r} is installed, but it does not "
                "advertise process-exec=1 yet. Image pull, image browsing, "
                "Dockerfile/Compose editing, and Engine API metadata can run; "
                "RUN, docker run, docker exec, compose services, and published "
                "ports need the RuntimeBackend executor implementation."
            )
        return (
            "pdocker runtime error: the configured no-PRoot/direct Android "
            f"executor {DIRECT_EXECUTOR!r} did not pass the pdocker direct "
            "executor probe. docker run, docker exec, Dockerfile RUN, compose "
            "services, and published ports remain blocked."
        )
    return (
        "pdocker runtime error: the no-PRoot/direct Android execution backend "
        "can materialize images, browse files, and expose Docker metadata, but "
        "it cannot execute container processes yet. docker run, docker exec, "
        "compose services, and published ports require the direct executor "
        "implementation; pdocker will not start a fake listener in its place."
    )


def direct_executor_probe():
    if not DIRECT_EXECUTOR:
        return {
            "probe_ok": False,
            "process_exec": False,
            "output": "",
            "error": "PDOCKER_DIRECT_EXECUTOR is unset",
        }
    cached = _direct_executor_probe_cache.get(DIRECT_EXECUTOR)
    if cached is not None:
        return cached
    if not os.path.isfile(DIRECT_EXECUTOR) or not os.access(DIRECT_EXECUTOR, os.X_OK):
        result = {
            "probe_ok": False,
            "process_exec": False,
            "output": "",
            "error": "executor is missing or not executable",
        }
        _direct_executor_probe_cache[DIRECT_EXECUTOR] = result
        return result
    try:
        proc = subprocess.run(
            [DIRECT_EXECUTOR, "--pdocker-direct-probe"],
            stdout=subprocess.PIPE,
            stderr=subprocess.STDOUT,
            timeout=3,
        )
    except (OSError, subprocess.SubprocessError) as exc:
        result = {
            "probe_ok": False,
            "process_exec": False,
            "output": "",
            "error": str(exc),
        }
        _direct_executor_probe_cache[DIRECT_EXECUTOR] = result
        return result
    output = proc.stdout.decode("utf-8", "replace")
    result = {
        "probe_ok": proc.returncode == 0 and "pdocker-direct-executor:1" in output,
        "process_exec": proc.returncode == 0 and "process-exec=1" in output,
        "output": output,
        "error": "" if proc.returncode == 0 else f"probe exited {proc.returncode}",
    }
    _direct_executor_probe_cache[DIRECT_EXECUTOR] = result
    return result


def direct_executor_available():
    return bool(direct_executor_probe().get("probe_ok"))


def direct_executor_can_execute_processes():
    return bool(direct_executor_probe().get("probe_ok") and direct_executor_probe().get("process_exec"))


def _direct_runtime_argv(rootfs, argv, inner_env, workdir="/", binds=None, cow_bind=None, mode="run"):
    if not direct_executor_can_execute_processes():
        raise RuntimeError(direct_executor_unavailable_message())
    cmd = [
        DIRECT_EXECUTOR,
        "run",
        "--mode", mode,
        "--rootfs", rootfs,
        "--workdir", workdir or "/",
    ]
    for item in inner_env or []:
        if item.startswith("LD_PRELOAD="):
            continue
        cmd.extend(["--env", item])
    for bind in binds or []:
        cmd.extend(["--bind", bind])
    if cow_bind:
        cmd.extend([
            "--cow-upper", cow_bind.get("upper", ""),
            "--cow-lower", cow_bind.get("lower", ""),
            "--cow-guest", cow_bind.get("guest_path", "/"),
        ])
    cmd.append("--")
    cmd.extend(str(x) for x in (argv or []))
    return cmd


for d in [IMAGES_DIR, LAYERS_DIR, CONTAINERS_DIR, META_DIR, LOGS_DIR, VOLUMES_DIR, NETWORKS_DIR]:
    os.makedirs(d, exist_ok=True)

# In-memory state for running processes
running_containers = {}  # container_id -> Popen
running_lock = threading.Lock()

# Container create-time payloads (remembered until start)
container_configs = {}  # container_id -> dict

# Exec sessions
exec_sessions = {}  # exec_id -> dict

# Active daemon operations. This is intentionally daemon-owned instead of
# Android-UI-owned so adb/test-triggered builds are visible in the app too.
active_operations = {}
active_operations_lock = threading.Lock()

# Docker event stream compatibility. Events are kept on disk so reconnecting
# clients can replay recent state transitions, while active /events requests
# wait on a condition for live updates.
EVENTS_PATH = os.path.join(META_DIR, "events.jsonl")
events_lock = threading.Lock()
events_cond = threading.Condition(events_lock)


def start_operation(kind, title, detail=""):
    op_id = uuid.uuid4().hex
    now = time.time()
    with active_operations_lock:
        active_operations[op_id] = {
            "Id": op_id,
            "Kind": kind,
            "Title": title,
            "Detail": detail,
            "Status": "running",
            "StartedAt": now,
            "UpdatedAt": now,
        }
    return op_id


def update_operation(op_id, detail=None, status=None):
    if not op_id:
        return
    with active_operations_lock:
        op = active_operations.get(op_id)
        if not op:
            return
        if detail is not None:
            op["Detail"] = detail
        if status is not None:
            op["Status"] = status
        op["UpdatedAt"] = time.time()


def finish_operation(op_id, status="done", detail=None):
    if not op_id:
        return
    with active_operations_lock:
        op = active_operations.get(op_id)
        if not op:
            return
        if detail is not None:
            op["Detail"] = detail
        op["Status"] = status
        op["UpdatedAt"] = time.time()
        op["EndedAt"] = op["UpdatedAt"]
        active_operations.pop(op_id, None)


def list_active_operations():
    with active_operations_lock:
        return sorted(
            (dict(op) for op in active_operations.values()),
            key=lambda op: op.get("StartedAt", 0),
            reverse=True,
        )

# Log
def log(msg, **kwargs):
    kv = " ".join(f"{k}={v}" for k, v in kwargs.items())
    sys.stderr.write(f"[pdockerd] {msg} {kv}\n".rstrip() + "\n")
    sys.stderr.flush()


# ---- Rootfs preparation and execution helpers ----

_MERGED_USR = {"bin", "lib", "lib32", "lib64", "libx32", "sbin"}


def _is_musl_rootfs(rootfs):
    """Detect musl libc by presence of ld-musl-*.so.1 (alpine etc.)."""
    for d in ("lib", "usr/lib"):
        try:
            for f in os.listdir(os.path.join(rootfs, d)):
                if f.startswith("ld-musl-") and f.endswith(".so.1"):
                    return True
        except OSError:
            pass
    return False


def _clone_tree(src, dst):
    """Clone src → dst: hardlink regular files, re-create symlinks."""
    os.makedirs(dst, exist_ok=True)
    for root, dirs, files in os.walk(src, followlinks=False):
        rel = os.path.relpath(root, src)
        dstroot = dst if rel == "." else os.path.join(dst, rel)
        os.makedirs(dstroot, exist_ok=True)
        for name in list(dirs) + list(files):
            s = os.path.join(root, name)
            d = os.path.join(dstroot, name)
            if os.path.islink(s):
                if os.path.lexists(d):
                    continue
                os.symlink(os.readlink(s), d)
            elif os.path.isfile(s):
                try:
                    os.link(s, d)
                except FileExistsError:
                    pass
                except OSError:
                    _copy_no_xattr(s, d)
        dirs[:] = [x for x in dirs if not os.path.islink(os.path.join(root, x))]


def _copy_no_xattr(src, dst):
    """shutil.copy2 substitute that skips xattr/flag copying. Android's
    SELinux denies setxattr in the security.* namespace on app_data_file
    files, so the standard copy2 path raises EACCES on every file copy.
    We still preserve the byte content + mode bits + mtime, which is all
    pdockerd needs for layer/container rootfs cloning."""
    shutil.copyfile(src, dst, follow_symlinks=False)
    try:
        st = os.lstat(src)
        os.chmod(dst, st.st_mode & 0o7777)
        os.utime(dst, ns=(st.st_atime_ns, st.st_mtime_ns), follow_symlinks=False)
    except OSError:
        pass


def _ensure_rootfs_dir_path(rootfs, path):
    """Ensure a rootfs-relative directory path is writable.

    Some Android materialization modes preserve lower-layer directory
    symlinks. Dockerfile COPY needs an upper, writable directory instead of
    following an absolute symlink out to the Android host.
    """
    rel = os.path.relpath(path, rootfs)
    cur = rootfs
    if rel == ".":
        return cur
    for part in rel.split(os.sep):
        cur = os.path.join(cur, part)
        if os.path.islink(cur):
            os.unlink(cur)
        os.makedirs(cur, exist_ok=True)
    return cur


def _flatten_merged_usr(dst_rootfs):
    """Legacy PRoot-only merged-usr workaround.

    This function intentionally does nothing for current pdocker materialization.
    Docker/OCI rootfs content must preserve top-level symlinks such as
    `/bin -> usr/bin`; replacing them with real directories breaks image
    interchange semantics and caused the direct runtime to need incorrect
    `/bin` to `/usr/bin` path fallbacks.

    Keep the function as a named historical marker because older notes and
    tests refer to "merged-usr flattening", but do not call it for normal image
    or container rootfs creation.
    """
    return
    for top in _MERGED_USR:
        link_path = os.path.join(dst_rootfs, top)
        if not os.path.islink(link_path):
            continue
        tgt = os.readlink(link_path)
        abs_tgt = (os.path.join(dst_rootfs, tgt.lstrip("/"))
                   if tgt.startswith("/")
                   else os.path.normpath(os.path.join(dst_rootfs, tgt)))
        if not os.path.isdir(abs_tgt):
            continue
        os.unlink(link_path)
        os.makedirs(link_path)
        _clone_tree(abs_tgt, link_path)


def _install_libcow(dst_rootfs):
    """Install CoW shim inside the rootfs so LD_PRELOAD resolves it after
    userspace rootfs path translation. Pick musl vs glibc variant by sniffing the
    rootfs linker — the glibc shim links against ld-linux-* and explodes
    inside an alpine rootfs that ships ld-musl-*.
    """
    src = LIBCOW_MUSL if _is_musl_rootfs(dst_rootfs) else LIBCOW
    if os.path.exists(src):
        try:
            shutil.copy(src, os.path.join(dst_rootfs, ".libcow.so"))
            os.chmod(os.path.join(dst_rootfs, ".libcow.so"), 0o755)
        except Exception as e:
            log(f"warn: cannot install libcow: {e}")


def clone_image_rootfs(src_rootfs, dst_rootfs):
    """Legacy flatten path — clones a monolithic image rootfs into a
    container rootfs. Retained for images pulled before the layer-aware
    pull was introduced (no manifest.json), and for fallback when layer
    materialization fails.

    Overcomes the old `cp -al` issue where symlinks could be dropped by
    explicitly recreating symlinks. It must not flatten merged-usr symlinks;
    `/bin`, `/sbin`, `/lib`, and `/lib64` are image data.
    """
    _clone_tree(src_rootfs, dst_rootfs)
    _install_libcow(dst_rootfs)


def materialize_container_rootfs(dst_rootfs, diff_ids):
    """Overlayfs-equivalent container rootfs build: apply image layers
    (lowest first) into `dst_rootfs` using hardlink-clone + whiteout
    semantics, then install libcow.so.

    The resulting rootfs is a merged view — regular files share inodes
    with their source layer tree under LAYERS_DIR (so N containers from
    the same image cost ~0 extra disk). Writes trigger break_hardlink
    inside libcow, which materializes a per-container upper on demand.
    """
    os.makedirs(dst_rootfs, exist_ok=True)
    merge_layers_into(dst_rootfs, diff_ids)
    ensure_rootfs_dynamic_loader(dst_rootfs, diff_ids)
    _install_libcow(dst_rootfs)


def ensure_rootfs_dynamic_loader(dst_rootfs, diff_ids):
    """Keep the rootfs dynamic loader executable after userspace layer merge.

    Android direct execution depends on the image's own ELF interpreter. Some
    package-manager layer transitions can leave the merged rootfs with the
    loader symlink but without the target file; recover it from the layer stack
    so subsequent RUN/exec steps observe Docker image content.
    """
    loader_rels = (
        "usr/lib/aarch64-linux-gnu/ld-linux-aarch64.so.1",
        "lib/aarch64-linux-gnu/ld-linux-aarch64.so.1",
        "lib/ld-linux-aarch64.so.1",
        "lib64/ld-linux-aarch64.so.1",
    )
    for rel in loader_rels:
        p = os.path.join(dst_rootfs, rel)
        if os.path.isfile(p) and not os.path.islink(p):
            return None
    for did in reversed(diff_ids or []):
        tree = _layer_tree(did)
        for rel in loader_rels:
            src = os.path.join(tree, rel)
            if not os.path.isfile(src):
                continue
            dst = os.path.join(dst_rootfs, rel)
            os.makedirs(os.path.dirname(dst), exist_ok=True)
            if os.path.lexists(dst) and not os.path.isdir(dst):
                try:
                    os.unlink(dst)
                except OSError:
                    pass
            _copy_no_xattr(src, dst)
            return rel
    return None


def _container_cow_bind(state):
    storage = state.get("Storage") or {}
    if storage.get("Mode") != "cow_bind":
        return None
    lower = storage.get("LowerDir")
    upper = storage.get("UpperDir")
    if not lower or not upper:
        return None
    return {"lower": lower, "upper": upper, "guest_path": "/"}


def _container_rootfs_path(state, cdir):
    cow = _container_cow_bind(state)
    if cow:
        return cow["lower"]
    return os.path.join(cdir, "rootfs")


def _container_runtime(state):
    cdir = os.path.join(CONTAINERS_DIR, state["Id"])
    cow = _container_cow_bind(state)
    rootfs = _container_rootfs_path(state, cdir)
    return cdir, cow, rootfs


def _write_container_file(state, cdir, relpath, content):
    """Write a container-visible file. In cow_bind mode this pre-seeds the
    upperdir; in the legacy mode it writes into the materialized rootfs."""
    cow = _container_cow_bind(state)
    base = cow["upper"] if cow else os.path.join(cdir, "rootfs")
    dst = os.path.join(base, relpath.lstrip("/"))
    os.makedirs(os.path.dirname(dst), exist_ok=True)
    with open(dst, "w") as f:
        f.write(content)


def _container_env(state, extra=None):
    env = {"HOME": "/root", "TERM": os.environ.get("TERM", "xterm")}
    for item in state.get("Env", []):
        if "=" in item:
            k, v = item.split("=", 1)
            env[k] = v
    for item in (extra or []):
        if "=" in item:
            k, v = item.split("=", 1)
            env[k] = v
    return env


def _join_under(base, relpath):
    path = os.path.normpath(os.path.join(base, relpath.lstrip("/")))
    try:
        if os.path.commonpath([base, path]) != base:
            return None
    except ValueError:
        return None
    return path


def _container_host_path(state, cdir, ctr_path, for_write=False):
    """Resolve a container path to the best host path.

    In cow_bind mode reads prefer upper when present and otherwise fall back to
    lower. Writes always target upper, creating the directory if the lower path
    is an existing directory. This keeps docker cp/archive operations aligned
    with the lower/upper storage split.
    """
    cow = _container_cow_bind(state)
    rel = ctr_path.lstrip("/")
    if not cow:
        return _join_under(os.path.join(cdir, "rootfs"), rel)

    upper = _join_under(cow["upper"], rel)
    lower = _join_under(cow["lower"], rel)
    if upper is None or lower is None:
        return None
    if for_write:
        if os.path.isdir(lower) and not os.path.exists(upper):
            os.makedirs(upper, exist_ok=True)
        return upper
    return upper if os.path.lexists(upper) else lower


# ============================================================
# Layer storage (OCI-style content-addressable layer pool)
# ============================================================
#
# Each layer is a content-addressable tarball (sha256 of the *compressed*
# tar = OCI "digest"; sha256 of the *uncompressed* tar = OCI "diff_id").
# All images reference layers by diff_id and reuse the same extracted
# `tree/` directory on disk → storage is deduplicated across images.
#
# Runtime merge (container start) rebuilds an overlayfs-like merged view
# by applying layers in order with proper whiteout semantics:
#   - `.wh.<name>`       — remove <name> from lower
#   - `.wh..wh..opq`     — opaque dir: clear lower and apply upper only
#   - `trusted.overlay.redirect` xattr — honor source redirect
#
# This is the "overlayfs in userspace" substrate — the libcow.so shim
# only provides the upper CoW above it.


WHITEOUT_PREFIX = ".wh."
OPAQUE_MARKER = ".wh..wh..opq"


def _sha256_file(path):
    import hashlib
    h = hashlib.sha256()
    with open(path, "rb") as f:
        for chunk in iter(lambda: f.read(1 << 20), b""):
            h.update(chunk)
    return h.hexdigest()


def _layer_dir(diff_id):
    """`$LAYERS_DIR/<sha256>/` — diff_id is the uncompressed-tar sha256."""
    return os.path.join(LAYERS_DIR, diff_id)


def _layer_tree(diff_id):
    """Extracted layer content (may contain .wh.* whiteout markers)."""
    return os.path.join(_layer_dir(diff_id), "tree")


def _layer_exists(diff_id):
    return os.path.isdir(_layer_tree(diff_id))


def _layer_size(diff_id):
    bare = diff_id.split(":", 1)[-1]
    mp = os.path.join(_layer_dir(bare), "meta.json")
    try:
        with open(mp) as f:
            return int((json.load(f) or {}).get("size", 0) or 0)
    except (OSError, ValueError, TypeError, json.JSONDecodeError):
        return 0


def _stable_json_hash(payload):
    data = json.dumps(payload, sort_keys=True, separators=(",", ":")).encode("utf-8")
    return hashlib.sha256(data).hexdigest()


def _build_cache_enabled():
    return os.environ.get("PDOCKER_BUILD_CACHE", "1") != "0"


def build_cache_key(kind, payload, parent_diff_ids, state=None):
    """Return a deterministic cache key for a Dockerfile filesystem layer.

    The cache intentionally follows Docker's coarse semantics: a RUN result is
    reusable when the parent layer stack and command/config state match. It does
    not try to inspect network freshness; users can invalidate by changing the
    Dockerfile or clearing the build cache.
    """
    return _stable_json_hash({
        "version": 1,
        "kind": kind,
        "payload": payload,
        "parents": [d.split(":", 1)[-1] for d in parent_diff_ids],
        "state": state or {},
    })


def _build_cache_path(key):
    return os.path.join(BUILD_CACHE_DIR, f"{key}.json")


def load_build_cache_entry(key):
    if not _build_cache_enabled():
        return None
    try:
        with open(_build_cache_path(key)) as f:
            entry = json.load(f)
    except (OSError, json.JSONDecodeError):
        return None
    did = str(entry.get("diff_id", "")).split(":", 1)[-1]
    if not re.fullmatch(r"[A-Fa-f0-9]{64}", did or ""):
        return None
    if not _layer_exists(did):
        return None
    entry["diff_id"] = did
    return entry


def store_build_cache_entry(key, entry):
    if not _build_cache_enabled():
        return
    os.makedirs(BUILD_CACHE_DIR, exist_ok=True)
    data = dict(entry)
    data["created"] = time.strftime("%Y-%m-%dT%H:%M:%SZ", time.gmtime())
    data["key"] = key
    tmp = _build_cache_path(key) + ".tmp"
    with open(tmp, "w") as f:
        json.dump(data, f, indent=2, sort_keys=True)
    os.replace(tmp, _build_cache_path(key))


def _extract_layer_python(tar_path, tree):
    """Python-tarfile layer extractor. Used when PDOCKER_LINK_MODE forbids
    `link` (Android sandboxes hit EACCES on hardlink creation even in the
    app's own data dir). On a hardlink entry, fall back to `symlink`
    (same inode feel, trivial cost) or `copy` (full duplication) per the
    env var."""
    mode = os.environ.get("PDOCKER_LINK_MODE", "hard")
    with tarfile.open(tar_path, "r") as tf:
        for m in tf:
            dst = os.path.join(tree, m.name)
            # Strip any absolute prefix so tar entries stay under tree/.
            if m.islnk():
                # Hardlink entry (m.linkname points at another archive member
                # already extracted before this).
                src = os.path.join(tree, m.linkname)
                _mkparent(dst)
                try: os.remove(dst)
                except OSError: pass
                if mode == "symlink":
                    # relative symlink so the tree remains relocatable
                    rel = os.path.relpath(src, os.path.dirname(dst))
                    os.symlink(rel, dst)
                elif mode == "copy":
                    _copy_no_xattr(src, dst)
                else:
                    os.link(src, dst)
            else:
                tf.extract(m, tree, numeric_owner=True)


def _mkparent(path):
    d = os.path.dirname(path)
    if d:
        os.makedirs(d, exist_ok=True)


def _extract_layer_tar(tar_path, diff_id):
    """Extract a layer tarball into LAYERS_DIR/<diff_id>/tree/ idempotently.

    Preserves whiteout markers as-is (do NOT delete `.wh.*` here — they are
    consumed at merge time). Skips if layer already extracted.
    """
    ldir = _layer_dir(diff_id)
    tree = _layer_tree(diff_id)
    if os.path.isdir(tree):
        return False
    os.makedirs(tree, exist_ok=True)
    link_mode = os.environ.get("PDOCKER_LINK_MODE", "hard")
    if link_mode != "hard":
        # Android SELinux denies link() on app_data_file — tar(1) falls
        # over on hardlink entries. Use the Python path with symlink/copy
        # fallback instead.
        try:
            _extract_layer_python(tar_path, tree)
        except Exception as e:
            shutil.rmtree(ldir, ignore_errors=True)
            raise RuntimeError(f"layer extract failed (python): {e}")
    else:
        # Use tar(1) — faster than Python tarfile for large images and
        # handles xattr / hardlink tar entries correctly.
        r = subprocess.run(
            ["tar", "-xf", tar_path, "-C", tree, "--numeric-owner"],
            stdout=subprocess.PIPE, stderr=subprocess.PIPE,
        )
        if r.returncode != 0:
            shutil.rmtree(ldir, ignore_errors=True)
            raise RuntimeError(
                f"layer extract failed: {r.stderr.decode('utf-8', 'replace')[:200]}"
            )
    # Record metadata (per-file try/except — one broken symlink shouldn't
    # zero out the whole total).
    size = 0
    for root, _, files in os.walk(tree):
        for f in files:
            try:
                size += os.path.getsize(os.path.join(root, f))
            except OSError:
                pass
    meta = {"diff_id": f"sha256:{diff_id}", "size": size,
            "created": time.strftime("%Y-%m-%dT%H:%M:%SZ", time.gmtime())}
    with open(os.path.join(ldir, "meta.json"), "w") as f:
        json.dump(meta, f)
    return True


def _hardlink_clone_tree(src, dst):
    """Hardlink-copy `src` tree into `dst` (overlayfs-style upper-on-lower merge).

    - Regular files: os.link() (hardlink — shares inode with src). If dst
      already has a non-dir entry at the same path it is removed first (upper
      overrides lower). If dst has a directory there, we rmtree it (upper
      file replaces lower dir — rare but valid in OCI layers).
    - Symlinks: re-create with os.symlink. Existing non-dir dst removed; dir
      dst rmtree'd.
    - Directories: ensure dst_root is a directory. If an existing non-dir
      blocks it (lower had a file, upper has a dir), remove the blocker then
      mkdir. Mode copied from src.
    - Special (char/block/fifo): skip (PRoot can't mknod; also rare in images).

    This is the "copy_up" step of overlayfs merge_layers_into: whiteouts have
    already been applied by `_apply_whiteouts_in_tree`, so anything remaining
    in dst is lower content that upper legitimately overrides at same path.
    """
    def _clobber(path):
        """Remove path regardless of type. Returns True on success."""
        try:
            if os.path.islink(path) or not os.path.isdir(path):
                os.remove(path)
            else:
                shutil.rmtree(path, ignore_errors=True)
            return True
        except OSError:
            return False

    for root, dirs, files in os.walk(src, followlinks=False):
        rel = os.path.relpath(root, src)
        dst_root = dst if rel == "." else os.path.join(dst, rel)
        # Ensure dst_root is a directory (clobber non-dir blockers)
        if os.path.lexists(dst_root) and (
            os.path.islink(dst_root) or not os.path.isdir(dst_root)
        ):
            _clobber(dst_root)
        if not os.path.isdir(dst_root):
            try:
                os.makedirs(dst_root, exist_ok=True)
            except OSError:
                pass
        try:
            st = os.lstat(root)
            os.chmod(dst_root, st.st_mode & 0o7777)
        except OSError:
            pass
        # Recreate symlinks and hardlink files
        for name in files + dirs:
            sp = os.path.join(root, name)
            dp = os.path.join(dst_root, name)
            try:
                st = os.lstat(sp)
            except OSError:
                continue
            if os.path.islink(sp):
                if os.path.lexists(dp):
                    _clobber(dp)
                try:
                    os.symlink(os.readlink(sp), dp)
                except OSError:
                    pass
            elif stat_mod.S_ISDIR(st.st_mode):
                # Directory entry in upper — ensure dp is a dir (clobber non-dir).
                # Contents are populated by os.walk recursion.
                if os.path.lexists(dp) and (
                    os.path.islink(dp) or not os.path.isdir(dp)
                ):
                    _clobber(dp)
                if not os.path.isdir(dp):
                    try:
                        os.makedirs(dp, exist_ok=True)
                    except OSError:
                        pass
            elif stat_mod.S_ISREG(st.st_mode):
                # Regular file: upper overrides lower at same path.
                if os.path.lexists(dp):
                    # If dp is already a hardlink to the same inode, skip —
                    # this happens when the same layer is reapplied.
                    try:
                        if os.lstat(dp).st_ino == st.st_ino:
                            continue
                    except OSError:
                        pass
                    _clobber(dp)
                try:
                    os.link(sp, dp)
                except OSError:
                    try:
                        _copy_no_xattr(sp, dp)
                    except OSError:
                        pass
            # Special files (char/block/fifo/socket) — skip silently.


def _apply_whiteouts_in_tree(layer_tree, target_root):
    """Consume `.wh.*` markers from `layer_tree` and apply them to `target_root`.

    - `<dir>/.wh..wh..opq` → clear every entry under `<dir>` in target
    - `<dir>/.wh.<name>`   → remove `<dir>/<name>` from target
    """
    for root, dirs, files in os.walk(layer_tree, followlinks=False):
        rel = os.path.relpath(root, layer_tree)
        tgt_dir = target_root if rel == "." else os.path.join(target_root, rel)
        if OPAQUE_MARKER in files:
            if os.path.isdir(tgt_dir):
                for entry in os.listdir(tgt_dir):
                    ep = os.path.join(tgt_dir, entry)
                    if os.path.islink(ep) or not os.path.isdir(ep):
                        try:
                            os.remove(ep)
                        except OSError:
                            pass
                    else:
                        shutil.rmtree(ep, ignore_errors=True)
        for fn in files:
            if fn.startswith(WHITEOUT_PREFIX) and fn != OPAQUE_MARKER:
                target_name = fn[len(WHITEOUT_PREFIX):]
                victim = os.path.join(tgt_dir, target_name)
                if os.path.islink(victim) or (os.path.isfile(victim) and not os.path.isdir(victim)):
                    try:
                        os.remove(victim)
                    except OSError:
                        pass
                elif os.path.isdir(victim):
                    shutil.rmtree(victim, ignore_errors=True)


def _strip_whiteout_markers(target_root):
    """Remove any `.wh.*` files that leaked into the merged tree."""
    for root, _, files in os.walk(target_root, followlinks=False):
        for fn in files:
            if fn.startswith(WHITEOUT_PREFIX):
                try:
                    os.remove(os.path.join(root, fn))
                except OSError:
                    pass


def merge_layers_into(target_rootfs, diff_ids):
    """Apply layers in order (lowest first) into target_rootfs.

    For each layer:
      1. Apply whiteouts/opaque markers to the already-merged target
      2. Hardlink-clone the layer tree on top
      3. Strip leftover `.wh.*` markers from the merged view

    This produces an overlayfs-equivalent merged rootfs using only hardlinks
    + userspace semantics (no kernel mount, no CAP_SYS_ADMIN).
    """
    os.makedirs(target_rootfs, exist_ok=True)
    for did in diff_ids:
        bare = did.split(":", 1)[-1]  # strip optional sha256: prefix
        tree = _layer_tree(bare)
        if not os.path.isdir(tree):
            raise FileNotFoundError(f"layer not extracted: {did}")
        _apply_whiteouts_in_tree(tree, target_rootfs)
        _hardlink_clone_tree(tree, target_rootfs)
    _strip_whiteout_markers(target_rootfs)


def _image_manifest_path(img_tag_dir):
    return os.path.join(img_tag_dir, "manifest.json")


def _save_image_manifest(img_tag_dir, diff_ids, config=None):
    """Persist layer digest list + image config for a tag."""
    os.makedirs(img_tag_dir, exist_ok=True)
    manifest = {
        "schemaVersion": 2,
        "mediaType": "application/vnd.oci.image.manifest.v1+json",
        "layers": [
            {"mediaType": "application/vnd.oci.image.layer.v1.tar",
             "digest": d if d.startswith("sha256:") else f"sha256:{d}",
             "diff_id": d if d.startswith("sha256:") else f"sha256:{d}"}
            for d in diff_ids
        ],
        "config_ref": "config.json",
    }
    with open(_image_manifest_path(img_tag_dir), "w") as f:
        json.dump(manifest, f, indent=2)
    if config is not None:
        with open(os.path.join(img_tag_dir, "config.json"), "w") as f:
            json.dump(config, f, indent=2)


def _load_image_manifest(img_tag_dir):
    """Return list of diff_ids for this image, or [] if manifest missing."""
    mp = _image_manifest_path(img_tag_dir)
    if not os.path.exists(mp):
        return []
    try:
        with open(mp) as f:
            m = json.load(f)
    except (OSError, json.JSONDecodeError):
        return []
    out = []
    for l in m.get("layers") or []:
        did = l.get("diff_id") or l.get("digest") or ""
        if did:
            out.append(did.split(":", 1)[-1])
    return out


def _dockerignore_rules(context_dir):
    """Parse the practical .dockerignore subset used by Docker CLI contexts."""
    path = os.path.join(context_dir, ".dockerignore")
    if not os.path.exists(path):
        return []
    rules = []
    with open(path, errors="replace") as f:
        for raw in f:
            line = raw.strip()
            if not line or line.startswith("#"):
                continue
            negated = line.startswith("!")
            if negated:
                line = line[1:].strip()
            line = line.replace("\\", "/").strip("/")
            if not line or line == ".":
                continue
            directory_only = line.endswith("/")
            line = line.rstrip("/")
            rules.append({
                "pattern": line,
                "negated": negated,
                "directory_only": directory_only,
                "basename_only": "/" not in line,
            })
    return rules


def _dockerignore_rule_matches(rule, rel, is_dir):
    pattern = rule["pattern"]
    rel = rel.replace(os.sep, "/").strip("/")
    if not rel:
        return False
    if rule["directory_only"]:
        if not is_dir and not rel.startswith(pattern + "/"):
            return False
        if rule["basename_only"]:
            return any(fnmatch.fnmatchcase(part, pattern) for part in rel.split("/"))
        return rel == pattern or rel.startswith(pattern + "/") \
            or fnmatch.fnmatchcase(rel, pattern) \
            or fnmatch.fnmatchcase(rel, pattern + "/*")
    if rule["basename_only"]:
        return any(fnmatch.fnmatchcase(part, pattern) for part in rel.split("/"))
    return fnmatch.fnmatchcase(rel, pattern) or fnmatch.fnmatchcase(rel, pattern + "/*")


def _dockerignore_excluded(rules, rel, is_dir):
    ignored = False
    for rule in rules:
        if _dockerignore_rule_matches(rule, rel, is_dir):
            ignored = not rule["negated"]
    return ignored


def apply_dockerignore(context_dir, emit=None):
    """Remove .dockerignore-excluded entries from an extracted build context.

    Docker CLI normally filters before uploading the context. API clients may
    not, and pdockerd's legacy builder also benefits from an explicit server
    side pass for direct tests and non-standard clients.
    """
    rules = _dockerignore_rules(context_dir)
    if not rules:
        return 0
    doomed = []
    for root, dirs, files in os.walk(context_dir, topdown=True):
        rel_root = os.path.relpath(root, context_dir)
        if rel_root == ".":
            rel_root = ""
        for name in list(dirs):
            rel = "/".join(p for p in (rel_root, name) if p)
            if _dockerignore_excluded(rules, rel, True):
                doomed.append(os.path.join(root, name))
        for name in files:
            rel = "/".join(p for p in (rel_root, name) if p)
            if _dockerignore_excluded(rules, rel, False):
                doomed.append(os.path.join(root, name))
    removed = 0
    for path in sorted(doomed, key=lambda p: p.count(os.sep), reverse=True):
        if not os.path.lexists(path):
            continue
        if os.path.isdir(path) and not os.path.islink(path):
            shutil.rmtree(path, ignore_errors=True)
        else:
            try:
                os.unlink(path)
            except FileNotFoundError:
                pass
        removed += 1
    if removed and emit:
        emit(f"  .dockerignore excluded {removed} entr{'y' if removed == 1 else 'ies'}")
    return removed


def _profile_add(profile, key, seconds):
    if profile is not None:
        profile[key] = profile.get(key, 0.0) + seconds


def _delete_layer_index_path(index, rel_path):
    prefix = rel_path + os.sep
    for key in list(index.keys()):
        if key == rel_path or key.startswith(prefix):
            index.pop(key, None)


def _build_layer_index(diff_ids, skip_paths=None, profile=None):
    """Build the merged prior-layer path map without materializing a rootfs.

    `_snapshot_tree_as_layer` only needs to know whether a current path differs
    from the previous merged view. Creating that previous view with
    `merge_layers_into()` was the dominant cost for large dev images. This
    index applies whiteout semantics directly while walking layer trees, then
    points each live path at its source entry under LAYERS_DIR.
    """
    start = time.perf_counter()
    skip_paths = set(skip_paths or [])
    index = {}

    def _skipped(p_rel):
        if p_rel in skip_paths:
            return True
        for sp in skip_paths:
            if p_rel.startswith(sp + os.sep):
                return True
        return False

    for did in diff_ids or []:
        tree = _layer_tree(did.split(":", 1)[-1])
        if not os.path.isdir(tree):
            raise FileNotFoundError(f"layer not extracted: {did}")

        for root, dirs, files in os.walk(tree, followlinks=False):
            rel = os.path.relpath(root, tree)
            rel_prefix = "" if rel == "." else rel + os.sep

            if OPAQUE_MARKER in files:
                if rel == ".":
                    index.clear()
                else:
                    prefix = rel + os.sep
                    for key in list(index.keys()):
                        if key.startswith(prefix):
                            index.pop(key, None)

            for fn in files:
                if fn.startswith(WHITEOUT_PREFIX) and fn != OPAQUE_MARKER:
                    _delete_layer_index_path(index, rel_prefix + fn[len(WHITEOUT_PREFIX):])

            for name in list(dirs) + list(files):
                if name.startswith(WHITEOUT_PREFIX):
                    continue
                p_rel = rel_prefix + name
                if _skipped(p_rel):
                    continue
                index[p_rel] = os.path.join(root, name)
    _profile_add(profile, "prev_index", time.perf_counter() - start)
    if profile is not None:
        profile["prev_paths"] = len(index)
    return index


def _snapshot_tree_as_layer(src_tree, prev_diff_ids=None, skip_paths=None,
                            profile=None, changed_paths=None,
                            deleted_paths=None):
    """Tar the contents of `src_tree`, compute diff_id, extract to LAYERS_DIR.

    When prev_diff_ids is given, emit only the *delta* vs. the materialized
    merged view of those prev layers (added/modified files + whiteout markers
    for removed ones). Otherwise snapshot the whole tree (full base layer).

    skip_paths: iterable of rel paths (relative to src_tree) to exclude from
    both the added/modified set and the whiteout set — use it to drop
    runtime-only artifacts like `.libcow.so`, `etc/resolv.conf`, `etc/hosts`.

    Returns diff_id (str, no sha256: prefix).
    """
    skip_paths = set(skip_paths or [])
    import hashlib
    tmp_tar = os.path.join(PDOCKER_TMP, f"pdlayer_{uuid.uuid4().hex}.tar")

    prev_index = (
        {}
        if changed_paths is not None
        else (_build_layer_index(prev_diff_ids, skip_paths, profile) if prev_diff_ids else {})
    )

    def _skipped(p_rel):
        if p_rel in skip_paths:
            return True
        # Skip any descendant of a skipped dir
        for sp in skip_paths:
            if p_rel.startswith(sp + os.sep):
                return True
        return False

    def _add_changed_path(out, seen_paths, p_rel):
        p_rel = os.path.normpath(p_rel.strip("/"))
        if not p_rel or p_rel == "." or _skipped(p_rel) or p_rel in seen_paths:
            return
        sp = os.path.join(src_tree, p_rel)
        if not os.path.lexists(sp):
            return
        if os.path.isdir(sp) and not os.path.islink(sp):
            for root, dirs, files in os.walk(sp, followlinks=False):
                rel = os.path.relpath(root, src_tree)
                if rel != "." and not _skipped(rel) and rel not in seen_paths:
                    seen_paths.add(rel)
                    out.append(rel)
                for name in list(dirs) + list(files):
                    child = os.path.join(rel, name) if rel != "." else name
                    if not _skipped(child) and child not in seen_paths:
                        seen_paths.add(child)
                        out.append(child)
        else:
            seen_paths.add(p_rel)
            out.append(p_rel)

    # Walk src_tree and build file list (added/modified paths relative to
    # root). Three comparison modes:
    #   symlinks   — equal if readlink target matches (inodes differ per
    #                merge because symlinks are freshly-created, not
    #                hardlinked)
    #   directories— equal if present in diff_base (dir inodes always
    #                differ; contents are walked separately)
    #   regular    — equal if st_ino matches (hardlinks share inode)
    import stat
    paths = []
    seen = set()
    if changed_paths is not None:
        walk_start = time.perf_counter()
        for p_rel in changed_paths:
            _add_changed_path(paths, seen, p_rel)
        _profile_add(profile, "walk_current", time.perf_counter() - walk_start)
    else:
        walk_start = time.perf_counter()
        for root, dirs, files in os.walk(src_tree, followlinks=False):
            rel = os.path.relpath(root, src_tree)
            for name in list(dirs) + list(files):
                p_rel = name if rel == "." else os.path.join(rel, name)
                if _skipped(p_rel):
                    continue
                sp = os.path.join(src_tree, p_rel)
                bp = prev_index.get(p_rel)
                seen.add(p_rel)
                if bp is not None and os.path.lexists(bp):
                    try:
                        sp_st = os.lstat(sp)
                        bp_st = os.lstat(bp)
                        if stat.S_ISLNK(sp_st.st_mode) and stat.S_ISLNK(bp_st.st_mode):
                            if os.readlink(sp) == os.readlink(bp):
                                continue
                        elif stat.S_ISDIR(sp_st.st_mode) and stat.S_ISDIR(bp_st.st_mode):
                            # Unchanged dir — contents walked independently
                            continue
                        elif sp_st.st_ino == bp_st.st_ino:
                            continue
                    except OSError:
                        pass
                paths.append(p_rel)
        _profile_add(profile, "walk_current", time.perf_counter() - walk_start)

    # Emit whiteouts for deletions (present in base, absent in src)
    whiteouts = []
    whiteout_start = time.perf_counter()
    if changed_paths is not None:
        for p_rel in deleted_paths or []:
            p_rel = os.path.normpath(p_rel.strip("/"))
            if p_rel and p_rel != "." and not _skipped(p_rel):
                whiteouts.append(p_rel)
    else:
        for p_rel in prev_index:
            if _skipped(p_rel):
                continue
            if p_rel not in seen and not os.path.lexists(os.path.join(src_tree, p_rel)):
                whiteouts.append(p_rel)
    _profile_add(profile, "whiteouts", time.perf_counter() - whiteout_start)
    if profile is not None:
        profile["changed_paths"] = len(paths)
        profile["whiteout_paths"] = len(whiteouts)
        profile["seen_paths"] = len(seen)

    # Stage a tar build directory (we may need to inject whiteouts)
    stage = os.path.join(PDOCKER_TMP, f"pdstage_{uuid.uuid4().hex}")
    os.makedirs(stage, exist_ok=True)
    try:
        # Hardlink-copy the changed paths into stage
        stage_start = time.perf_counter()
        for p_rel in paths:
            sp = os.path.join(src_tree, p_rel)
            dp = os.path.join(stage, p_rel)
            os.makedirs(os.path.dirname(dp), exist_ok=True)
            if os.path.islink(sp):
                try:
                    os.symlink(os.readlink(sp), dp)
                except OSError:
                    pass
            elif os.path.isdir(sp):
                os.makedirs(dp, exist_ok=True)
            else:
                try:
                    os.link(sp, dp)
                except OSError:
                    try:
                        _copy_no_xattr(sp, dp)
                    except OSError:
                        pass
        # Drop whiteout markers
        for w in whiteouts:
            parent = os.path.dirname(w)
            name = os.path.basename(w)
            wp = os.path.join(stage, parent, WHITEOUT_PREFIX + name)
            os.makedirs(os.path.join(stage, parent), exist_ok=True)
            open(wp, "wb").close()
        _profile_add(profile, "stage", time.perf_counter() - stage_start)

        # Tar + digest
        tar_start = time.perf_counter()
        r = subprocess.run(
            ["tar", "-cf", tmp_tar, "-C", stage, "--numeric-owner", "."],
            stderr=subprocess.PIPE,
        )
        if r.returncode != 0:
            raise RuntimeError(
                f"snapshot tar failed: {r.stderr.decode('utf-8', 'replace')[:200]}"
            )
        _profile_add(profile, "tar", time.perf_counter() - tar_start)
        digest_start = time.perf_counter()
        diff_id = _sha256_file(tmp_tar)
        _profile_add(profile, "digest", time.perf_counter() - digest_start)

        # Extract into layer storage (idempotent)
        if not _layer_exists(diff_id):
            extract_start = time.perf_counter()
            _extract_layer_tar(tmp_tar, diff_id)
            _profile_add(profile, "extract", time.perf_counter() - extract_start)

        # Re-hardlink src_tree files with the freshly extracted layer tree so
        # the next inode-based diff can skip them without rebuilding the whole
        # rootfs from all layers. This happens after RUN/COPY has completed,
        # so no traced process is still using the files.
        if os.environ.get("PDOCKER_DISABLE_SNAPSHOT_RELINK", "0") != "1":
            relink_start = time.perf_counter()
            layer_tree = _layer_tree(diff_id)
            for lroot, _, lfiles in os.walk(layer_tree, followlinks=False):
                rel = os.path.relpath(lroot, layer_tree)
                for fn in lfiles:
                    if fn.startswith(WHITEOUT_PREFIX):
                        continue
                    lp = os.path.join(lroot, fn)
                    sp = os.path.join(src_tree, rel, fn) if rel != "." \
                        else os.path.join(src_tree, fn)
                    tmp_sp = None
                    try:
                        if not os.path.isfile(sp) or os.path.islink(sp):
                            continue
                        if os.lstat(sp).st_ino == os.lstat(lp).st_ino:
                            continue
                        tmp_sp = f"{sp}.pdocker-link-{uuid.uuid4().hex}"
                        os.link(lp, tmp_sp)
                        os.replace(tmp_sp, sp)
                    except OSError:
                        try:
                            if tmp_sp and os.path.exists(tmp_sp):
                                os.remove(tmp_sp)
                        except OSError:
                            pass
                        pass
            _profile_add(profile, "relink", time.perf_counter() - relink_start)
    finally:
        cleanup_start = time.perf_counter()
        shutil.rmtree(stage, ignore_errors=True)
        try:
            os.remove(tmp_tar)
        except OSError:
            pass
        _profile_add(profile, "cleanup", time.perf_counter() - cleanup_start)
    return diff_id


def _volume_meta(name):
    """Return persisted metadata for a named volume, or empty dict."""
    mp = os.path.join(VOLUMES_DIR, name, "meta.json")
    if not os.path.exists(mp):
        return {}
    try:
        with open(mp) as f:
            return json.load(f)
    except (OSError, json.JSONDecodeError):
        return {}


def _volume_mountpoint(name):
    """Host path that gets bind-mounted into the container for volume `name`."""
    return os.path.join(VOLUMES_DIR, name, "_data")


def _volume_exists(name):
    return os.path.isdir(os.path.join(VOLUMES_DIR, name))


def _ensure_volume(name, driver="local", labels=None, options=None):
    """Create a named volume on disk if it doesn't exist. Idempotent."""
    vdir = os.path.join(VOLUMES_DIR, name)
    created = False
    if not os.path.isdir(vdir):
        os.makedirs(os.path.join(vdir, "_data"), exist_ok=True)
        created = True
    mp = os.path.join(vdir, "meta.json")
    if not os.path.exists(mp):
        meta = {
            "Name": name,
            "Driver": driver or "local",
            "Labels": labels or {},
            "Options": options or {},
            "CreatedAt": time.strftime("%Y-%m-%dT%H:%M:%SZ", time.gmtime()),
        }
        try:
            with open(mp, "w") as f:
                json.dump(meta, f)
        except OSError:
            pass
    return created


def _volume_public(name):
    """Render a volume as Docker API `Volume` object."""
    meta = _volume_meta(name)
    return {
        "Name": name,
        "Driver": meta.get("Driver", "local"),
        "Mountpoint": _volume_mountpoint(name),
        "CreatedAt": meta.get("CreatedAt", ""),
        "Labels": meta.get("Labels") or {},
        "Scope": "local",
        "Options": meta.get("Options") or {},
    }


def _volume_refcount(name):
    """Count how many containers currently reference this volume."""
    if not os.path.isdir(CONTAINERS_DIR):
        return 0
    count = 0
    for cid in os.listdir(CONTAINERS_DIR):
        sp = os.path.join(CONTAINERS_DIR, cid, "state.json")
        if not os.path.isfile(sp):
            continue
        try:
            with open(sp) as f:
                s = json.load(f)
        except (OSError, json.JSONDecodeError):
            continue
        hc = s.get("HostConfig") or {}
        for b in hc.get("Binds") or []:
            src = b.split(":", 1)[0]
            if src == name:
                count += 1
                break
        else:
            for m in hc.get("Mounts") or []:
                if m.get("Type") == "volume" and m.get("Source") == name:
                    count += 1
                    break
    return count


def _effective_binds(state):
    """Merge HostConfig.Binds + HostConfig.Mounts into a single list of
    "HOST:CONTAINER[:ro]" strings ready for proot -b. Named volumes are
    auto-created and resolved to $VOLUMES_DIR/<name>/_data."""
    hc = state.get("HostConfig") or {}
    out = []
    # Legacy Binds: "HOST-or-VOLUME:CONTAINER[:ro]"
    for b in hc.get("Binds") or []:
        parts = b.split(":")
        if len(parts) < 2:
            continue
        src, dst = parts[0], parts[1]
        ro = "ro" if len(parts) >= 3 and "ro" in parts[2:] else ""
        if not src or not dst:
            continue
        if src.startswith("/"):
            host = src
        else:
            _ensure_volume(src)
            host = _volume_mountpoint(src)
        out.append(f"{host}:{dst}" + (f":{ro}" if ro else ""))
    # Newer Mounts: [{Type,Source,Target,ReadOnly}]
    for m in hc.get("Mounts") or []:
        t = m.get("Type")
        src = m.get("Source", "")
        dst = m.get("Target", "")
        if not dst:
            continue
        if t == "bind":
            if not src:
                continue
            host = src
        elif t == "volume":
            if not src:
                src = f"anon_{uuid.uuid4().hex[:12]}"
            _ensure_volume(src)
            host = _volume_mountpoint(src)
        else:
            continue
        ro = ":ro" if m.get("ReadOnly") else ""
        out.append(f"{host}:{dst}{ro}")
    return out


def _gpu_request_modes(state):
    """Return requested pdocker GPU modes from Docker HostConfig.

    This intentionally accepts both standard Docker `--gpus` payloads
    (HostConfig.DeviceRequests) and pdocker labels/options. The backend is
    Android/user-space, so "cuda" means pdocker's compatibility API layer, not
    native NVIDIA kernel-driver passthrough.
    """
    modes = set()
    hc = state.get("HostConfig") or {}
    if hc.get("Runtime") in ("nvidia", "pdocker-gpu", "vulkan", "cuda"):
        modes.add("vulkan")
        if hc.get("Runtime") in ("nvidia", "cuda"):
            modes.add("cuda-compat")
    for req in hc.get("DeviceRequests") or []:
        driver = (req.get("Driver") or "").lower()
        caps = []
        for group in req.get("Capabilities") or []:
            caps.extend(str(c).lower() for c in group)
        opts = {str(k).lower(): str(v).lower()
                for k, v in (req.get("Options") or {}).items()}
        if driver in ("nvidia", "cuda") or "gpu" in caps:
            modes.add("vulkan")
            modes.add("cuda-compat")
        if driver == "vulkan" or "vulkan" in caps or opts.get("pdocker.gpu") == "vulkan":
            modes.add("vulkan")
        if "cuda" in caps or opts.get("pdocker.cuda") in ("1", "true", "compat"):
            modes.add("cuda-compat")
    labels = state.get("Labels") or {}
    label_mode = labels.get("io.pdocker.gpu") or labels.get("pdocker.gpu")
    if label_mode:
        for part in str(label_mode).replace(",", " ").split():
            if part in ("vulkan", "gpu"):
                modes.add("vulkan")
            elif part in ("cuda", "cuda-compat"):
                modes.add("cuda-compat")
    return modes


def _gpu_env(state):
    modes = _gpu_request_modes(state)
    if not modes:
        return {}
    env = {
        "PDOCKER_GPU": "1",
        "PDOCKER_GPU_MODES": ",".join(sorted(modes)),
        "NVIDIA_VISIBLE_DEVICES": "all",
        "NVIDIA_DRIVER_CAPABILITIES": "compute,utility,graphics",
    }
    if "vulkan" in modes:
        env.update({
            "PDOCKER_VULKAN_PASSTHROUGH": "1",
            "VK_ICD_FILENAMES": "/etc/vulkan/icd.d/pdocker-android.json",
        })
    if "cuda-compat" in modes:
        env.update({
            "PDOCKER_CUDA_COMPAT": "1",
            "CUDA_VISIBLE_DEVICES": "0",
            "CUDA_DEVICE_ORDER": "PCI_BUS_ID",
        })
    return env


def _existing_bind(src, dst=None, readonly=True):
    if not os.path.exists(src):
        return None
    target = dst or src
    return f"{src}:{target}" + (":ro" if readonly else "")


def _gpu_binds(state):
    modes = _gpu_request_modes(state)
    if not modes:
        return []
    candidates = [
        ("/dev/kgsl-3d0", "/dev/kgsl-3d0", False),
        ("/dev/dri", "/dev/dri", False),
        ("/system/lib64/libvulkan.so", "/system/lib64/libvulkan.so", True),
        ("/vendor/lib64/libvulkan.so", "/vendor/lib64/libvulkan.so", True),
        ("/vendor/lib64/egl", "/vendor/lib64/egl", True),
        ("/vendor/lib64/hw", "/vendor/lib64/hw", True),
        ("/system/etc/vulkan", "/system/etc/vulkan", True),
        ("/vendor/etc/vulkan", "/vendor/etc/vulkan", True),
    ]
    out = []
    seen = set()
    for src, dst, ro in candidates:
        b = _existing_bind(src, dst, ro)
        if b and b not in seen:
            out.append(b)
            seen.add(b)
    return out


def _split_port_proto(key):
    if "/" in str(key):
        port, proto = str(key).split("/", 1)
    else:
        port, proto = str(key), "tcp"
    try:
        port_i = int(port)
    except ValueError:
        return None, None
    return port_i, proto or "tcp"


def _container_virtual_ip(cid):
    """Stable synthetic per-container IP for UI/API visibility.

    pdocker still runs in a host-style Android network context. This IP is a
    compatibility identity and a future key for syscall-hook port rewriting,
    not a kernel-assigned namespace address.
    """
    try:
        a = int(cid[0:2], 16)
        b = int(cid[2:4], 16)
    except Exception:
        a, b = 0, 2
    return f"10.88.{a}.{max(2, min(254, b))}"


def _stable_rewrite_port(cid, container_port, proto):
    seed = f"{cid}:{container_port}/{proto}".encode()
    h = hashlib.sha256(seed).hexdigest()
    return 20000 + (int(h[:8], 16) % 40000)


def _safe_host_port(value, fallback):
    try:
        n = int(value)
        if 0 < n <= 65535:
            return n
    except Exception:
        pass
    return fallback


def _network_port_plan(cid, config, img_config):
    """Build Docker-visible Ports plus pdocker's future syscall rewrite plan."""
    hc = config.get("HostConfig") or {}
    exposed = {}
    exposed.update(img_config.get("ExposedPorts") or {})
    exposed.update(config.get("ExposedPorts") or {})
    bindings = hc.get("PortBindings") or {}
    publish_all = bool(hc.get("PublishAllPorts"))

    keys = set(exposed.keys()) | set(bindings.keys())
    ports = {}
    rewrite = []
    for key in sorted(keys):
        cport, proto = _split_port_proto(key)
        if not cport:
            continue
        docker_key = f"{cport}/{proto}"
        requested = bindings.get(docker_key) or bindings.get(str(key)) or []
        entries = []
        if requested:
            for item in requested:
                host_ip = item.get("HostIp") or "127.0.0.1"
                host_port = _safe_host_port(
                    item.get("HostPort"),
                    _stable_rewrite_port(cid, cport, proto),
                )
                entries.append({"HostIp": host_ip, "HostPort": str(host_port)})
        elif publish_all:
            entries.append({
                "HostIp": "127.0.0.1",
                "HostPort": str(_stable_rewrite_port(cid, cport, proto)),
            })
        ports[docker_key] = entries or None

        rewrite_port = _safe_host_port(
            (entries or [{"HostPort": _stable_rewrite_port(cid, cport, proto)}])[0]["HostPort"],
            _stable_rewrite_port(cid, cport, proto),
        )
        rewrite.append({
            "ContainerPort": cport,
            "Protocol": proto,
            "HostIp": (entries or [{"HostIp": "127.0.0.1"}])[0]["HostIp"],
            "HostPort": rewrite_port,
            "Hook": "bind",
            "Status": "planned",
        })
    return ports, rewrite


def _network_warnings(config, port_rewrite):
    """Return user-visible warnings for Docker networking features we emulate."""
    hc = config.get("HostConfig") or {}
    warnings = []
    if hc.get("PortBindings") or hc.get("PublishAllPorts") or port_rewrite:
        warnings.append(
            "pdocker records requested port publishing, but Android sandbox "
            "runtime is still host-network-only; bind/connect syscall rewrite "
            "is planned and not active yet."
        )
    network_mode = hc.get("NetworkMode")
    if network_mode and network_mode not in ("default", "bridge", "host", "none"):
        warnings.append(
            f"pdocker treats network mode {network_mode!r} as a compose-compatible "
            "host-network stub."
        )
    return warnings


def _container_ports_summary(state):
    out = []
    ports = (state.get("NetworkSettings") or {}).get("Ports") or {}
    for key, bindings in ports.items():
        cport, proto = _split_port_proto(key)
        if not cport:
            continue
        if bindings:
            for b in bindings:
                try:
                    public = int(b.get("HostPort") or 0)
                except ValueError:
                    public = 0
                out.append({
                    "IP": b.get("HostIp", "127.0.0.1"),
                    "PrivatePort": cport,
                    "PublicPort": public,
                    "Type": proto,
                })
        else:
            out.append({
                "IP": "",
                "PrivatePort": cport,
                "Type": proto,
            })
    return out


def _container_mounts_inspect(state):
    """Render Mounts[] field for container inspect, resolving named volumes."""
    hc = state.get("HostConfig") or {}
    out = []
    for b in hc.get("Binds") or []:
        parts = b.split(":")
        if len(parts) < 2:
            continue
        src, dst = parts[0], parts[1]
        rw = not (len(parts) >= 3 and "ro" in parts[2:])
        if src.startswith("/"):
            out.append({"Type": "bind", "Source": src, "Destination": dst,
                        "Mode": "", "RW": rw, "Propagation": "rprivate"})
        else:
            out.append({"Type": "volume", "Name": src,
                        "Source": _volume_mountpoint(src), "Destination": dst,
                        "Driver": "local", "Mode": "", "RW": rw,
                        "Propagation": ""})
    for m in hc.get("Mounts") or []:
        t = m.get("Type")
        src = m.get("Source", "")
        dst = m.get("Target", "")
        rw = not m.get("ReadOnly")
        if t == "bind":
            out.append({"Type": "bind", "Source": src, "Destination": dst,
                        "Mode": "", "RW": rw, "Propagation": "rprivate"})
        elif t == "volume":
            out.append({"Type": "volume", "Name": src,
                        "Source": _volume_mountpoint(src), "Destination": dst,
                        "Driver": "local", "Mode": "", "RW": rw,
                        "Propagation": ""})
    return out


def _network_members(net_name):
    """Return list of {id, name} for containers connected to this network."""
    mp = os.path.join(NETWORKS_DIR, net_name, "members.json")
    if not os.path.exists(mp):
        return []
    try:
        with open(mp) as f:
            return json.load(f)
    except (OSError, json.JSONDecodeError):
        return []


def _network_meta(net_name):
    """Return network metadata (Labels/Driver/Options/IPAM/Created)."""
    mp = os.path.join(NETWORKS_DIR, net_name, "meta.json")
    if not os.path.exists(mp):
        return {}
    try:
        with open(mp) as f:
            return json.load(f)
    except (OSError, json.JSONDecodeError):
        return {}


def _network_containers(net_name):
    """Format network membership for /networks/{name} GET response."""
    out = {}
    for m in _network_members(net_name):
        out[m["id"]] = {
            "Name": m.get("name", m["id"][:12]),
            "EndpointID": m["id"],
            "MacAddress": "",
            "IPv4Address": "127.0.0.1/32",
            "IPv6Address": "",
        }
    return out


def _network_for_container(cid):
    """Return the named network this container belongs to, or None."""
    if not os.path.isdir(NETWORKS_DIR):
        return None
    for n in os.listdir(NETWORKS_DIR):
        for m in _network_members(n):
            if m["id"] == cid:
                return n
    return None


def _inject_network_hosts(rootfs, net_name, self_cid):
    """
    Append `127.0.0.1 <member-name>` lines for every other member of
    `net_name` into the container's /etc/hosts. Spoil: all members
    collapse to localhost — same-port collisions break.
    """
    members = _network_members(net_name)
    others = [m for m in members if m["id"] != self_cid]
    if not others:
        return
    hosts_path = os.path.join(rootfs, "etc/hosts")
    os.makedirs(os.path.dirname(hosts_path), exist_ok=True)
    existing = ""
    if os.path.exists(hosts_path):
        with open(hosts_path) as f:
            existing = f.read()
    marker = "# pdockerd-network-aliases"
    if marker in existing:
        # strip prior block to keep idempotent
        existing = existing.split(marker)[0].rstrip() + "\n"
    block = [marker]
    for m in others:
        n = m.get("name", m["id"][:12])
        block.append(f"127.0.0.1\t{n} {m['id'][:12]}")
    with open(hosts_path, "w") as f:
        f.write(existing.rstrip() + "\n" + "\n".join(block) + "\n")


def build_run_argv(rootfs, argv, env, workdir="/", binds=None, cow_bind=None, mode="run"):
    """
    Wrap `argv` so it runs inside `rootfs` with overlayfs-like CoW.
    - Apply LD_PRELOAD=/.libcow.so inside the guest environment when available.
    - `binds` is a list of "HOST:CTR[:ro]" strings for backend-owned path
      mapping. Some backends can only record :ro as metadata.
    - Android APK builds use the direct RuntimeBackend; chroot remains a Linux
      host fallback and explicit proot runners remain diagnostic only.
    """
    inner_env = ["HOME=/root", f"TERM={os.environ.get('TERM', 'xterm')}"]
    if not cow_bind and os.path.exists(os.path.join(rootfs, ".libcow.so")) \
       and os.environ.get("PDOCKER_NO_COW") != "1":
        inner_env.append("LD_PRELOAD=/.libcow.so")
    for k, v in (env or {}).items():
        inner_env.append(f"{k}={v}")

    return RUNTIME_BACKEND.build_argv(
        rootfs, argv, inner_env, workdir=workdir, binds=binds,
        cow_bind=cow_bind, mode=mode,
    )


# ---- Image management ----

def normalize_image(name):
    """Normalize image reference: ubuntu -> docker.io/library/ubuntu:latest"""
    if "@" in name:
        return name  # digest form
    if ":" not in name.split("/")[-1]:
        name = name + ":latest"
    parts = name.split(":")
    tag = parts[-1]
    repo = ":".join(parts[:-1])
    if "/" not in repo:
        repo = "library/" + repo
    if "." not in repo.split("/")[0] and ":" not in repo.split("/")[0]:
        repo = "docker.io/" + repo
    return f"{repo}:{tag}"


def image_to_path(name):
    return name.replace("/", "_").replace(":", "_")


def image_dir(name):
    return os.path.join(IMAGES_DIR, image_to_path(name))


def image_config(name):
    p = os.path.join(image_dir(name), "config.json")
    if os.path.exists(p):
        with open(p) as f:
            return json.load(f)
    return None


def image_id(name):
    """Stable image ID based on the image reference and config digest."""
    cfg = image_config(name)
    if cfg and "config" in cfg:
        # Best-effort: use config JSON content as a pseudo digest
        data = json.dumps(cfg, sort_keys=True).encode()
        import hashlib
        return "sha256:" + hashlib.sha256(data).hexdigest()
    return "sha256:" + "0" * 64


def _fetch_layer_blob(image_ref, digest, media_type):
    """Download one OCI layer blob via crane and return a path to the
    uncompressed tar on /tmp. Caller is responsible for removing it.

    Supports `*/tar` (raw) and `*/tar+gzip`. Zstd is not supported by the
    bundled crane output path and is rejected loudly.
    """
    if "zstd" in (media_type or ""):
        raise RuntimeError(f"zstd layers are not supported (blob {digest[:19]})")
    tmp_blob = os.path.join(PDOCKER_TMP, f"pdblob_{uuid.uuid4().hex}")
    with open(tmp_blob, "wb") as outf:
        _run_crane(
            ["blob", f"{image_ref}@{digest}"],
            stdout=outf, stderr=subprocess.PIPE, check=True,
        )
    # Sniff magic — media type is authoritative but some registries lie,
    # so magic-bytes detection keeps us honest.
    with open(tmp_blob, "rb") as f:
        magic = f.read(2)
    if magic == b"\x1f\x8b":
        tmp_tar = tmp_blob + ".tar"
        with open(tmp_tar, "wb") as outf:
            subprocess.run(["gzip", "-dc", tmp_blob],
                           stdout=outf, check=True)
        os.remove(tmp_blob)
        return tmp_tar
    return tmp_blob


def pull_image(name, platform=None):
    """Pull an image via crane, storing each layer content-addressably in
    LAYERS_DIR/<diff_id>/tree/ and materializing a merged rootfs at
    images/<tag>/rootfs for backwards compatibility with the flatten-based
    container creation path.
    """
    norm = normalize_image(name)
    d = image_dir(norm)
    os.makedirs(d, exist_ok=True)

    plat = platform or PLATFORM

    # 1. Fetch manifest (gives us per-layer blob digests)
    log(f"Fetching manifest for {norm}")
    manifest_bytes = _run_crane(
        ["manifest", "--platform", plat, norm],
        capture_output=True, check=True,
    ).stdout
    manifest = json.loads(manifest_bytes.decode("utf-8"))

    # 2. Fetch config (gives us diff_ids — uncompressed layer digests)
    log(f"Fetching config for {norm}")
    cfg_bytes = _run_crane(
        ["config", "--platform", plat, norm],
        capture_output=True, check=True,
    ).stdout
    config = json.loads(cfg_bytes.decode("utf-8"))
    with open(os.path.join(d, "config.json"), "wb") as f:
        f.write(cfg_bytes)

    diff_ids_full = (config.get("rootfs") or {}).get("diff_ids") or []
    blob_descs = manifest.get("layers") or []
    if len(diff_ids_full) != len(blob_descs):
        raise RuntimeError(
            f"diff_id count {len(diff_ids_full)} != manifest layer count "
            f"{len(blob_descs)} for {norm}"
        )

    # 3. Pull each layer blob, gunzip if needed, extract into
    #    LAYERS_DIR/<diff_id>/tree/. Layers are shared across images —
    #    `_layer_exists` short-circuits re-downloads.
    diff_ids_bare = []
    for i, (did_full, desc) in enumerate(zip(diff_ids_full, blob_descs)):
        bare = did_full.split(":", 1)[-1]
        diff_ids_bare.append(bare)
        if _layer_exists(bare):
            log(f"Layer {i+1}/{len(diff_ids_full)} cached: sha256:{bare[:12]}")
            continue
        log(f"Pulling layer {i+1}/{len(diff_ids_full)}: sha256:{bare[:12]}")
        tmp_tar = _fetch_layer_blob(norm, desc["digest"], desc.get("mediaType", ""))
        try:
            actual = _sha256_file(tmp_tar)
            if actual != bare:
                raise RuntimeError(
                    f"diff_id mismatch for layer {i}: expected {bare[:12]}, "
                    f"got {actual[:12]}"
                )
            _extract_layer_tar(tmp_tar, bare)
        finally:
            try:
                os.remove(tmp_tar)
            except OSError:
                pass

    # 4. Record image manifest (layer order + config)
    _save_image_manifest(d, diff_ids_bare, config)

    # 5. Materialize merged rootfs for flatten-path compatibility.
    #    Phase 3 will drop this in favor of direct per-container merge.
    rootfs = os.path.join(d, "rootfs")
    if os.path.exists(rootfs):
        shutil.rmtree(rootfs)
    merge_layers_into(rootfs, diff_ids_bare)

    # Metadata
    with open(os.path.join(d, "image_ref"), "w") as f:
        f.write(norm)
    with open(os.path.join(d, "pulled_at"), "w") as f:
        f.write(time.strftime("%Y-%m-%dT%H:%M:%SZ", time.gmtime()))

    log(f"Pulled {norm} ({len(diff_ids_bare)} layer{'s' if len(diff_ids_bare) != 1 else ''})")
    return norm


# ============================================================
# docker save / docker load — OCI image layout + Docker v1.2 compat
# ============================================================
#
# Save output is a tar with both `manifest.json` (Docker v1.2) and
# OCI layout (`oci-layout`, `index.json`, `blobs/sha256/*`) so the
# result is loadable by any Docker 24+ / containerd / podman.
#
# Layers are stored UNCOMPRESSED (media type
# application/vnd.oci.image.layer.v1.tar). The digest of the
# uncompressed tar == diff_id == blob sha256 — a single content
# address for all three.


def _retar_layer(diff_id, out_path):
    """Re-tar LAYERS_DIR/<diff_id>/tree/ to `out_path`. Deterministic
    ordering keeps digests stable across re-saves of the same layer.

    Returns the sha256 of the resulting tar (may differ from diff_id
    if the image was loaded from an external source that tarred
    with different options). Caller persists the new digest.
    """
    tree = _layer_tree(diff_id)
    if not os.path.isdir(tree):
        raise FileNotFoundError(f"layer tree missing: {diff_id}")
    r = subprocess.run(
        ["tar", "-cf", out_path, "-C", tree, "--numeric-owner",
         "--sort=name", "."],
        stderr=subprocess.PIPE,
    )
    if r.returncode != 0:
        raise RuntimeError(
            f"retar failed for {diff_id}: "
            f"{r.stderr.decode('utf-8', 'replace')[:200]}"
        )
    return _sha256_file(out_path)


def save_images(names, out_stream):
    """Write a Docker-save-compatible tar for `names` (list of image
    refs) to `out_stream` (a writable binary file-like)."""
    import hashlib, tarfile, io as _io

    # Collect (norm, diff_ids, config) for each image
    bundles = []
    for name in names:
        norm = normalize_image(name)
        d = image_dir(norm)
        if not os.path.isdir(d):
            raise FileNotFoundError(f"image not found: {name}")
        diff_ids = _load_image_manifest(d)
        cfg_path = os.path.join(d, "config.json")
        if not diff_ids or not os.path.exists(cfg_path):
            raise RuntimeError(
                f"image {name} has no layer manifest — re-pull or rebuild"
            )
        with open(cfg_path) as f:
            config = json.load(f)
        bundles.append((norm, diff_ids, config))

    # Stage blobs + digests under a temp dir so we can compute sizes
    # before writing the final tar header (tarfile wants size up front).
    import tempfile
    staging = tempfile.mkdtemp(prefix="pdsave_")
    try:
        blobs = {}  # digest -> (path, size, media_type)
        docker_manifest = []
        oci_manifests = []  # for index.json

        for norm, diff_ids, config in bundles:
            # 1. Re-tar each layer as an OCI blob
            layer_digests = []
            for did in diff_ids:
                if did in blobs:
                    layer_digests.append(did)
                    continue
                blob_path = os.path.join(staging, did)
                actual = _retar_layer(did, blob_path)
                if actual != did:
                    # Retar produced a different digest (possible if
                    # the layer was loaded from an external source
                    # with different tar options). Relocate under the
                    # new digest.
                    new_path = os.path.join(staging, actual)
                    os.rename(blob_path, new_path)
                    blob_path = new_path
                    # Update image's diff_ids to match actual
                    idx = diff_ids.index(did)
                    diff_ids[idx] = actual
                blobs[actual if actual != did else did] = (
                    blob_path, os.path.getsize(blob_path),
                    "application/vnd.oci.image.layer.v1.tar",
                )
                layer_digests.append(actual if actual != did else did)

            # 2. Write the config blob (must reflect updated diff_ids)
            config["rootfs"] = {
                "type": "layers",
                "diff_ids": [f"sha256:{d}" for d in layer_digests],
            }
            cfg_bytes = json.dumps(config).encode("utf-8")
            cfg_digest = hashlib.sha256(cfg_bytes).hexdigest()
            cfg_blob_path = os.path.join(staging, cfg_digest)
            with open(cfg_blob_path, "wb") as f:
                f.write(cfg_bytes)
            blobs[cfg_digest] = (
                cfg_blob_path, len(cfg_bytes),
                "application/vnd.oci.image.config.v1+json",
            )

            # 3. Docker v1.2 manifest entry
            repo_tag = norm.replace("docker.io/library/", "").replace(
                "docker.io/", "")
            docker_manifest.append({
                "Config": f"blobs/sha256/{cfg_digest}",
                "RepoTags": [repo_tag],
                "Layers": [f"blobs/sha256/{d}" for d in layer_digests],
            })

            # 4. OCI manifest blob (one per image) — referenced by index.json
            oci_m = {
                "schemaVersion": 2,
                "mediaType": "application/vnd.oci.image.manifest.v1+json",
                "config": {
                    "mediaType": "application/vnd.oci.image.config.v1+json",
                    "digest": f"sha256:{cfg_digest}",
                    "size": len(cfg_bytes),
                },
                "layers": [
                    {
                        "mediaType": "application/vnd.oci.image.layer.v1.tar",
                        "digest": f"sha256:{d}",
                        "size": blobs[d][1],
                    }
                    for d in layer_digests
                ],
            }
            oci_m_bytes = json.dumps(oci_m).encode("utf-8")
            oci_m_digest = hashlib.sha256(oci_m_bytes).hexdigest()
            oci_m_path = os.path.join(staging, oci_m_digest)
            with open(oci_m_path, "wb") as f:
                f.write(oci_m_bytes)
            blobs[oci_m_digest] = (
                oci_m_path, len(oci_m_bytes),
                "application/vnd.oci.image.manifest.v1+json",
            )
            oci_manifests.append({
                "mediaType": "application/vnd.oci.image.manifest.v1+json",
                "digest": f"sha256:{oci_m_digest}",
                "size": len(oci_m_bytes),
                "annotations": {
                    "org.opencontainers.image.ref.name": repo_tag,
                },
            })

        # 4. Write the output tar
        tf = tarfile.open(fileobj=out_stream, mode="w|")
        try:
            def _add_bytes(arcname, data):
                info = tarfile.TarInfo(name=arcname)
                info.size = len(data)
                info.mtime = int(time.time())
                info.mode = 0o644
                tf.addfile(info, _io.BytesIO(data))

            # oci-layout
            _add_bytes("oci-layout",
                       b'{"imageLayoutVersion":"1.0.0"}\n')

            # blobs/sha256/<digest> for each unique blob
            for digest, (bp, size, mt) in blobs.items():
                info = tf.gettarinfo(name=bp,
                                     arcname=f"blobs/sha256/{digest}")
                info.mode = 0o644
                info.uid = info.gid = 0
                info.uname = info.gname = ""
                with open(bp, "rb") as bf:
                    tf.addfile(info, bf)

            # Docker v1.2 manifest.json
            _add_bytes("manifest.json",
                       json.dumps(docker_manifest).encode("utf-8"))

            # OCI index.json — top-level manifest list
            index = {
                "schemaVersion": 2,
                "manifests": oci_manifests,
            }
            _add_bytes("index.json",
                       json.dumps(index).encode("utf-8"))
        finally:
            tf.close()
    finally:
        shutil.rmtree(staging, ignore_errors=True)


def load_images(in_stream):
    """Consume a Docker-save-compatible tar from `in_stream` and import
    every referenced image into our layer store + image_dir. Returns
    list of loaded image refs.
    """
    import tempfile, tarfile
    loaded = []
    staging = tempfile.mkdtemp(prefix="pdload_")
    try:
        # Extract the save tar so we can address blobs by path
        tf = tarfile.open(fileobj=in_stream, mode="r|*")
        tf.extractall(staging, filter="data")
        tf.close()

        manifest_path = os.path.join(staging, "manifest.json")
        if not os.path.exists(manifest_path):
            raise RuntimeError("input is not a Docker save tar "
                               "(missing manifest.json)")
        with open(manifest_path) as f:
            manifest = json.load(f)

        for entry in manifest:
            cfg_rel = entry.get("Config", "")
            layer_rels = entry.get("Layers") or []
            repo_tags = entry.get("RepoTags") or []
            cfg_path = os.path.join(staging, cfg_rel)
            if not os.path.exists(cfg_path):
                raise RuntimeError(f"save tar references missing config "
                                   f"{cfg_rel}")
            with open(cfg_path) as f:
                config = json.load(f)

            # Import every layer — compute diff_id fresh (source may
            # have been compressed; our store holds uncompressed only)
            diff_ids = []
            for lrel in layer_rels:
                lpath = os.path.join(staging, lrel)
                if not os.path.exists(lpath):
                    raise RuntimeError(f"save tar references missing "
                                       f"layer {lrel}")
                # Detect gzip (some Docker engines save tar.gz layers)
                with open(lpath, "rb") as bf:
                    magic = bf.read(2)
                if magic == b"\x1f\x8b":
                    uncompressed = os.path.join(
                        staging, os.path.basename(lpath) + ".tar")
                    with open(uncompressed, "wb") as outf:
                        subprocess.run(["gzip", "-dc", lpath],
                                       stdout=outf, check=True)
                    lpath = uncompressed
                did = _sha256_file(lpath)
                if not _layer_exists(did):
                    _extract_layer_tar(lpath, did)
                diff_ids.append(did)

            # Patch config to reference our diff_ids
            config["rootfs"] = {
                "type": "layers",
                "diff_ids": [f"sha256:{d}" for d in diff_ids],
            }

            # Materialize under each tag
            for tag in (repo_tags or [None]):
                if tag is None:
                    continue
                norm = normalize_image(tag)
                dest = image_dir(norm)
                if os.path.exists(dest):
                    shutil.rmtree(dest)
                os.makedirs(dest)
                with open(os.path.join(dest, "config.json"), "w") as f:
                    json.dump(config, f, indent=2)
                _save_image_manifest(dest, diff_ids, config)
                # Materialize flatten fallback
                rootfs = os.path.join(dest, "rootfs")
                merge_layers_into(rootfs, diff_ids)
                with open(os.path.join(dest, "image_ref"), "w") as f:
                    f.write(norm)
                with open(os.path.join(dest, "pulled_at"), "w") as f:
                    f.write(time.strftime("%Y-%m-%dT%H:%M:%SZ",
                                          time.gmtime()))
                loaded.append(norm)

    finally:
        shutil.rmtree(staging, ignore_errors=True)
    return loaded


def list_images():
    imgs = []
    if not os.path.isdir(IMAGES_DIR):
        return imgs
    for d in os.listdir(IMAGES_DIR):
        fullp = os.path.join(IMAGES_DIR, d)
        ref_file = os.path.join(fullp, "image_ref")
        if not os.path.exists(ref_file):
            continue
        with open(ref_file) as f:
            ref = f.read().strip()
        cfg = image_config(ref) or {}
        size = sum(
            os.path.getsize(os.path.join(r, f))
            for r, _, files in os.walk(os.path.join(fullp, "rootfs"))
            for f in files
            if os.path.isfile(os.path.join(r, f))
        )
        pulled_at_file = os.path.join(fullp, "pulled_at")
        created = 0
        if os.path.exists(pulled_at_file):
            with open(pulled_at_file) as f:
                try:
                    created = int(time.mktime(time.strptime(f.read().strip(), "%Y-%m-%dT%H:%M:%SZ")))
                except Exception:
                    created = int(os.path.getmtime(pulled_at_file))
        # Strip registry prefix for RepoTags
        repo_tag = ref
        repo_tag = repo_tag.replace("docker.io/library/", "").replace("docker.io/", "")
        imgs.append({
            "Id": image_id(ref),
            "ParentId": "",
            "RepoTags": [repo_tag],
            "RepoDigests": [],
            "Created": created,
            "Size": size,
            "SharedSize": 0,
            "VirtualSize": size,
            "Labels": cfg.get("config", {}).get("Labels") or {},
        })
    return imgs


def remove_image(name):
    norm = normalize_image(name)
    d = image_dir(norm)
    if os.path.isdir(d):
        shutil.rmtree(d)
        return True
    return False


# ---- Docker event stream helpers ----

def _parse_event_time(value, default=0):
    if value in (None, ""):
        return default
    if isinstance(value, (int, float)):
        return float(value)
    s = str(value)
    try:
        return float(s)
    except ValueError:
        pass
    # Accept the common Docker/RFC3339 forms used by the CLI. Nanoseconds are
    # ignored because event matching only needs second-level ordering here.
    s = s.replace("Z", "+00:00")
    if "." in s:
        head, tail = s.split(".", 1)
        tz = ""
        for marker in ("+", "-"):
            if marker in tail:
                frac, tz = tail.split(marker, 1)
                tz = marker + tz
                break
        else:
            frac = tail
        s = f"{head}.{frac[:6]}{tz}"
    try:
        import datetime as _dt
        dt = _dt.datetime.fromisoformat(s)
        if dt.tzinfo is None:
            dt = dt.replace(tzinfo=_dt.timezone.utc)
        return dt.timestamp()
    except ValueError:
        return default


def _load_events_unlocked():
    out = []
    if not os.path.exists(EVENTS_PATH):
        return out
    try:
        with open(EVENTS_PATH) as f:
            for line in f:
                line = line.strip()
                if not line:
                    continue
                try:
                    out.append(json.loads(line))
                except json.JSONDecodeError:
                    pass
    except OSError:
        pass
    return out


def record_event(type_, action, actor_id, attributes=None):
    now = time.time()
    attrs = {k: str(v) for k, v in (attributes or {}).items()
             if v is not None}
    event = {
        "status": action,
        "id": actor_id,
        "Type": type_,
        "Action": action,
        "Actor": {"ID": actor_id, "Attributes": attrs},
        "scope": "local",
        "time": int(now),
        "timeNano": int(now * 1_000_000_000),
    }
    os.makedirs(META_DIR, exist_ok=True)
    with events_cond:
        with open(EVENTS_PATH, "a") as f:
            f.write(json.dumps(event, separators=(",", ":")) + "\n")
        events_cond.notify_all()
    return event


def _event_matches(event, filters):
    if not filters:
        return True
    attrs = (event.get("Actor") or {}).get("Attributes") or {}

    def any_match(key, *values):
        wanted = filters.get(key)
        if not wanted:
            return True
        normalized = [str(v) for v in values if v is not None and str(v) != ""]
        return any(
            got == str(want) or got.startswith(str(want))
            for got in normalized
            for want in wanted
        )

    if not any_match("type", event.get("Type", "")):
        return False
    if not any_match("event", event.get("Action", "")):
        return False
    name = attrs.get("name", "").lstrip("/")
    if not any_match("container", event.get("id", ""), name):
        return False
    image = attrs.get("image") or attrs.get("name", "")
    image_short = image.replace("docker.io/library/", "").replace("docker.io/", "")
    if not any_match("image", image, image_short):
        return False
    if not any_match("network", event.get("id", ""), name):
        return False
    if not any_match("volume", event.get("id", ""), name):
        return False
    labels = filters.get("label") or []
    for item in labels:
        if "=" in item:
            k, v = item.split("=", 1)
            if attrs.get(k) != v:
                return False
        elif item not in attrs:
            return False
    return True


def _container_event_attrs(state):
    attrs = {
        "name": state.get("Name", "").lstrip("/"),
        "image": state.get("Image", ""),
    }
    attrs.update(state.get("Labels") or {})
    return attrs


def _decode_event_filters(raw):
    if not raw:
        return {}
    try:
        data = json.loads(raw)
    except (TypeError, ValueError, json.JSONDecodeError):
        return {}
    filters = {}
    for key, value in data.items():
        if isinstance(value, dict):
            filters[key] = {str(k) for k, enabled in value.items() if enabled}
        elif isinstance(value, list):
            filters[key] = {str(v) for v in value}
        else:
            filters[key] = {str(value)}
    return filters


# ---- Container management ----

def create_container(config, name=None):
    """Create a container (prepare rootfs, save config, don't start)."""
    cid = uuid.uuid4().hex
    image = config.get("Image", "")
    norm_img = normalize_image(image)

    # Auto-pull if missing
    if not os.path.exists(os.path.join(image_dir(norm_img), "rootfs")):
        pull_image(image)

    cdir = os.path.join(CONTAINERS_DIR, cid)
    os.makedirs(cdir, exist_ok=True)

    # Prepare rootfs. Default path materializes an overlayfs-like merged tree
    # with libcow break-on-write. Experimental cow_bind mode keeps the image
    # rootfs read-only and supplies an upperdir to the runtime at start time.
    dst_rootfs = os.path.join(cdir, "rootfs")
    img_d = image_dir(norm_img)
    img_rootfs = os.path.join(img_d, "rootfs")
    storage = {"Mode": "libcow", "Rootfs": dst_rootfs}
    if COW_BIND_AVAILABLE:
        upper = os.path.join(cdir, "upper")
        os.makedirs(upper, exist_ok=True)
        storage = {"Mode": "cow_bind", "LowerDir": img_rootfs, "UpperDir": upper}
    else:
        diff_ids = _load_image_manifest(img_d)
        if diff_ids:
            materialize_container_rootfs(dst_rootfs, diff_ids)
        else:
            # Fallback: legacy flatten path (image pulled before Phase 2 or
            # produced by build without per-layer snapshotting)
            clone_image_rootfs(img_rootfs, dst_rootfs)

    runtime_root = storage.get("UpperDir") or dst_rootfs
    for sub in ["proc", "sys", "dev", "tmp", "etc"]:
        os.makedirs(os.path.join(runtime_root, sub), exist_ok=True)

    # Merge image config + container config
    img_cfg = image_config(norm_img) or {}
    img_c = img_cfg.get("config", {})

    final_cmd = config.get("Cmd") or img_c.get("Cmd") or ["/bin/sh"]
    final_ep = config.get("Entrypoint")
    if final_ep is None:
        final_ep = img_c.get("Entrypoint") or []
    final_env = list(img_c.get("Env") or []) + list(config.get("Env") or [])
    final_wd = config.get("WorkingDir") or img_c.get("WorkingDir") or "/"
    gpu_env = [f"{k}={v}" for k, v in _gpu_env({
        "HostConfig": config.get("HostConfig") or {},
        "Labels": config.get("Labels") or {},
    }).items()]
    final_env += [e for e in gpu_env if e.split("=", 1)[0] not in {
        item.split("=", 1)[0] for item in final_env if "=" in item
    }]
    ports, port_rewrite = _network_port_plan(cid, config, img_c)
    virtual_ip = _container_virtual_ip(cid)
    warnings = _network_warnings(config, port_rewrite)

    state = {
        "Id": cid,
        "Name": "/" + (name or f"c_{cid[:12]}"),
        "Image": norm_img,
        "ImageId": image_id(norm_img),
        "Cmd": final_cmd if isinstance(final_cmd, list) else [final_cmd],
        "Entrypoint": final_ep if isinstance(final_ep, list) else [final_ep] if final_ep else [],
        "Env": final_env,
        "WorkingDir": final_wd,
        "Labels": config.get("Labels") or {},
        "Volumes": {},
        "HostConfig": config.get("HostConfig") or {},
        "Storage": storage,
        "PdockerGpu": {
            "Modes": sorted(_gpu_request_modes({
                "HostConfig": config.get("HostConfig") or {},
                "Labels": config.get("Labels") or {},
            })),
            "Kind": "android-vulkan-passthrough+cuda-compat",
        },
        "PdockerNetwork": {
            "IPAddress": virtual_ip,
            "Ports": ports,
            "PortRewrite": port_rewrite,
            "Kind": "host-network-with-syscall-hook-plan",
            "Warnings": warnings,
        },
        "Warnings": warnings,
        "State": {
            "Status": "created",
            "Running": False,
            "Paused": False,
            "Restarting": False,
            "OOMKilled": False,
            "Dead": False,
            "Pid": 0,
            "ExitCode": 0,
            "Error": "",
            "StartedAt": "0001-01-01T00:00:00Z",
            "FinishedAt": "0001-01-01T00:00:00Z",
        },
        "Created": time.strftime("%Y-%m-%dT%H:%M:%S.000000000Z", time.gmtime()),
        "Config": {
            "Hostname": name or cid[:12],
            "Image": image,
            "Cmd": final_cmd,
            "Entrypoint": final_ep,
            "Env": final_env,
            "WorkingDir": final_wd,
            "Labels": config.get("Labels") or {},
            "AttachStdin": config.get("AttachStdin", False),
            "AttachStdout": config.get("AttachStdout", True),
            "AttachStderr": config.get("AttachStderr", True),
            "Tty": config.get("Tty", False),
            "OpenStdin": config.get("OpenStdin", False),
        },
        "NetworkSettings": {
            "IPAddress": virtual_ip,
            "Ports": ports,
            "Networks": {
                "bridge": {
                    "IPAddress": virtual_ip,
                    "Gateway": "",
                    "MacAddress": "",
                }
            }
        },
    }

    # resolv.conf and hosts are container-local runtime files. In cow_bind
    # mode they live in upperdir so the pristine image rootfs stays read-only.
    _write_container_file(state, cdir, "etc/resolv.conf", _host_resolv_conf_text())
    if RUNTIME_BACKEND.kind == "direct" and os.environ.get("PDOCKER_APT_SANDBOX_ROOT", "1") != "0":
        _write_container_file(
            state,
            cdir,
            "etc/apt/apt.conf.d/00pdocker-direct-sandbox",
            'APT::Sandbox::User "root";\n',
        )
    if not os.path.exists(os.path.join(runtime_root, "etc/hosts")):
        _write_container_file(
            state,
            cdir,
            "etc/hosts",
            f"127.0.0.1 localhost\n::1 localhost\n127.0.1.1 {name or cid[:12]}\n",
        )
    if "vulkan" in state.get("PdockerGpu", {}).get("Modes", []):
        vulkan_lib = "/vendor/lib64/libvulkan.so" \
            if os.path.exists("/vendor/lib64/libvulkan.so") else "/system/lib64/libvulkan.so"
        _write_container_file(
            state,
            cdir,
            "etc/vulkan/icd.d/pdocker-android.json",
            json.dumps({
                "file_format_version": "1.0.0",
                "ICD": {
                    "library_path": vulkan_lib,
                    "api_version": "1.3.0",
                },
            }, indent=2) + "\n",
        )

    # Volumes/bind mounts are applied at run-time via proot -b in
    # build_run_argv (path translation = userspace bind mount). We no
    # longer pre-create symlinks at container-create time; HostConfig.Binds
    # is preserved on the state and consumed by start_container.
    save_container_state(cid, state)
    container_configs[cid] = state
    record_event("container", "create", cid, _container_event_attrs(state))
    return state


def save_container_state(cid, state):
    cdir = os.path.join(CONTAINERS_DIR, cid)
    path = os.path.join(cdir, "state.json")
    tmp = path + ".tmp"
    with open(tmp, "w") as f:
        json.dump(state, f, indent=2)
    os.replace(tmp, path)


def load_container_state(cid):
    path = os.path.join(CONTAINERS_DIR, cid, "state.json")
    if os.path.exists(path):
        for _ in range(3):
            try:
                with open(path) as f:
                    return json.load(f)
            except json.JSONDecodeError:
                time.sleep(0.02)
        return None
    return None


def find_container(identifier):
    """Resolve container by full ID, short ID, or name."""
    # Exact ID
    if os.path.isdir(os.path.join(CONTAINERS_DIR, identifier)):
        return load_container_state(identifier)
    # Short ID (12 chars) prefix or name
    if os.path.isdir(CONTAINERS_DIR):
        for cid in os.listdir(CONTAINERS_DIR):
            if cid.startswith(identifier):
                return load_container_state(cid)
            state = load_container_state(cid)
            if state and state.get("Name", "").lstrip("/") == identifier:
                return state
    return None


def reconcile_container_state(state):
    if not state:
        return state
    cid = state.get("Id")
    st = state.get("State") or {}
    if not cid or not st.get("Running"):
        return state
    with running_lock:
        proc = running_containers.get(cid)
    if proc is not None and proc.poll() is None:
        return state
    pid = int(st.get("Pid") or 0)
    if pid > 0 and _pid_alive(pid):
        st["Running"] = True
        st["Status"] = "running"
        state["State"] = st
        return state
    st["Running"] = False
    st["Status"] = "exited"
    st["ExitCode"] = st.get("ExitCode", 0) if st.get("ExitCode", 0) else -129
    st["FinishedAt"] = time.strftime("%Y-%m-%dT%H:%M:%S.000000000Z", time.gmtime())
    state["State"] = st
    save_container_state(cid, state)
    return state


def _pid_alive(pid):
    try:
        os.kill(pid, 0)
        return True
    except ProcessLookupError:
        return False
    except PermissionError:
        return True
    except OSError:
        return False


def _signal_pid_group(pid, sig):
    try:
        os.killpg(os.getpgid(pid), sig)
        return True
    except ProcessLookupError:
        return False
    except OSError:
        try:
            os.kill(pid, sig)
            return True
        except ProcessLookupError:
            return False
        except OSError:
            return False


def list_containers(all_=False):
    containers = []
    if not os.path.isdir(CONTAINERS_DIR):
        return containers
    for cid in os.listdir(CONTAINERS_DIR):
        state = load_container_state(cid)
        if not state:
            continue
        state = reconcile_container_state(state)
        st = state.get("State", {})
        running = st.get("Running", False)
        if not all_ and not running:
            continue
        img = state.get("Image", "").replace("docker.io/library/", "").replace("docker.io/", "")
        status = st.get("Status", "exited")
        if running:
            docker_status = "Up"
        elif status == "created":
            docker_status = "Created"
        else:
            docker_status = f"Exited ({st.get('ExitCode', 0)})"
        containers.append({
            "Id": cid,
            "Names": [state.get("Name", f"/{cid[:12]}")],
            "Image": img,
            "ImageID": state.get("ImageId", ""),
            "Command": " ".join(shlex.quote(str(x)) for x in state.get("Cmd", [])),
            "Created": int(time.mktime(time.strptime(
                state.get("Created", "")[:19] + "Z", "%Y-%m-%dT%H:%M:%SZ"
            ))) if state.get("Created") else 0,
            "State": "running" if running else status,
            "Status": docker_status,
            "Ports": _container_ports_summary(state),
            "Labels": state.get("Labels") or {},
            "Mounts": [],
            "HostConfig": {"NetworkMode": "default"},
            "NetworkSettings": state.get("NetworkSettings", {}),
        })
    return containers


def start_container(cid, stdout_stream=None, stderr_stream=None, attach=False):
    state = load_container_state(cid)
    if not state:
        return None
    cdir, cow, rootfs = _container_runtime(state)

    entrypoint = state.get("Entrypoint") or []
    cmd = state.get("Cmd") or []
    full = entrypoint + cmd if entrypoint else cmd
    if not full:
        full = ["/bin/sh"]

    env = _container_env(state)

    workdir = state.get("WorkingDir", "/") or "/"

    # Bind mounts via proot -b (path translation = userspace bind mount).
    # Handles both legacy HostConfig.Binds (host|volume:ctr[:ro]) and newer
    # HostConfig.Mounts. Named volumes are auto-created and resolved to
    # $VOLUMES_DIR/<name>/_data so compose volumes: blocks work transparently.
    binds = _effective_binds(state) + _gpu_binds(state)

    # Inject /etc/hosts entries for connected named-network members.
    # Also handle docker-compose's `--network NAME` flow where the
    # container's NetworkMode names a user-defined network: ensure
    # this container is registered as a member, then inject.
    net_mode = (state.get("HostConfig") or {}).get("NetworkMode", "default")
    net_name = None
    if net_mode and net_mode not in ("default", "bridge", "host", "none"):
        net_name = net_mode
        np_ = os.path.join(NETWORKS_DIR, net_name)
        if os.path.isdir(np_):
            mp = os.path.join(np_, "members.json")
            members = _network_members(net_name)
            if not any(m_["id"] == cid for m_ in members):
                cname = state.get("Name", cid).lstrip("/")
                members.append({"id": cid, "name": cname})
                with open(mp, "w") as f:
                    json.dump(members, f)
    else:
        net_name = _network_for_container(cid)
    if net_name:
        _inject_network_hosts(cow["upper"] if cow else rootfs, net_name, cid)

    fault = runtime_preflight(rootfs, env, workdir=workdir, binds=binds, cow_bind=cow)
    if fault:
        with open(os.path.join(LOGS_DIR, f"{cid}.log"), "ab") as log_file:
            log_file.write((fault + "\n").encode("utf-8", "replace"))
        state["State"]["Running"] = False
        state["State"]["Status"] = "exited"
        state["State"]["ExitCode"] = 126
        state["State"]["FinishedAt"] = time.strftime("%Y-%m-%dT%H:%M:%S.000000000Z", time.gmtime())
        save_container_state(cid, state)
        raise RuntimeError(fault)

    fault = runtime_process_unavailable_message()
    if fault:
        with open(os.path.join(LOGS_DIR, f"{cid}.log"), "ab") as log_file:
            log_file.write((fault + "\n").encode("utf-8", "replace"))
        state["State"]["Running"] = False
        state["State"]["Status"] = "exited"
        state["State"]["ExitCode"] = 126
        state["State"]["FinishedAt"] = time.strftime("%Y-%m-%dT%H:%M:%S.000000000Z", time.gmtime())
        save_container_state(cid, state)
        attrs = _container_event_attrs(state)
        attrs["exitCode"] = 126
        record_event("container", "die", cid, attrs)
        raise RuntimeError(fault)

    # build_run_argv applies LD_PRELOAD=/.libcow.so for libcow materialized
    # rootfs mode, or passes lower/upper metadata for cow_bind-capable runtimes.
    argv = build_run_argv(rootfs, full, env, workdir=workdir, binds=binds, cow_bind=cow, mode="start")

    # Open the log fd, hand it to Popen, then close *our* copy. Popen has
    # already inherited the fd into the child process, so the file stays
    # open as long as the container lives — we just don't keep a dangling
    # reference here that triggers ResourceWarning at GC.
    with open(os.path.join(LOGS_DIR, f"{cid}.log"), "ab") as log_file:
        proc = subprocess.Popen(
            argv,
            stdin=subprocess.PIPE,
            stdout=log_file,
            stderr=log_file,
            preexec_fn=os.setsid,
        )
    with running_lock:
        running_containers[cid] = proc

    state["State"]["Running"] = True
    state["State"]["Status"] = "running"
    state["State"]["Pid"] = proc.pid
    state["State"]["StartedAt"] = time.strftime("%Y-%m-%dT%H:%M:%S.000000000Z", time.gmtime())
    save_container_state(cid, state)
    record_event("container", "start", cid, _container_event_attrs(state))

    def watcher():
        rc = proc.wait()
        s = load_container_state(cid)
        if s:
            s["State"]["Running"] = False
            s["State"]["Status"] = "exited"
            s["State"]["ExitCode"] = rc
            s["State"]["FinishedAt"] = time.strftime("%Y-%m-%dT%H:%M:%S.000000000Z", time.gmtime())
            save_container_state(cid, s)
            attrs = _container_event_attrs(s)
            attrs["exitCode"] = rc
            record_event("container", "die", cid, attrs)
            if (s.get("HostConfig") or {}).get("AutoRemove"):
                remove_container(cid, force=True)
        with running_lock:
            running_containers.pop(cid, None)
        # Close stdin so attach readers can drain and exit.
        try: proc.stdin.close()
        except Exception: pass

    threading.Thread(target=watcher, daemon=True).start()
    return state


def stop_container(cid, timeout=10):
    with running_lock:
        proc = running_containers.get(cid)
    state = load_container_state(cid)
    pid = int(((state or {}).get("State") or {}).get("Pid") or 0)
    stopped = False
    if proc and proc.poll() is None:
        try:
            _signal_pid_group(proc.pid, signal.SIGTERM)
            try:
                proc.wait(timeout=timeout)
            except subprocess.TimeoutExpired:
                _signal_pid_group(proc.pid, signal.SIGKILL)
                proc.wait()
                if state:
                    record_event("container", "kill", cid,
                                 _container_event_attrs(state))
            stopped = True
            if state:
                record_event("container", "stop", cid,
                             _container_event_attrs(state))
        except Exception as e:
            log(f"stop {cid} error: {e}")
    elif pid > 0 and _pid_alive(pid):
        _signal_pid_group(pid, signal.SIGTERM)
        deadline = time.time() + timeout
        while time.time() < deadline and _pid_alive(pid):
            time.sleep(0.05)
        if _pid_alive(pid):
            _signal_pid_group(pid, signal.SIGKILL)
            if state:
                record_event("container", "kill", cid,
                             _container_event_attrs(state))
        stopped = True
        if state:
            record_event("container", "stop", cid,
                         _container_event_attrs(state))
    if state:
        state["State"]["Running"] = False
        state["State"]["Status"] = "exited"
        state["State"]["Pid"] = 0
        state["State"]["FinishedAt"] = time.strftime("%Y-%m-%dT%H:%M:%S.000000000Z", time.gmtime())
        if stopped and not state["State"].get("ExitCode"):
            state["State"]["ExitCode"] = 143
        save_container_state(cid, state)
    with running_lock:
        running_containers.pop(cid, None)


def remove_container(cid, force=False):
    state = load_container_state(cid)
    if not state:
        return False
    if state.get("State", {}).get("Running"):
        if not force:
            return False
        stop_container(cid)
    # Prune container from every network's membership roster so a
    # subsequent `network rm` doesn't see it as "still in use".
    if os.path.isdir(NETWORKS_DIR):
        for n in os.listdir(NETWORKS_DIR):
            np_ = os.path.join(NETWORKS_DIR, n)
            mp = os.path.join(np_, "members.json")
            if not os.path.isfile(mp):
                continue
            members = _network_members(n)
            new_members = [m for m in members if m.get("id") != cid]
            if len(new_members) != len(members):
                try:
                    with open(mp, "w") as f:
                        json.dump(new_members, f)
                except OSError:
                    pass
    cdir = os.path.join(CONTAINERS_DIR, cid)
    record_event("container", "destroy", cid, _container_event_attrs(state))
    shutil.rmtree(cdir, ignore_errors=True)
    return True


def prune_build_artifacts():
    """Remove failed/interrupted Dockerfile build rootfs directories.

    Build containers are internal implementation detail (`build_*` under the
    container store), not user-created containers. They are intentionally not
    kept unless PDOCKER_KEEP_FAILED_BUILD_ROOTFS=1 was set for debugging.
    """
    removed = []
    if os.path.isdir(CONTAINERS_DIR):
        for name in os.listdir(CONTAINERS_DIR):
            if not name.startswith("build_"):
                continue
            path = os.path.join(CONTAINERS_DIR, name)
            if not os.path.isdir(path):
                continue
            try:
                shutil.rmtree(path)
                removed.append(name)
            except OSError as exc:
                log(f"build prune {name} error: {exc}")
    if os.path.isdir(PDOCKER_TMP):
        for name in os.listdir(PDOCKER_TMP):
            if not (name.startswith("pdlayer_") or
                    name.startswith("pdbase_") or
                    name.startswith("pdstage_")):
                continue
            path = os.path.join(PDOCKER_TMP, name)
            try:
                if os.path.isdir(path):
                    shutil.rmtree(path)
                else:
                    os.remove(path)
                removed.append(f"tmp:{name}")
            except OSError as exc:
                log(f"tmp prune {name} error: {exc}")
    return removed


def _dir_size(path):
    total = 0
    if not os.path.exists(path):
        return 0
    if os.path.isfile(path):
        try:
            return os.path.getsize(path)
        except OSError:
            return 0
    for root, dirs, files in os.walk(path):
        for name in files:
            fp = os.path.join(root, name)
            try:
                total += os.path.getsize(fp)
            except OSError:
                pass
    return total


def referenced_layer_ids():
    refs = set()
    if not os.path.isdir(IMAGES_DIR):
        return refs
    for name in os.listdir(IMAGES_DIR):
        img_dir = os.path.join(IMAGES_DIR, name)
        if not os.path.isdir(img_dir):
            continue
        refs.update(_load_image_manifest(img_dir))
    return refs


def prune_unreferenced_layers(min_age_seconds=60):
    """Delete layer store entries that are not reachable from any image tag.

    Failed Dockerfile builds can create content-addressed layer directories
    before the final image manifest is recorded. Docker engines garbage collect
    those through builder/system prune; pdocker needs the same safety valve or
    repeated failed builds keep filling app data.
    """
    removed = []
    reclaimed = 0
    if not os.path.isdir(LAYERS_DIR):
        return {"Deleted": removed, "SpaceReclaimed": reclaimed}
    referenced = referenced_layer_ids()
    now = time.time()
    for name in os.listdir(LAYERS_DIR):
        if name in referenced:
            continue
        if not re.fullmatch(r"[A-Fa-f0-9]{64}", name):
            continue
        path = os.path.join(LAYERS_DIR, name)
        if not os.path.isdir(path):
            continue
        try:
            if min_age_seconds > 0 and now - os.path.getmtime(path) < min_age_seconds:
                continue
        except OSError:
            continue
        size = _dir_size(path)
        try:
            shutil.rmtree(path)
            removed.append(name)
            reclaimed += size
        except OSError as exc:
            log(f"layer prune {name} error: {exc}")
    return {"Deleted": removed, "SpaceReclaimed": reclaimed}


def spawn_in_container(cid, cmd, env=None, workdir=None, tty=False,
                        stdout=subprocess.PIPE, stderr=subprocess.PIPE,
                        stdin=subprocess.DEVNULL):
    """Like exec_in_container but returns a live Popen instead of running to completion."""
    state = load_container_state(cid)
    if not state:
        return None
    cdir, cow, rootfs = _container_runtime(state)
    wd = workdir or state.get("WorkingDir", "/")
    e = _container_env(state, env)
    fault = runtime_preflight(rootfs, e, workdir=wd, cow_bind=cow)
    if fault:
        raise RuntimeError(fault)
    fault = runtime_process_unavailable_message()
    if fault:
        raise RuntimeError(fault)
    argv = build_run_argv(rootfs, list(cmd), e, workdir=wd, cow_bind=cow, mode="exec")
    if tty:
        import pty
        master, slave = pty.openpty()
        proc = subprocess.Popen(argv, stdin=slave, stdout=slave, stderr=slave,
                                close_fds=True)
        os.close(slave)
        proc.stdout = os.fdopen(master, "rb", buffering=0)
        proc.stderr = None
        proc.stdin = os.fdopen(os.dup(master), "wb", buffering=0)
        return proc
    return subprocess.Popen(argv, stdin=stdin, stdout=stdout, stderr=stderr)


def exec_in_container(cid, cmd, env=None, workdir=None, tty=False):
    state = load_container_state(cid)
    if not state:
        return None
    cdir, cow, rootfs = _container_runtime(state)
    wd = workdir or state.get("WorkingDir", "/")
    e = _container_env(state, env)
    fault = runtime_preflight(rootfs, e, workdir=wd, cow_bind=cow)
    if fault:
        raise RuntimeError(fault)
    fault = runtime_process_unavailable_message()
    if fault:
        raise RuntimeError(fault)
    argv = build_run_argv(rootfs, list(cmd), e, workdir=wd, cow_bind=cow, mode="exec")
    return subprocess.run(argv, capture_output=True)


def runner_fault_message(output):
    """Return a concise diagnostic for known Android/PRoot exec failures."""
    text = output.decode("utf-8", "replace") if isinstance(output, bytes) else str(output or "")
    if "Bad address" in text and "execve(" in text:
        return (
            "pdocker runtime error: the bundled PRoot backend could not exec "
            "a container process on this Android build (execve returned "
            "EFAULT/Bad address). This is below Dockerfile/Compose level; "
            "repair or replace the Android execution backend before RUN, "
            "docker run, and compose services can work."
        )
    if "signal 11" in text and "proot" in text.lower():
        return (
            "pdocker runtime error: the bundled PRoot backend crashed while "
            "starting a container process. This Android execution backend is "
            "not usable for RUN/docker run/compose services on this device yet."
        )
    return ""


def runtime_preflight(rootfs, env=None, workdir="/", binds=None, cow_bind=None):
    """Return a diagnostic if the current runner cannot start /bin/sh."""
    backend_fault = runtime_backend_unavailable_message()
    if backend_fault:
        return backend_fault
    if os.environ.get("PDOCKER_RUNTIME_PREFLIGHT") != "1":
        return ""
    if os.environ.get("PDOCKER_SKIP_RUNTIME_PREFLIGHT") == "1":
        return ""
    if not RUNNER:
        return ""
    if not rootfs or not os.path.isdir(rootfs):
        return ""
    shell = os.path.join(rootfs, "bin/sh")
    if not os.path.exists(shell):
        shell = os.path.join(rootfs, "usr/bin/sh")
    if not os.path.exists(shell):
        return ""
    try:
        proc = subprocess.run(
            build_run_argv(rootfs, ["/bin/sh", "-c", "true"],
                           env or {}, workdir=workdir or "/",
                           binds=binds, cow_bind=cow_bind),
            capture_output=True,
            timeout=8,
        )
    except subprocess.TimeoutExpired:
        return (
            "pdocker runtime error: the Android execution backend timed out "
            "while starting a probe shell. RUN, docker run, and compose "
            "services are blocked until the no-PRoot backend is available."
        )
    except Exception as exc:
        return (
            "pdocker runtime error: the Android execution backend could not "
            f"start a probe shell: {exc}"
        )
    if proc.returncode == 0:
        return ""
    fault = runner_fault_message((proc.stdout or b"") + (proc.stderr or b""))
    if fault:
        return (
            "pdocker runtime preflight failed before running the requested "
            f"command.\n{fault}"
        )
    output = ((proc.stdout or b"") + (proc.stderr or b"")).decode("utf-8", "replace").strip()
    return (
        "pdocker runtime preflight failed before running the requested "
        f"command with exit code {proc.returncode}."
        + (f"\n{output}" if output else "")
    )


# ---- HTTP server ----

class DockerAPIHandler(BaseHTTPRequestHandler):
    server_version = "pdockerd/0.1"
    API_VERSION = "1.43"

    def log_message(self, fmt, *args):
        log(fmt % args)

    def _send_json(self, code, data):
        body = json.dumps(data).encode()
        self.send_response(code)
        self.send_header("Content-Type", "application/json")
        self.send_header("Api-Version", self.API_VERSION)
        self.send_header("Docker-Experimental", "false")
        self.send_header("Ostype", "linux")
        self.send_header("Server", "pdockerd/0.1")
        self.send_header("Content-Length", str(len(body)))
        self.end_headers()
        try:
            self.wfile.write(body)
        except BrokenPipeError:
            pass

    def _send_stream_started(self, content_type="application/json"):
        self.send_response(200)
        self.send_header("Content-Type", content_type)
        self.send_header("Api-Version", self.API_VERSION)
        self.end_headers()

    def _tail_log_until_exit(self, log_path, proc):
        """
        Tail `log_path` (the container's combined stdout+stderr log) and
        forward bytes to the hijacked socket using docker's multiplexed
        framing on stdout (stream=1). When `proc` exits, drain the
        remaining log and return.
        """
        try:
            f = open(log_path, "rb")
        except FileNotFoundError:
            return
        try:
            while True:
                chunk = f.read(4096)
                if chunk:
                    hdr = bytes([1, 0, 0, 0]) + len(chunk).to_bytes(4, "big")
                    try:
                        self.wfile.write(hdr + chunk)
                        self.wfile.flush()
                    except (BrokenPipeError, ConnectionResetError):
                        return
                    continue
                if proc.poll() is not None:
                    # Process done; one more drain then exit
                    chunk = f.read()
                    if chunk:
                        hdr = bytes([1, 0, 0, 0]) + len(chunk).to_bytes(4, "big")
                        try:
                            self.wfile.write(hdr + chunk)
                        except (BrokenPipeError, ConnectionResetError):
                            pass
                    return
                time.sleep(0.05)
        finally:
            f.close()

    def _pipe_to_multiplexed(self, proc, tty=False):
        """
        Stream Popen.stdout/.stderr to the hijacked socket using docker's
        multiplexed frame format: [stream_type(1), 0,0,0, len(4 BE)] + data.
        stream_type: 1=stdout, 2=stderr. In TTY mode the framing is
        omitted (docker CLI reads raw bytes).
        """
        import select
        fds = []
        if proc.stdout: fds.append((1, proc.stdout))
        if proc.stderr: fds.append((2, proc.stderr))
        fdmap = {f.fileno(): (st, f) for st, f in fds}
        while fdmap:
            try:
                ready, _, _ = select.select(list(fdmap.keys()), [], [], 1.0)
            except (OSError, ValueError):
                break
            for fd in ready:
                st, f = fdmap[fd]
                try:
                    chunk = os.read(fd, 4096)
                except OSError:
                    chunk = b""
                if not chunk:
                    fdmap.pop(fd, None)
                    continue
                try:
                    if tty:
                        self.wfile.write(chunk)
                    else:
                        hdr = bytes([st, 0, 0, 0]) + len(chunk).to_bytes(4, "big")
                        self.wfile.write(hdr + chunk)
                    self.wfile.flush()
                except (BrokenPipeError, ConnectionResetError):
                    return
            if not ready and proc.poll() is not None:
                # Process exited; drain any remaining and stop.
                for fd, (st, f) in list(fdmap.items()):
                    try:
                        rest = f.read()
                    except OSError:
                        rest = b""
                    if rest:
                        try:
                            if tty:
                                self.wfile.write(rest)
                            else:
                                hdr = bytes([st, 0, 0, 0]) + len(rest).to_bytes(4, "big")
                                self.wfile.write(hdr + rest)
                        except (BrokenPipeError, ConnectionResetError):
                            return
                break

    def _pipe_hijacked_stdin(self, proc):
        """Forward raw bytes from a hijacked docker connection to child stdin."""
        if not proc.stdin:
            return None

        def pump():
            try:
                while proc.poll() is None:
                    chunk = self.rfile.read(4096)
                    if not chunk:
                        break
                    try:
                        proc.stdin.write(chunk)
                        proc.stdin.flush()
                    except (BrokenPipeError, OSError):
                        break
            except (ConnectionResetError, OSError):
                pass
            finally:
                try:
                    proc.stdin.close()
                except OSError:
                    pass

        t = threading.Thread(target=pump, daemon=True, name="hijack-stdin")
        t.start()
        return t

    def _send_hijacked(self, content_type="application/vnd.docker.raw-stream"):
        """
        Send HTTP/1.1 101 Switching Protocols so the docker CLI hands
        the raw socket back. Required for `docker exec`, `docker run`,
        `docker attach` — all of which "hijack" the connection and
        proxy stdin/stdout over the bare TCP stream.
        """
        body = (
            f"HTTP/1.1 101 UPGRADED\r\n"
            f"Content-Type: {content_type}\r\n"
            f"Connection: Upgrade\r\n"
            f"Upgrade: tcp\r\n"
            f"Api-Version: {self.API_VERSION}\r\n"
            f"\r\n"
        ).encode()
        self.wfile.write(body)
        self.wfile.flush()

    def _read_body(self):
        # docker CLI sends `docker build` context with
        # Transfer-Encoding: chunked instead of Content-Length, so we
        # decode chunks here. Falls back to Content-Length for normal
        # JSON/POST payloads.
        if self.headers.get("Transfer-Encoding", "").lower() == "chunked":
            chunks = []
            while True:
                line = self.rfile.readline().strip()
                if not line:
                    continue
                try:
                    size = int(line.split(b";")[0], 16)
                except ValueError:
                    break
                if size == 0:
                    self.rfile.readline()  # consume trailing CRLF
                    break
                chunks.append(self.rfile.read(size))
                self.rfile.readline()  # CRLF after chunk
            return b"".join(chunks)
        length = int(self.headers.get("Content-Length") or 0)
        if length:
            return self.rfile.read(length)
        return b""

    def _read_json(self):
        b = self._read_body()
        if not b:
            return {}
        return json.loads(b)

    def _parse_path(self):
        parsed = urllib.parse.urlsplit(self.path)
        return parsed.path, urllib.parse.parse_qs(parsed.query)

    # --- Routes ---

    def _safe_500(self, e):
        """Try to send 500, but swallow the secondary write error if the
        client already hung up — otherwise we'd dirty the log with a
        useless traceback for every cancelled compose request."""
        if isinstance(e, (BrokenPipeError, ConnectionResetError)):
            return
        try:
            self._send_json(500, {"message": str(e)})
        except (BrokenPipeError, ConnectionResetError):
            pass

    def do_GET(self):
        try:
            path, query = self._parse_path()
            self._route("GET", path, query)
        except Exception as e:
            log(f"GET error: {e}")
            self._safe_500(e)

    def do_POST(self):
        try:
            path, query = self._parse_path()
            self._route("POST", path, query)
        except Exception as e:
            log(f"POST error: {e}")
            log(f"POST traceback:\n{traceback.format_exc()}")
            self._safe_500(e)

    def do_DELETE(self):
        try:
            path, query = self._parse_path()
            self._route("DELETE", path, query)
        except Exception as e:
            log(f"DELETE error: {e}")
            self._safe_500(e)

    def do_PUT(self):
        try:
            path, query = self._parse_path()
            self._route("PUT", path, query)
        except Exception as e:
            log(f"PUT error: {e}")
            self._safe_500(e)

    def do_HEAD(self):
        try:
            path, query = self._parse_path()
            self._route("HEAD", path, query)
        except Exception as e:
            if isinstance(e, (BrokenPipeError, ConnectionResetError)):
                return
            log(f"HEAD error: {e}")
            try:
                self.send_response(500)
                self.end_headers()
            except (BrokenPipeError, ConnectionResetError):
                pass

    def _route(self, method, path, query):
        # Strip version prefix /v1.43/...
        m = re.match(r"^/v\d+\.\d+(/.*)$", path)
        if m:
            path = m.group(1)

        # --- Basic ---
        if path in ("/_ping",):
            self.send_response(200)
            self.send_header("Api-Version", self.API_VERSION)
            self.send_header("Ostype", "linux")
            self.send_header("Docker-Experimental", "false")
            self.send_header("Content-Type", "text/plain")
            self.send_header("Content-Length", "2")
            self.end_headers()
            self.wfile.write(b"OK")
            return

        if path == "/version":
            self._send_json(200, {
                "Platform": {"Name": "pdockerd"},
                "Components": [
                    {"Name": "Engine", "Version": "0.1.0",
                     "Details": {"ApiVersion": self.API_VERSION, "MinAPIVersion": "1.12",
                                 "GitCommit": "pdocker", "GoVersion": "none",
                                 "Os": "linux", "Arch": "arm64",
                                 "KernelVersion": os.uname().release,
                                 "BuildTime": "2026-04-17T00:00:00.000000000+00:00",
                                 "Experimental": "false"}},
                ],
                "Version": "24.0.0",
                "ApiVersion": self.API_VERSION,
                "MinAPIVersion": "1.12",
                "GitCommit": "pdocker",
                "GoVersion": "none",
                "Os": "linux",
                "Arch": "arm64",
                "KernelVersion": os.uname().release,
                "BuildTime": "2026-04-17T00:00:00.000000000+00:00",
            })
            return

        if path == "/info":
            self._send_json(200, {
                "ID": runtime_info_id(),
                "Containers": len(list_containers(all_=True)),
                "ContainersRunning": len(list_containers(all_=False)),
                "ContainersPaused": 0,
                "ContainersStopped": len(list_containers(all_=True)) - len(list_containers(all_=False)),
                "Images": len(list_images()),
                "Driver": runtime_driver_name(),
                "DriverStatus": [["Root Dir", PDOCKER_HOME]],
                "SystemStatus": None,
                "Plugins": {"Volume": ["local"], "Network": ["host"], "Authorization": None, "Log": ["json-file"]},
                "MemoryLimit": False,
                "SwapLimit": False,
                "KernelMemory": False,
                "CpuCfsPeriod": False,
                "CpuCfsQuota": False,
                "CPUShares": False,
                "CPUSet": False,
                "PidsLimit": False,
                "IPv4Forwarding": False,
                "BridgeNfIptables": False,
                "Debug": False,
                "NFd": 0,
                "OomKillDisable": False,
                "NGoroutines": 0,
                "SystemTime": time.strftime("%Y-%m-%dT%H:%M:%S.000000000Z", time.gmtime()),
                "LoggingDriver": "json-file",
                "CgroupDriver": "none",
                "CgroupVersion": "1",
                "NEventsListener": 0,
                "KernelVersion": os.uname().release,
                "OperatingSystem": runtime_operating_system(),
                "OSVersion": "25.04",
                "OSType": "linux",
                "Architecture": "aarch64",
                "IndexServerAddress": "https://index.docker.io/v1/",
                "RegistryConfig": {"AllowNondistributableArtifactsCIDRs": None,
                                   "AllowNondistributableArtifactsHostnames": None,
                                   "InsecureRegistryCIDRs": ["127.0.0.0/8"],
                                   "IndexConfigs": {}, "Mirrors": None},
                "NCPU": os.cpu_count() or 1,
                "MemTotal": 0,
                "DockerRootDir": PDOCKER_HOME,
                "HttpProxy": "",
                "HttpsProxy": "",
                "NoProxy": "",
                "Name": socket.gethostname(),
                "Labels": [],
                "ExperimentalBuild": False,
                "ServerVersion": "24.0.0-pdocker",
                "Runtimes": {"pdocker-direct": {"path": "pdocker-direct"}},
                "DefaultRuntime": "pdocker-direct",
                "Swarm": {"NodeID": "", "NodeAddr": "", "LocalNodeState": "inactive",
                          "ControlAvailable": False, "Error": "", "RemoteManagers": None},
                "LiveRestoreEnabled": False,
                "Isolation": "",
                "InitBinary": "docker-init",
                "Warnings": ["WARNING: Android userspace runtime has no namespaces or cgroups yet"],
                "SecurityOptions": [],
            })
            return

        if path == "/system/operations" and method == "GET":
            self._send_json(200, list_active_operations())
            return

        # --- Images ---
        if path == "/images/json" and method == "GET":
            self._send_json(200, list_images())
            return

        if path == "/images/create" and method == "POST":
            fromImage = query.get("fromImage", [""])[0]
            tag = query.get("tag", ["latest"])[0]
            image = f"{fromImage}:{tag}" if ":" not in fromImage else fromImage
            self._send_stream_started()
            try:
                self.wfile.write(json.dumps({"status": f"Pulling {image}"}).encode() + b"\r\n")
                self.wfile.flush()
                pull_image(image)
                norm = normalize_image(image)
                record_event("image", "pull", image_id(norm), {"name": norm})
                self.wfile.write(json.dumps({"status": f"Status: Downloaded newer image for {image}"}).encode() + b"\r\n")
            except Exception as e:
                self.wfile.write(json.dumps({"errorDetail": {"message": str(e)}, "error": str(e)}).encode() + b"\r\n")
            return

        # GET /images/get?names=a&names=b — docker save
        if path == "/images/get" and method == "GET":
            names = query.get("names") or []
            if not names:
                self._send_json(400, {"message": "no image names specified"})
                return
            try:
                # Buffer the full OCI tar; pdockerd speaks HTTP/1.0 by
                # default, and chunked Transfer-Encoding isn't valid under
                # HTTP/1.0 — docker CLI would write the raw chunk framing
                # into the output file. Send with Content-Length instead.
                import io as _io
                buf = _io.BytesIO()
                save_images(names, buf)
                data = buf.getvalue()
                self.send_response(200)
                self.send_header("Content-Type", "application/x-tar")
                self.send_header("Content-Length", str(len(data)))
                self.end_headers()
                self.wfile.write(data)
                self.wfile.flush()
            except Exception as e:
                log(f"save error: {e}")
            return

        # POST /images/load — docker load
        if path == "/images/load" and method == "POST":
            try:
                body = self._read_body()
                import io as _io
                loaded = load_images(_io.BytesIO(body))
                self._send_stream_started()
                for ref in loaded:
                    record_event("image", "load", image_id(ref), {"name": ref})
                    msg = {"stream": f"Loaded image: {ref}\n"}
                    self.wfile.write(json.dumps(msg).encode() + b"\r\n")
                self.wfile.flush()
            except Exception as e:
                self._send_json(400, {"message": str(e)})
            return

        if path == "/images/prune" and method == "POST":
            self._send_json(200, {
                "ImagesDeleted": [],
                "SpaceReclaimed": 0,
            })
            return

        # /images/{name}/history
        m = re.match(r"^/images/(.+?)/history$", path)
        if m and method == "GET":
            name = urllib.parse.unquote(m.group(1))
            norm = normalize_image(name)
            d = image_dir(norm)
            if not os.path.isdir(d):
                self._send_json(404, {"message": f"No such image: {name}"})
                return
            lp = os.path.join(d, "layers.json")
            entries = []
            if os.path.exists(lp):
                try:
                    with open(lp) as f:
                        layers = json.load(f)
                except Exception:
                    layers = []
                img_id = image_id(norm)
                for i, ly in enumerate(layers):
                    try:
                        created_ts = int(time.mktime(time.strptime(
                            ly.get("created", ""), "%Y-%m-%dT%H:%M:%SZ")))
                    except Exception:
                        created_ts = 0
                    entries.append({
                        "Id": img_id if i == len(layers) - 1 else "<missing>",
                        "Created": created_ts,
                        "CreatedBy": ly.get("created_by", ""),
                        "Tags": [norm.replace("docker.io/library/", "").replace(
                            "docker.io/", "")] if i == len(layers) - 1 else None,
                        "Size": int(ly.get("size", 0) or 0),
                        "Comment": "",
                    })
            else:
                # Pulled image: fabricate single entry from config
                cfg = image_config(norm)
                if not cfg:
                    self._send_json(404, {"message": f"No such image: {name}"})
                    return
                try:
                    created_ts = int(time.mktime(time.strptime(
                        cfg.get("created", "")[:19], "%Y-%m-%dT%H:%M:%S")))
                except Exception:
                    created_ts = 0
                size = sum(
                    os.path.getsize(os.path.join(r, fn))
                    for r, _, files in os.walk(os.path.join(d, "rootfs"))
                    for fn in files
                    if os.path.isfile(os.path.join(r, fn))
                )
                entries.append({
                    "Id": image_id(norm),
                    "Created": created_ts,
                    "CreatedBy": "",
                    "Tags": [norm.replace("docker.io/library/", "").replace(
                        "docker.io/", "")],
                    "Size": size,
                    "Comment": "Pulled via crane",
                })
            entries.reverse()
            self._send_json(200, entries)
            return

        # /images/{name}/json
        m = re.match(r"^/images/(.+?)/json$", path)
        if m and method == "GET":
            name = urllib.parse.unquote(m.group(1))
            norm = normalize_image(name)
            cfg = image_config(norm)
            if not cfg:
                self._send_json(404, {"message": f"No such image: {name}"})
                return
            self._send_json(200, {
                "Id": image_id(norm),
                "RepoTags": [norm.replace("docker.io/library/", "").replace("docker.io/", "")],
                "RepoDigests": [],
                "Parent": "",
                "Comment": "",
                "Created": cfg.get("created", ""),
                "Architecture": cfg.get("architecture", "arm64"),
                "Os": cfg.get("os", "linux"),
                "Size": 0,
                "VirtualSize": 0,
                "Config": cfg.get("config", {}),
                "RootFS": cfg.get("rootfs", {"type": "layers", "layers": []}),
                "GraphDriver": {"Name": runtime_driver_name(), "Data": None},
            })
            return

        # DELETE /images/{name}
        m = re.match(r"^/images/(.+)$", path)
        if m and method == "DELETE":
            name = urllib.parse.unquote(m.group(1))
            norm = normalize_image(name)
            iid = image_id(norm)
            if remove_image(name):
                record_event("image", "delete", iid, {"name": norm})
                self._send_json(200, [{"Untagged": name}, {"Deleted": image_id(normalize_image(name))}])
            else:
                self._send_json(404, {"message": f"No such image: {name}"})
            return

        # --- Containers ---
        if path == "/containers/json" and method == "GET":
            all_ = query.get("all", ["false"])[0] in ("1", "true", "True")
            self._send_json(200, list_containers(all_=all_))
            return

        if path == "/containers/create" and method == "POST":
            config = self._read_json()
            name = query.get("name", [None])[0]
            state = create_container(config, name=name)
            self._send_json(201, {"Id": state["Id"], "Warnings": state.get("Warnings", [])})
            return

        # /containers/{id}/rename?name=new-name
        m = re.match(r"^/containers/(.+?)/rename$", path)
        if m and method == "POST":
            cid = m.group(1)
            state = find_container(cid)
            if not state:
                self._send_json(404, {"message": f"No such container: {cid}"})
                return
            new_name = (query.get("name", [""])[0] or "").strip().lstrip("/")
            if not new_name:
                self._send_json(400, {"message": "rename requires a non-empty name"})
                return
            state["Name"] = "/" + new_name
            state.setdefault("Config", {})["Hostname"] = new_name
            save_container_state(state["Id"], state)
            record_event("container", "rename", state["Id"], _container_event_attrs(state))
            self.send_response(204)
            self.end_headers()
            return

        # /containers/{id}/json
        m = re.match(r"^/containers/(.+?)/json$", path)
        if m and method == "GET":
            cid = m.group(1)
            state = find_container(cid)
            if not state:
                self._send_json(404, {"message": f"No such container: {cid}"})
                return
            state = reconcile_container_state(state)
            # Reshape into Docker inspect format
            resp = {
                "Id": state["Id"],
                "Created": state["Created"],
                "Path": (state.get("Entrypoint") or state.get("Cmd") or [""])[0],
                "Args": (state.get("Entrypoint") or state.get("Cmd") or [""])[1:],
                "State": state["State"],
                "Image": state["ImageId"],
                "ResolvConfPath": "",
                "HostnamePath": "",
                "HostsPath": "",
                "LogPath": os.path.join(LOGS_DIR, f"{state['Id']}.log"),
                "Name": state["Name"],
                "RestartCount": 0,
                "Driver": runtime_driver_name(),
                "Platform": "linux",
                "MountLabel": "",
                "ProcessLabel": "",
                "AppArmorProfile": "",
                "ExecIDs": None,
                "HostConfig": state.get("HostConfig", {}),
                "GraphDriver": {"Name": runtime_driver_name(), "Data": None},
                "Mounts": [],
                "Config": state.get("Config", {}),
                "NetworkSettings": state.get("NetworkSettings", {}),
                "PdockerNetwork": state.get("PdockerNetwork", {}),
                "PdockerGpu": state.get("PdockerGpu", {}),
                "PdockerWarnings": state.get("Warnings", []),
            }
            self._send_json(200, resp)
            return

        # /containers/{id}/start
        m = re.match(r"^/containers/(.+?)/start$", path)
        if m and method == "POST":
            cid = m.group(1)
            state = find_container(cid)
            if not state:
                self._send_json(404, {"message": f"No such container: {cid}"})
                return
            try:
                start_container(state["Id"])
            except RuntimeError as exc:
                self._send_json(500, {"message": str(exc)})
                return
            self.send_response(204)
            self.end_headers()
            return

        # /containers/{id}/attach — used by `docker run` to stream
        # the foreground container's stdout/stderr. Hijacks the socket.
        # The CLI calls attach BEFORE start, so we don't 409 — we hijack
        # the socket immediately, then wait (briefly) for start, then
        # tail the container's log file.
        m = re.match(r"^/containers/(.+?)/attach$", path)
        if m and method == "POST":
            cid = m.group(1)
            state = find_container(cid)
            if not state:
                self._send_json(404, {"message": f"No such container: {cid}"})
                return
            log_path = os.path.join(LOGS_DIR, f"{state['Id']}.log")
            self._send_hijacked()
            # Wait up to 15s for container to start, then tail.
            for _ in range(150):
                with running_lock:
                    proc = running_containers.get(state["Id"])
                if proc is not None:
                    break
                time.sleep(0.1)
            else:
                return
            self._tail_log_until_exit(log_path, proc)
            return

        # /containers/{id}/stop
        m = re.match(r"^/containers/(.+?)/stop$", path)
        if m and method == "POST":
            cid = m.group(1)
            state = find_container(cid)
            if not state:
                self._send_json(404, {"message": f"No such container: {cid}"})
                return
            timeout = int(query.get("t", ["10"])[0])
            stop_container(state["Id"], timeout=timeout)
            self.send_response(204)
            self.end_headers()
            return

        # /containers/{id}/kill
        m = re.match(r"^/containers/(.+?)/kill$", path)
        if m and method == "POST":
            cid = m.group(1)
            state = find_container(cid)
            if state:
                stop_container(state["Id"], timeout=0)
            self.send_response(204)
            self.end_headers()
            return

        # /containers/{id}/wait
        m = re.match(r"^/containers/(.+?)/wait$", path)
        if m and method == "POST":
            cid = m.group(1)
            state = find_container(cid)
            if not state:
                self._send_json(404, {"message": f"No such container: {cid}"})
                return
            # Docker CLI's `docker run --rm` calls wait BEFORE start with
            # condition=removed; if we returned immediately on missing proc
            # the CLI would drop attach/start mid-flight and exit silently.
            # Block on the actual condition instead.
            cond = query.get("condition", ["next-exit"])[0]
            cid_full = state["Id"]
            if cond == "removed":
                if state.get("State", {}).get("Status") == "created":
                    self._send_json(200, {"StatusCode": 0})
                    return
                # Spin until find_container() can no longer locate it.
                while find_container(cid_full):
                    # Also break if we know it ran and got removed via DELETE
                    # (find_container returns None then).
                    time.sleep(0.2)
                # Recover exit code from the now-deleted container's state
                # if anyone managed to capture it via in-memory tracker;
                # otherwise default to 0.
                rc = 0
            else:
                # next-exit / not-running: block until the proc terminates.
                # If the container hasn't started yet, wait for it to appear
                # in running_containers, then for it to exit.
                proc = None
                for _ in range(150):  # up to 15s for start
                    with running_lock:
                        proc = running_containers.get(cid_full)
                    if proc is not None:
                        break
                    time.sleep(0.1)
                if proc is not None:
                    rc = proc.wait()
                else:
                    s = load_container_state(cid_full) or {}
                    rc = s.get("State", {}).get("ExitCode", 0)
            self._send_json(200, {"StatusCode": rc})
            return

        # DELETE /containers/{id}
        m = re.match(r"^/containers/(.+)$", path)
        if m and method == "DELETE":
            cid = m.group(1)
            state = find_container(cid)
            if not state:
                self._send_json(404, {"message": f"No such container: {cid}"})
                return
            force = query.get("force", ["false"])[0] in ("1", "true", "True")
            if remove_container(state["Id"], force=force):
                self.send_response(204)
                self.end_headers()
            else:
                self._send_json(409, {"message": "container is running"})
            return

        # /containers/{id}/logs
        m = re.match(r"^/containers/(.+?)/logs$", path)
        if m and method == "GET":
            cid = m.group(1)
            state = find_container(cid)
            if not state:
                self._send_json(404, {"message": f"No such container: {cid}"})
                return
            log_file = os.path.join(LOGS_DIR, f"{state['Id']}.log")
            self._send_stream_started("application/vnd.docker.raw-stream")
            if os.path.exists(log_file):
                with open(log_file, "rb") as f:
                    # Docker multiplexed stream: 8-byte header + data per chunk
                    data = f.read()
                    if data:
                        header = bytes([1, 0, 0, 0]) + len(data).to_bytes(4, "big")
                        try:
                            self.wfile.write(header + data)
                        except BrokenPipeError:
                            pass
            return

        # /containers/{id}/stats — approximate via /proc (no cgroup access)
        m = re.match(r"^/containers/(.+?)/stats$", path)
        if m and method == "GET":
            cid = m.group(1)
            state = find_container(cid)
            if not state:
                self._send_json(404, {"message": f"No such container: {cid}"})
                return
            stream = query.get("stream", ["1"])[0] in ("1", "true", "True")
            self._handle_stats(state, stream)
            return

        # /containers/{id}/archive — docker cp endpoint
        # HEAD: stat info via X-Docker-Container-Path-Stat header (base64 JSON)
        # GET : stream tar of `path` from container rootfs
        # PUT : extract incoming tar into `path` in container rootfs
        m = re.match(r"^/containers/(.+?)/archive$", path)
        if m and method in ("HEAD", "GET", "PUT"):
            cid = m.group(1)
            state = find_container(cid)
            if not state:
                self._send_json(404, {"message": f"No such container: {cid}"})
                return
            ctr_path = query.get("path", ["/"])[0]
            cdir, _, _ = _container_runtime(state)
            host_target = _container_host_path(state, cdir, ctr_path, for_write=(method == "PUT"))
            if host_target is None:
                self._send_json(400, {"message": "path escapes rootfs"})
                return

            if method == "HEAD":
                if not os.path.lexists(host_target):
                    self._send_json(404, {"message": f"path not found: {ctr_path}"})
                    return
                st = os.lstat(host_target)
                stat_info = {
                    "name": os.path.basename(ctr_path) or "/",
                    "size": st.st_size,
                    "mode": st.st_mode,
                    "mtime": time.strftime(
                        "%Y-%m-%dT%H:%M:%SZ", time.gmtime(st.st_mtime)
                    ),
                    "linkTarget": os.readlink(host_target) if os.path.islink(host_target) else "",
                }
                import base64
                self.send_response(200)
                self.send_header(
                    "X-Docker-Container-Path-Stat",
                    base64.b64encode(json.dumps(stat_info).encode()).decode(),
                )
                self.send_header("Content-Type", "application/json")
                self.end_headers()
                return

            if method == "GET":
                if not os.path.lexists(host_target):
                    self._send_json(404, {"message": f"path not found: {ctr_path}"})
                    return
                # Stream tar of host_target. Tar arcname uses basename so
                # docker cp extracts as `dst/<basename>` on the receiving end.
                # GET also returns X-Docker-Container-Path-Stat (same as HEAD)
                # — docker CLI requires it to validate the source.
                import base64
                st = os.lstat(host_target)
                stat_info = {
                    "name": os.path.basename(ctr_path) or "/",
                    "size": st.st_size,
                    "mode": st.st_mode,
                    "mtime": time.strftime(
                        "%Y-%m-%dT%H:%M:%SZ", time.gmtime(st.st_mtime)
                    ),
                    "linkTarget": os.readlink(host_target) if os.path.islink(host_target) else "",
                }
                self.send_response(200)
                self.send_header(
                    "X-Docker-Container-Path-Stat",
                    base64.b64encode(json.dumps(stat_info).encode()).decode(),
                )
                self.send_header("Content-Type", "application/x-tar")
                self.end_headers()
                try:
                    with tarfile.open(fileobj=self.wfile, mode="w|") as tf:
                        tf.add(host_target, arcname=os.path.basename(ctr_path) or ".")
                except BrokenPipeError:
                    pass
                return

            if method == "PUT":
                # Extract uploaded tar into host_target (must be a dir)
                if not os.path.isdir(host_target):
                    self._send_json(
                        400, {"message": f"target is not a directory: {ctr_path}"}
                    )
                    return
                body = self._read_body()
                try:
                    with tarfile.open(fileobj=BytesIO(body), mode="r|*") as tf:
                        tf.extractall(host_target, filter="data")
                except Exception as e:
                    self._send_json(500, {"message": f"extract failed: {e}"})
                    return
                self.send_response(200)
                self.end_headers()
                return

        # /containers/{id}/exec
        m = re.match(r"^/containers/(.+?)/exec$", path)
        if m and method == "POST":
            cid = m.group(1)
            state = find_container(cid)
            if not state:
                self._send_json(404, {"message": f"No such container: {cid}"})
                return
            payload = self._read_json()
            exec_id = uuid.uuid4().hex
            exec_sessions[exec_id] = {
                "container": state["Id"],
                "cmd": payload.get("Cmd", []),
                "env": payload.get("Env", []),
                "workdir": payload.get("WorkingDir"),
                "tty": payload.get("Tty", False),
                "running": False,
                "exit_code": None,
            }
            self._send_json(201, {"Id": exec_id})
            return

        # /exec/{id}/start — hijacks the connection so docker CLI can
        # stream stdin/stdout/stderr directly to the spawned process.
        m = re.match(r"^/exec/(.+?)/start$", path)
        if m and method == "POST":
            exec_id = m.group(1)
            ses = exec_sessions.get(exec_id)
            if not ses:
                self._send_json(404, {"message": "no such exec"})
                return
            payload = self._read_json() if self.headers.get("Content-Length") else {}
            detach = bool(payload.get("Detach"))
            tty = bool(payload.get("Tty") or ses.get("tty"))
            ses["running"] = True
            try:
                proc = spawn_in_container(
                    ses["container"], ses["cmd"],
                    env=ses["env"], workdir=ses["workdir"], tty=tty,
                    stdout=subprocess.PIPE, stderr=subprocess.PIPE,
                    stdin=subprocess.PIPE,
                )
            except RuntimeError as exc:
                self._send_json(500, {"message": str(exc)})
                return
            if proc is None:
                self._send_json(404, {"message": "container missing"})
                return
            if detach:
                self._send_stream_started("application/vnd.docker.raw-stream")
                ses["running"] = False
                ses["exit_code"] = 0
                return
            self._send_hijacked()
            self._pipe_hijacked_stdin(proc)
            # Stream stdout/stderr live with docker's multiplex framing
            self._pipe_to_multiplexed(proc, tty=tty)
            ses["exit_code"] = proc.wait()
            ses["running"] = False
            return

        # /exec/{id}/json
        m = re.match(r"^/exec/(.+?)/json$", path)
        if m and method == "GET":
            exec_id = m.group(1)
            ses = exec_sessions.get(exec_id)
            if not ses:
                self._send_json(404, {"message": "no such exec"})
                return
            self._send_json(200, {
                "ID": exec_id,
                "Running": ses["running"],
                "ExitCode": ses["exit_code"] or 0,
                "ProcessConfig": {},
                "OpenStdin": False,
                "OpenStdout": True,
                "OpenStderr": True,
                "ContainerID": ses["container"],
                "Pid": 0,
            })
            return

        # Build/system prune: enough Docker API compatibility for
        # `docker builder prune` and for the Android UI to clear interrupted
        # build rootfs trees without scanning the whole image store.
        if path == "/build/prune" and method == "POST":
            removed = prune_build_artifacts()
            layers = prune_unreferenced_layers()
            self._send_json(200, {
                "CachesDeleted": removed + layers["Deleted"],
                "BuildRootfsDeleted": removed,
                "LayersDeleted": layers["Deleted"],
                "SpaceReclaimed": layers["SpaceReclaimed"],
            })
            return

        if path == "/containers/prune" and method == "POST":
            deleted = []
            for name in list(os.listdir(CONTAINERS_DIR)):
                if name.startswith("build_"):
                    continue
                state = load_container_state(name)
                if not state or state.get("State", {}).get("Running"):
                    continue
                if remove_container(name, force=True):
                    deleted.append(name)
            self._send_json(200, {
                "ContainersDeleted": deleted,
                "SpaceReclaimed": 0,
            })
            return

        if path == "/system/prune" and method == "POST":
            build_removed = prune_build_artifacts()
            layers = prune_unreferenced_layers()
            containers_deleted = []
            for name in list(os.listdir(CONTAINERS_DIR)):
                if name.startswith("build_"):
                    continue
                state = load_container_state(name)
                if not state or state.get("State", {}).get("Running"):
                    continue
                if remove_container(name, force=True):
                    containers_deleted.append(name)
            self._send_json(200, {
                "ContainersDeleted": containers_deleted,
                "ImagesDeleted": [],
                "NetworksDeleted": [],
                "VolumesDeleted": [],
                "BuildCacheDeleted": build_removed + layers["Deleted"],
                "BuildRootfsDeleted": build_removed,
                "LayersDeleted": layers["Deleted"],
                "SpaceReclaimed": layers["SpaceReclaimed"],
            })
            return

        # --- Networks (DNS aliasing — host-network underneath) ---
        # Spoil: PRoot can't do real bridging (no netlink/iptables/veth),
        # so all members of a named network resolve to 127.0.0.1 via
        # injected /etc/hosts entries. Port collisions on the same host
        # port between members are unavoidable — that's the user's problem.
        if path == "/networks" and method == "GET":
            nets = [{
                "Name": "bridge", "Id": "bridge",
                "Created": "2026-01-01T00:00:00Z",
                "Scope": "local", "Driver": "host",
                "IPAM": {"Driver": "default", "Config": []},
                "Containers": {}, "Options": {}, "Labels": {}}]
            for n in os.listdir(NETWORKS_DIR):
                np_ = os.path.join(NETWORKS_DIR, n)
                if os.path.isdir(np_):
                    meta = _network_meta(n)
                    nets.append({
                        "Name": n, "Id": n,
                        "Created": meta.get("Created", "2026-01-01T00:00:00Z"),
                        "Scope": "local",
                        "Driver": meta.get("Driver", "host"),
                        "IPAM": meta.get("IPAM", {"Driver": "default", "Config": []}),
                        "Containers": _network_containers(n),
                        "Options": meta.get("Options", {}),
                        "Labels": meta.get("Labels", {})})
            self._send_json(200, nets)
            return

        if path == "/networks/create" and method == "POST":
            payload = self._read_json()
            name = payload.get("Name") or f"net_{uuid.uuid4().hex[:8]}"
            np_ = os.path.join(NETWORKS_DIR, name)
            os.makedirs(np_, exist_ok=True)
            mp = os.path.join(np_, "members.json")
            if not os.path.exists(mp):
                with open(mp, "w") as f:
                    json.dump([], f)
            # Persist client-supplied metadata so subsequent inspects (esp.
            # docker-compose's idempotency check on Labels) round-trip cleanly.
            meta = {
                "Created": time.strftime("%Y-%m-%dT%H:%M:%SZ", time.gmtime()),
                "Driver": payload.get("Driver", "host"),
                "Options": payload.get("Options") or {},
                "Labels": payload.get("Labels") or {},
                "IPAM": payload.get("IPAM") or {"Driver": "default", "Config": []},
            }
            with open(os.path.join(np_, "meta.json"), "w") as f:
                json.dump(meta, f)
            record_event("network", "create", name, {
                "name": name,
                "type": meta["Driver"],
            })
            self._send_json(201, {
                "Id": name,
                "Warning": "host-network underneath; members resolve via /etc/hosts to 127.0.0.1",
            })
            return

        if path == "/networks/prune" and method == "POST":
            deleted = []
            if os.path.isdir(NETWORKS_DIR):
                for name in list(os.listdir(NETWORKS_DIR)):
                    np_ = os.path.join(NETWORKS_DIR, name)
                    if not os.path.isdir(np_):
                        continue
                    if _network_members(name):
                        continue
                    try:
                        shutil.rmtree(np_)
                        deleted.append(name)
                    except OSError as exc:
                        log(f"network prune {name} error: {exc}")
            self._send_json(200, {
                "NetworksDeleted": deleted,
                "SpaceReclaimed": 0,
            })
            return

        m = re.match(r"^/networks/(.+?)(/connect|/disconnect)?$", path)
        if m:
            net_name = m.group(1)
            sub = m.group(2)
            np_ = os.path.join(NETWORKS_DIR, net_name)
            if method == "GET":
                # Built-in 'bridge' is always present; user networks must
                # exist on disk. Returning 200 for missing networks fools
                # docker-compose into thinking a phantom net it never
                # created already exists.
                if net_name != "bridge" and not os.path.isdir(np_):
                    self._send_json(404, {"message": f"network {net_name} not found"})
                    return
                meta = _network_meta(net_name)
                self._send_json(200, {
                    "Name": net_name, "Id": net_name,
                    "Created": meta.get("Created", "2026-01-01T00:00:00Z"),
                    "Scope": "local",
                    "Driver": meta.get("Driver", "host"),
                    "IPAM": meta.get("IPAM", {"Driver": "default", "Config": []}),
                    "Containers": _network_containers(net_name) if os.path.isdir(np_) else {},
                    "Options": meta.get("Options", {}),
                    "Labels": meta.get("Labels", {})})
                return
            if method == "DELETE":
                shutil.rmtree(np_, ignore_errors=True)
                record_event("network", "destroy", net_name, {"name": net_name})
                self.send_response(204); self.end_headers()
                return
            if method == "POST" and sub in ("/connect", "/disconnect"):
                payload = self._read_json() or {}
                cid_or_name = payload.get("Container", "")
                state = find_container(cid_or_name)
                if not state:
                    self._send_json(404, {"message": f"No such container: {cid_or_name}"})
                    return
                os.makedirs(np_, exist_ok=True)
                mp = os.path.join(np_, "members.json")
                members = []
                if os.path.exists(mp):
                    with open(mp) as f:
                        members = json.load(f)
                cid = state["Id"]
                cname = state.get("Name", cid).lstrip("/")
                if sub == "/connect":
                    if not any(m_["id"] == cid for m_ in members):
                        members.append({"id": cid, "name": cname})
                    record_event("network", "connect", net_name, {
                        "name": net_name,
                        "container": cid,
                    })
                else:
                    members = [m_ for m_ in members if m_["id"] != cid]
                    record_event("network", "disconnect", net_name, {
                        "name": net_name,
                        "container": cid,
                    })
                with open(mp, "w") as f:
                    json.dump(members, f)
                self.send_response(200); self.end_headers()
                return
            if method == "POST":
                self.send_response(200); self.end_headers()
                return
            return

        # --- Volumes (real lifecycle) ---
        if path == "/volumes" and method == "GET":
            vols = []
            for v in os.listdir(VOLUMES_DIR):
                if os.path.isdir(os.path.join(VOLUMES_DIR, v)):
                    vols.append(_volume_public(v))
            self._send_json(200, {"Volumes": vols, "Warnings": []})
            return

        if path == "/volumes/create" and method == "POST":
            payload = self._read_json()
            name = payload.get("Name") or f"vol_{uuid.uuid4().hex[:12]}"
            driver = payload.get("Driver") or "local"
            _ensure_volume(name, driver=driver,
                           labels=payload.get("Labels") or {},
                           options=payload.get("DriverOpts") or {})
            attrs = {"name": name, "driver": driver}
            attrs.update(payload.get("Labels") or {})
            record_event("volume", "create", name, attrs)
            self._send_json(201, _volume_public(name))
            return

        if path == "/volumes/prune" and method == "POST":
            removed = []
            space = 0
            for v in os.listdir(VOLUMES_DIR):
                if not os.path.isdir(os.path.join(VOLUMES_DIR, v)):
                    continue
                if _volume_refcount(v) == 0:
                    try:
                        shutil.rmtree(os.path.join(VOLUMES_DIR, v))
                        removed.append(v)
                    except OSError:
                        pass
            self._send_json(200, {"VolumesDeleted": removed, "SpaceReclaimed": space})
            return

        m = re.match(r"^/volumes/(.+)$", path)
        if m:
            name = m.group(1)
            vp = os.path.join(VOLUMES_DIR, name)
            if method == "DELETE":
                if not os.path.isdir(vp):
                    self._send_json(404, {"message": f"no such volume: {name}"})
                    return
                force = query.get("force", ["0"])[0] in ("1", "true", "True")
                if not force and _volume_refcount(name) > 0:
                    self._send_json(409,
                        {"message": f"volume is in use: {name}"})
                    return
                shutil.rmtree(vp, ignore_errors=True)
                record_event("volume", "destroy", name, {"name": name})
                self.send_response(204); self.end_headers()
                return
            if method == "GET":
                if not os.path.isdir(vp):
                    self._send_json(404, {"message": f"no such volume: {name}"})
                    return
                self._send_json(200, _volume_public(name))
                return

        # --- Build (Dockerfile) ---
        if path == "/build" and method == "POST":
            self._handle_build(query)
            return

        # --- Events ---
        if path == "/events" and method == "GET":
            self._handle_events(query)
            return

        # --- Unknown ---
        log(f"Unknown route: {method} {path}")
        self._send_json(404, {"message": f"page not found: {path}"})

    def _handle_events(self, query):
        since = _parse_event_time(query.get("since", [None])[0], default=0)
        until_raw = query.get("until", [None])[0]
        until = _parse_event_time(until_raw, default=0)
        filters = _decode_event_filters(query.get("filters", [""])[0])

        def selected(events, start_index=0):
            out = []
            for ev in events[start_index:]:
                ts = float(ev.get("time", 0))
                if ts < since:
                    continue
                if until and ts > until:
                    continue
                if _event_matches(ev, filters):
                    out.append(ev)
            return out

        self._send_stream_started("application/json")
        index = 0
        try:
            with events_cond:
                events = _load_events_unlocked()
                index = len(events)
            for ev in selected(events):
                self.wfile.write(json.dumps(ev).encode() + b"\n")
            self.wfile.flush()

            # `docker events --until ...` expects a finite stream. Without an
            # until, keep the connection open and publish live events.
            if until_raw is not None:
                while time.time() <= until:
                    with events_cond:
                        events_cond.wait(timeout=min(1, max(0, until - time.time())))
                        events = _load_events_unlocked()
                        new = selected(events, index)
                        index = len(events)
                    for ev in new:
                        self.wfile.write(json.dumps(ev).encode() + b"\n")
                    self.wfile.flush()
                return

            while True:
                with events_cond:
                    events_cond.wait(timeout=30)
                    events = _load_events_unlocked()
                    new = selected(events, index)
                    index = len(events)
                for ev in new:
                    self.wfile.write(json.dumps(ev).encode() + b"\n")
                self.wfile.flush()
        except (BrokenPipeError, ConnectionResetError):
            return

    def _handle_stats(self, state, stream):
        """
        Approximate `docker stats` via /proc — cgroup is not accessible
        under PRoot, so we walk the container's process tree and sum
        CPU ticks (utime+stime+cutime+cstime from /proc/<pid>/stat) and
        VmRSS (from /proc/<pid>/status). Returns Docker stats v1 JSON.
        Spoil: limits are not enforced (no cgroup), system_cpu_usage is
        a host-wide read; per-container CPU% is computed from delta.
        """
        cid = state["Id"]
        clk_tck = os.sysconf("SC_CLK_TCK")
        page_sz = os.sysconf("SC_PAGESIZE")

        def descendants(root_pid):
            out = {root_pid}
            try:
                with open(f"/proc/{root_pid}/task/{root_pid}/children") as f:
                    kids = [int(x) for x in f.read().split() if x.isdigit()]
            except OSError:
                return out
            for k in kids:
                out |= descendants(k)
            return out

        def sample():
            with running_lock:
                proc = running_containers.get(cid)
            pid = proc.pid if proc else 0
            cpu_ticks = 0
            mem_bytes = 0
            num_procs = 0
            if pid:
                for p in descendants(pid):
                    try:
                        with open(f"/proc/{p}/stat") as f:
                            s = f.read().rsplit(")", 1)[1].split()
                        # fields after comm: state, ppid, pgrp, ..., utime(13), stime(14), cutime(15), cstime(16)
                        cpu_ticks += int(s[11]) + int(s[12]) + int(s[13]) + int(s[14])
                        with open(f"/proc/{p}/status") as f:
                            for line in f:
                                if line.startswith("VmRSS:"):
                                    mem_bytes += int(line.split()[1]) * 1024
                                    break
                        num_procs += 1
                    except (OSError, ValueError, IndexError):
                        pass
            try:
                with open("/proc/stat") as f:
                    fields = f.readline().split()[1:8]
                system_cpu = sum(int(x) for x in fields) * (10**9 // clk_tck)
            except OSError:
                system_cpu = 0
            container_cpu = cpu_ticks * (10**9 // clk_tck)
            return {
                "read": time.strftime("%Y-%m-%dT%H:%M:%SZ", time.gmtime()),
                "preread": "0001-01-01T00:00:00Z",
                "pids_stats": {"current": num_procs},
                "memory_stats": {
                    "usage": mem_bytes,
                    "max_usage": mem_bytes,
                    "limit": page_sz * os.sysconf("SC_PHYS_PAGES"),
                    "stats": {},
                },
                "cpu_stats": {
                    "cpu_usage": {
                        "total_usage": container_cpu,
                        "usage_in_kernelmode": 0,
                        "usage_in_usermode": container_cpu,
                    },
                    "system_cpu_usage": system_cpu,
                    "online_cpus": os.cpu_count() or 1,
                    "throttling_data": {"periods": 0, "throttled_periods": 0, "throttled_time": 0},
                },
                "precpu_stats": {
                    "cpu_usage": {"total_usage": 0, "usage_in_kernelmode": 0, "usage_in_usermode": 0},
                    "system_cpu_usage": 0,
                    "online_cpus": 0,
                    "throttling_data": {"periods": 0, "throttled_periods": 0, "throttled_time": 0},
                },
                "blkio_stats": {},
                "networks": {},
                "name": "/" + state.get("Name", cid).lstrip("/"),
                "id": cid,
            }

        self._send_stream_started("application/json")
        try:
            while True:
                self.wfile.write(json.dumps(sample()).encode() + b"\n")
                self.wfile.flush()
                if not stream:
                    return
                time.sleep(1)
        except (BrokenPipeError, ConnectionResetError):
            return

    def _handle_build(self, query):
        """Handle POST /build - receive tar context + Dockerfile, execute build."""
        tag = query.get("t", [""])[0]
        dockerfile_name = query.get("dockerfile", ["Dockerfile"])[0]
        buildargs = json.loads(query.get("buildargs", ["{}"])[0])
        op_id = start_operation(
            "build",
            f"build {tag or '<none>'}",
            f"receiving {dockerfile_name}",
        )

        self._send_stream_started()

        def emit(msg, newline=True):
            try:
                text = msg + "\n" if newline else msg
                clean = text.replace("\r", "\n").strip().split("\n")
                for line in reversed(clean):
                    if line.strip():
                        update_operation(op_id, line.strip())
                        break
                self.wfile.write(json.dumps({"stream": text}).encode() + b"\r\n")
                self.wfile.flush()
            except BrokenPipeError:
                pass

        def emit_error(msg):
            try:
                payload = {"errorDetail": {"message": msg}, "error": msg}
                self.wfile.write(json.dumps(payload).encode() + b"\r\n")
                self.wfile.flush()
            except BrokenPipeError:
                pass

        try:
            # Read context tar (may be chunked transfer)
            context_tar = self._read_body()
            import tempfile
            with tempfile.TemporaryDirectory() as ctx_dir:
                with tarfile.open(fileobj=BytesIO(context_tar)) as tf:
                    tf.extractall(ctx_dir, filter="data")
                apply_dockerignore(ctx_dir, emit)
                dockerfile_path = os.path.join(ctx_dir, dockerfile_name)
                if not os.path.exists(dockerfile_path):
                    emit(f"ERROR: {dockerfile_name} not found in context")
                    return

                result = execute_dockerfile_build(
                    dockerfile_path, ctx_dir, tag, buildargs, emit,
                )
                if result:
                    record_event("image", "build", image_id(result),
                                 {"name": result})
                    emit(f"Successfully built {result}")
                    emit(f"Successfully tagged {tag}")
                    finish_operation(op_id, "done", f"Successfully tagged {tag}")
                else:
                    emit("ERROR: build failed")
                    emit_error("build failed")
                    finish_operation(op_id, "failed", "build failed")
        except Exception as e:
            emit(f"ERROR: {e}")
            emit_error(str(e))
            finish_operation(op_id, "failed", str(e))
            log(traceback.format_exc())


def execute_dockerfile_build(dockerfile_path, context_dir, tag, buildargs, emit):
    """Execute a Dockerfile. Returns the final image name on success."""
    with open(dockerfile_path) as f:
        lines = []
        current = ""
        for raw in f:
            raw = raw.rstrip("\n")
            if raw.strip().startswith("#") or not raw.strip():
                continue
            if raw.endswith("\\"):
                current += raw[:-1] + " "
                continue
            current += raw
            lines.append(current)
            current = ""
        if current:
            lines.append(current)

    build_id = uuid.uuid4().hex
    build_dir = os.path.join(CONTAINERS_DIR, "build_" + build_id)
    rootfs = None
    workdir = "/"
    env = {}
    cmd = None
    entrypoint = None
    user = ""
    labels = {}
    exposed_ports = {}
    volumes = {}
    shell = ["/bin/sh", "-c"]
    healthcheck = None
    stop_signal = None
    onbuild = []
    author = None
    layers = []
    # Phase 4: content-addressable layer stack. Starts with base image
    # layers after FROM; each RUN/COPY/ADD appends the snapshot of its
    # delta vs. the prior merged view. WORKDIR/ENV/CMD/... are
    # empty_layer (config-only).
    diff_ids = []
    base_layer_count = [0]
    prior_tag_diff_ids = []
    prior_tag_fs_history = []
    if tag:
        prior_cfg = image_config(normalize_image(tag)) or {}
        prior_tag_diff_ids = [
            d.split(":", 1)[-1]
            for d in ((prior_cfg.get("rootfs") or {}).get("diff_ids") or [])
            if d
        ]
        prior_tag_fs_history = [
            h for h in (prior_cfg.get("history") or [])
            if not h.get("empty_layer")
        ]
    # Paths that are build-time scaffolding, not real image content —
    # libcow is a runtime shim; resolv.conf/hosts are rewritten per run.
    _BUILD_SKIP = (
        ".libcow.so",
        "etc/resolv.conf",
        "etc/hosts",
        "etc/apt/apt.conf.d/00pdocker-direct-sandbox",
    )

    def _rootfs_size():
        if not rootfs or not os.path.isdir(rootfs):
            return 0
        total = 0
        for root, _, files in os.walk(rootfs):
            for fn in files:
                p = os.path.join(root, fn)
                try:
                    total += os.path.getsize(p)
                except OSError:
                    pass
        return total

    last_size = [0]
    last_snapshot_size = [None]

    def record_layer(created_by, empty_layer=False, size_delta=None):
        if empty_layer:
            delta = 0
        elif size_delta is not None:
            delta = size_delta
        else:
            cur = _rootfs_size()
            delta = cur - last_size[0]
            last_size[0] = cur
        layers.append({
            "created_by": created_by,
            "created": time.strftime("%Y-%m-%dT%H:%M:%SZ", time.gmtime()),
            "size": max(0, delta),
            "empty_layer": empty_layer,
        })

    def snapshot_layer(label, prev_diff_ids=None, changed_paths=None, deleted_paths=None):
        emit(f"  snapshotting layer: {label}")
        start = time.perf_counter()
        profile = {}
        try:
            did = _snapshot_tree_as_layer(
                rootfs, prev_diff_ids=prev_diff_ids, skip_paths=_BUILD_SKIP,
                profile=profile, changed_paths=changed_paths,
                deleted_paths=deleted_paths,
            )
        except Exception:
            cleanup_failed_build()
            raise
        last_snapshot_size[0] = _layer_size(did)
        elapsed = time.perf_counter() - start
        parts = [
            f"prev-index={profile.get('prev_index', 0.0):.3f}s",
            f"walk={profile.get('walk_current', 0.0):.3f}s",
            f"whiteouts={profile.get('whiteouts', 0.0):.3f}s",
            f"stage={profile.get('stage', 0.0):.3f}s",
            f"tar={profile.get('tar', 0.0):.3f}s",
            f"digest={profile.get('digest', 0.0):.3f}s",
            f"extract={profile.get('extract', 0.0):.3f}s",
            f"relink={profile.get('relink', 0.0):.3f}s",
            f"cleanup={profile.get('cleanup', 0.0):.3f}s",
            f"changed={int(profile.get('changed_paths', 0))}",
            f"seen={int(profile.get('seen_paths', 0))}",
            f"prev={int(profile.get('prev_paths', 0))}",
            f"whiteout={int(profile.get('whiteout_paths', 0))}",
            f"mode={'paths' if changed_paths is not None else 'scan'}",
        ]
        emit(f"  build-profile snapshot {label}: " + " ".join(parts))
        emit(f"  layer sha256:{did[:12]} ({elapsed:.1f}s)")
        return did

    def build_state_for_cache(extra=None):
        state = {
            "env": dict(sorted(env.items())),
            "workdir": workdir,
            "shell": list(shell),
            "user": user,
            "platform": PLATFORM,
        }
        if extra:
            state.update(extra)
        return state

    def run_changed_paths(command):
        """Detect simple metadata-only RUN commands.

        A command such as `RUN chmod +x /usr/local/bin/foo` changes one inode's
        metadata. Treating it as an unknown RUN forces a full rootfs diff scan,
        which is brutally expensive for the dev workspace image. Keep this
        conservative: if parsing sees shell operators, env expansion, or
        relative paths, fall back to a full scan.
        """
        try:
            tokens = shlex.split(command)
        except ValueError:
            return None
        if len(tokens) < 3 or tokens[0] != "chmod":
            return None
        changed = []
        for token in tokens[1:]:
            if token == "--":
                continue
            if token.startswith("-") or re.fullmatch(r"[ugoa]*[=+-][rwxXstugo,=+-]+", token) or re.fullmatch(r"[0-7]{3,4}", token):
                continue
            if not token.startswith("/") or any(ch in token for ch in "$`*?[];&|<>"):
                return None
            changed.append(token.lstrip("/"))
        return changed or None

    def prior_tag_layer(created_by, parent_diff_ids):
        """Reuse a layer from the image currently stored at the same tag.

        This is pdocker's lightweight equivalent of Docker's local build cache
        import. It lets the first rebuild after an APK upgrade use the existing
        dev-workspace image instead of rerunning apt/npm just to populate the
        new metadata cache.
        """
        if not _build_cache_enabled() or not prior_tag_diff_ids:
            return None
        parents = [d.split(":", 1)[-1] for d in parent_diff_ids]
        if prior_tag_diff_ids[:len(parents)] != parents:
            return None
        built_index = len(parents) - base_layer_count[0]
        if built_index < 0 or built_index >= len(prior_tag_fs_history):
            return None
        hist = prior_tag_fs_history[built_index] or {}
        if hist.get("created_by") != created_by:
            return None
        if len(prior_tag_diff_ids) <= len(parents):
            return None
        did = prior_tag_diff_ids[len(parents)]
        return did if _layer_exists(did) else None

    def rematerialize_build_rootfs():
        if not rootfs:
            return
        if os.environ.get("PDOCKER_REMATERIALIZE_AFTER_LAYER", "0") != "1":
            return
        start = time.perf_counter()
        if os.path.exists(rootfs):
            shutil.rmtree(rootfs)
        materialize_container_rootfs(rootfs, diff_ids)
        for sub in ["proc", "sys", "dev", "tmp", "etc"]:
            os.makedirs(os.path.join(rootfs, sub), exist_ok=True)
        _prepare_rootfs_runtime_files(rootfs)
        emit(f"  build-profile rematerialize: {time.perf_counter() - start:.3f}s")

    def cleanup_failed_build():
        if os.environ.get("PDOCKER_KEEP_FAILED_BUILD_ROOTFS", "0") == "1":
            return
        shutil.rmtree(build_dir, ignore_errors=True)

    def fail_build():
        cleanup_failed_build()
        return None

    # Merge buildargs
    args_dict = dict(buildargs or {})

    def expand(s):
        for k, v in args_dict.items():
            s = s.replace("${" + k + "}", str(v)).replace("$" + k, str(v))
        return s

    def parse_from_base(from_args):
        tokens = shlex.split(from_args)
        while tokens and tokens[0].startswith("--"):
            tokens.pop(0)
        if not tokens:
            return ""
        return tokens[0]

    def parse_json_or_shell(value):
        value = value.strip()
        if value.startswith("["):
            try:
                return json.loads(value)
            except Exception:
                return ["/bin/sh", "-c", value]
        return ["/bin/sh", "-c", value]

    def build_run_command(value):
        value = value.strip()
        if value.startswith("["):
            try:
                return json.loads(value)
            except Exception:
                pass
        return list(shell) + [value]

    def try_reuse_existing_tag():
        if not tag or not _build_cache_enabled():
            return None
        norm_tag = normalize_image(tag)
        existing_dir = image_dir(norm_tag)
        existing_rootfs = os.path.join(existing_dir, "rootfs")
        existing_cfg = image_config(norm_tag) or {}
        existing_diff_ids = _load_image_manifest(existing_dir)
        if not existing_diff_ids or not os.path.isdir(existing_rootfs):
            return None
        history = [h.get("created_by", "") for h in (existing_cfg.get("history") or [])]
        expected = []
        copy_checks = []
        cache_args = dict(buildargs or {})
        cache_workdir = "/"
        base_diff_ids = []

        def cache_expand(value):
            out = value
            for k, v in cache_args.items():
                out = out.replace("${" + k + "}", str(v)).replace("$" + k, str(v))
            return out

        def file_equal(src, dst):
            try:
                if os.path.islink(src) or os.path.islink(dst):
                    return os.path.islink(src) and os.path.islink(dst) and os.readlink(src) == os.readlink(dst)
                if os.path.isdir(src):
                    for root, dirs, files in os.walk(src, followlinks=False):
                        rel = os.path.relpath(root, src)
                        dst_root = dst if rel == "." else os.path.join(dst, rel)
                        if not os.path.isdir(dst_root):
                            return False
                        for name in files:
                            if not file_equal(os.path.join(root, name), os.path.join(dst_root, name)):
                                return False
                    return True
                if not os.path.isfile(src) or not os.path.isfile(dst):
                    return False
                if os.path.getsize(src) != os.path.getsize(dst):
                    return False
                with open(src, "rb") as a, open(dst, "rb") as b:
                    while True:
                        ca = a.read(1 << 20)
                        cb = b.read(1 << 20)
                        if ca != cb:
                            return False
                        if not ca:
                            return True
            except OSError:
                return False

        for original in lines:
            line = cache_expand(original)
            parts = line.split(None, 1)
            if len(parts) < 2:
                continue
            instr = parts[0].upper()
            args = parts[1]
            if instr == "FROM":
                base = parse_from_base(args)
                if not base:
                    return None
                base_diff_ids = _load_image_manifest(image_dir(normalize_image(base)))
                if not base_diff_ids or existing_diff_ids[:len(base_diff_ids)] != base_diff_ids:
                    return None
                expected.append(f"FROM {base}")
            elif instr == "ARG":
                k, _, default = args.partition("=")
                k = k.strip()
                if k not in cache_args and default:
                    cache_args[k] = default.strip()
                expected.append(f"ARG {args}")
            elif instr == "RUN":
                expected.append(f"RUN {args}")
            elif instr in ("COPY", "ADD"):
                if re.search(r"(^|\s)--from(?:=|\s+)", args):
                    return None
                rest = args
                rest = re.sub(r"--chown(?:=\S+|\s+\S+)\s+", "", rest)
                rest = re.sub(r"--chmod(?:=\S+|\s+\S+)\s+", "", rest)
                rest = re.sub(r"--link\s+", "", rest)
                src_parts = shlex.split(rest)
                if len(src_parts) < 2:
                    return None
                dest = src_parts[-1]
                srcs = src_parts[:-1]
                if not dest.startswith("/"):
                    dest = os.path.join(cache_workdir, dest)
                for s in srcs:
                    spath = os.path.join(context_dir, s)
                    if not os.path.exists(spath):
                        return None
                    dst = os.path.join(existing_rootfs, dest.lstrip("/"))
                    if dest.endswith("/") or os.path.isdir(dst):
                        dst = os.path.join(dst, os.path.basename(spath))
                    copy_checks.append((spath, dst))
                expected.append(f"{instr} {args}")
            elif instr == "WORKDIR":
                cache_workdir = args.strip()
                if not cache_workdir.startswith("/"):
                    cache_workdir = "/" + cache_workdir
                expected.append(f"WORKDIR {cache_workdir}")
            elif instr == "ENV":
                expected.append(f"ENV {args}")
            elif instr == "CMD":
                expected.append(f"CMD {args}")
            elif instr == "ENTRYPOINT":
                expected.append(f"ENTRYPOINT {args}")
            elif instr == "EXPOSE":
                expected.append(f"EXPOSE {args}")
            elif instr == "LABEL":
                expected.append(f"LABEL {args}")
            elif instr == "USER":
                expected.append(f"USER {args}")
            elif instr == "VOLUME":
                expected.append(f"VOLUME {args}")
            elif instr == "SHELL":
                expected.append(f"SHELL {args}")
            elif instr == "HEALTHCHECK":
                expected.append(f"HEALTHCHECK {args}")
            elif instr == "STOPSIGNAL":
                expected.append(f"STOPSIGNAL {args}")
            elif instr == "ONBUILD":
                expected.append(f"ONBUILD {args}")
            elif instr == "MAINTAINER":
                expected.append(f"MAINTAINER {args}")
            else:
                return None

        if history != expected:
            return None
        for src, dst in copy_checks:
            if not file_equal(src, dst):
                return None
        return norm_tag

    reusable_tag = try_reuse_existing_tag()
    if reusable_tag:
        emit(f"Using image cache for {reusable_tag}")
        return reusable_tag

    for line in lines:
        line = expand(line)
        parts = line.split(None, 1)
        if len(parts) < 2:
            continue
        instr = parts[0].upper()
        args = parts[1]

        if instr == "FROM":
            base = parse_from_base(args)
            if not base:
                emit(f"ERROR: invalid FROM instruction: {args}")
                return fail_build()
            emit(f"Step: FROM {base}")
            norm = normalize_image(base)
            if not os.path.exists(os.path.join(image_dir(norm), "rootfs")):
                pull_image(base)
            # Prepare build rootfs — prefer layer-aware merge (Phase 2/3),
            # fallback to flatten clone for legacy images without manifest.
            os.makedirs(build_dir, exist_ok=True)
            rootfs = os.path.join(build_dir, "rootfs")
            if os.path.exists(rootfs):
                shutil.rmtree(rootfs)
            img_d = image_dir(norm)
            base_diff_ids = _load_image_manifest(img_d)
            if base_diff_ids:
                emit("  materializing base layers")
                start = time.perf_counter()
                materialize_container_rootfs(rootfs, base_diff_ids)
                emit(f"  build-profile materialize-base: {time.perf_counter() - start:.3f}s layers={len(base_diff_ids)}")
                diff_ids = list(base_diff_ids)
                base_layer_count[0] = len(base_diff_ids)
            else:
                emit("  cloning legacy base rootfs")
                start = time.perf_counter()
                clone_image_rootfs(os.path.join(img_d, "rootfs"), rootfs)
                emit(f"  build-profile clone-legacy-base: {time.perf_counter() - start:.3f}s")
                # Legacy base: can't attribute existing content to any
                # prior diff_id. Snapshot whole rootfs as a single layer
                # so subsequent RUN/COPY still layer diffs correctly.
                diff_ids = [snapshot_layer("legacy base")]
                base_layer_count[0] = len(diff_ids)
            for sub in ["proc", "sys", "dev", "tmp", "etc"]:
                os.makedirs(os.path.join(rootfs, sub), exist_ok=True)
            _prepare_rootfs_runtime_files(rootfs)
            # Inherit image config
            cfg = image_config(norm) or {}
            c = cfg.get("config", {})
            for e in c.get("Env", []) or []:
                if "=" in e:
                    k, v = e.split("=", 1)
                    env[k] = v
            workdir = c.get("WorkingDir") or "/"
            cmd = c.get("Cmd")
            entrypoint = c.get("Entrypoint")
            user = c.get("User") or ""
            labels = dict(c.get("Labels") or {})
            exposed_ports = dict(c.get("ExposedPorts") or {})
            volumes = dict(c.get("Volumes") or {})
            shell = list(c.get("Shell") or ["/bin/sh", "-c"])
            healthcheck = c.get("Healthcheck")
            stop_signal = c.get("StopSignal")
            onbuild = list(c.get("OnBuild") or [])
            last_size[0] = 0
            record_layer(f"FROM {base}", empty_layer=True)

        elif instr == "RUN":
            emit(f"Step: RUN {args}")
            full_env = dict(env)
            cache_key = build_cache_key(
                "RUN", args, diff_ids,
                build_state_for_cache({"run_env": dict(sorted(full_env.items()))}),
            )
            cached = load_build_cache_entry(cache_key)
            if cached:
                cached_did = cached["diff_id"]
                emit(f"  Using cache sha256:{cached_did[:12]}")
                merge_layers_into(rootfs, [cached_did])
                diff_ids.append(cached_did)
                last_snapshot_size[0] = _layer_size(cached_did)
                for sub in ["proc", "sys", "dev", "tmp", "etc"]:
                    os.makedirs(os.path.join(rootfs, sub), exist_ok=True)
                _prepare_rootfs_runtime_files(rootfs)
                record_layer(f"RUN {args}", size_delta=last_snapshot_size[0])
                continue
            inline_did = prior_tag_layer(f"RUN {args}", diff_ids)
            if inline_did:
                emit(f"  Using inline cache sha256:{inline_did[:12]}")
                merge_layers_into(rootfs, [inline_did])
                diff_ids.append(inline_did)
                last_snapshot_size[0] = _layer_size(inline_did)
                for sub in ["proc", "sys", "dev", "tmp", "etc"]:
                    os.makedirs(os.path.join(rootfs, sub), exist_ok=True)
                _prepare_rootfs_runtime_files(rootfs)
                store_build_cache_entry(cache_key, {
                    "diff_id": inline_did,
                    "size": last_snapshot_size[0],
                    "created_by": f"RUN {args}",
                    "source": "inline-tag",
                })
                record_layer(f"RUN {args}", size_delta=last_snapshot_size[0])
                continue
            repaired_loader = ensure_rootfs_dynamic_loader(rootfs, diff_ids)
            if repaired_loader:
                emit(f"  repaired dynamic loader from layer: {repaired_loader}")
            process_fault = runtime_process_unavailable_message()
            if process_fault:
                emit(process_fault)
                emit("RUN requires a real container process executor; build stopped without recording a fake layer")
                return fail_build()
            fault = runtime_preflight(rootfs, full_env, workdir=workdir)
            if fault:
                emit(fault)
                emit("RUN skipped because the Android execution backend is unavailable")
                return fail_build()
            run_start = time.perf_counter()
            proc = subprocess.Popen(
                build_run_argv(rootfs, build_run_command(args),
                               full_env, workdir=workdir, mode="build"),
                stdout=subprocess.PIPE,
                stderr=subprocess.STDOUT,
            )
            captured = bytearray()
            if proc.stdout:
                read_chunk = getattr(proc.stdout, "read1", proc.stdout.read)
                while True:
                    chunk = read_chunk(8192)
                    if not chunk:
                        break
                    captured.extend(chunk)
                    if len(captured) > 512 * 1024:
                        del captured[:len(captured) - 512 * 1024]
                    emit(chunk.decode(errors="replace"), newline=False)
            proc.wait()
            emit(f"  build-profile run-exec: {time.perf_counter() - run_start:.3f}s rc={proc.returncode}")
            if proc.returncode != 0:
                fault = runner_fault_message(bytes(captured))
                if fault:
                    emit(fault)
                emit(f"RUN failed with exit code {proc.returncode}")
                return fail_build()
            new_did = snapshot_layer(
                "RUN", prev_diff_ids=diff_ids,
                changed_paths=run_changed_paths(args),
            )
            store_build_cache_entry(cache_key, {
                "diff_id": new_did,
                "size": last_snapshot_size[0] or _layer_size(new_did),
                "created_by": f"RUN {args}",
            })
            diff_ids.append(new_did)
            rematerialize_build_rootfs()
            record_layer(f"RUN {args}", size_delta=last_snapshot_size[0])

        elif instr in ("COPY", "ADD"):
            if re.search(r"(^|\s)--from(?:=|\s+)", args):
                emit(f"ERROR: {instr} --from requires multi-stage build support, which is not implemented yet")
                return fail_build()
            # Strip implemented Docker flags that affect ownership/mode metadata.
            rest = args
            rest = re.sub(r"--chown(?:=\S+|\s+\S+)\s+", "", rest)
            rest = re.sub(r"--chmod(?:=\S+|\s+\S+)\s+", "", rest)
            rest = re.sub(r"--link\s+", "", rest)
            src_parts = shlex.split(rest)
            if len(src_parts) < 2:
                continue
            dest = src_parts[-1]
            srcs = src_parts[:-1]
            if not dest.startswith("/"):
                dest = os.path.join(workdir, dest)
            target = os.path.join(rootfs, dest.lstrip("/"))
            if dest.endswith("/"):
                _ensure_rootfs_dir_path(rootfs, target)
            else:
                _ensure_rootfs_dir_path(rootfs, os.path.dirname(target))
            copy_changed = []
            copy_deleted = []
            copy_start = time.perf_counter()
            copied = 0
            for s in srcs:
                spath = os.path.join(context_dir, s)
                if not os.path.exists(spath):
                    emit(f"COPY failed: {s} not found")
                    continue
                if os.path.isdir(spath):
                    dst = target if dest.endswith("/") else target
                    if os.path.exists(dst):
                        copy_deleted.append(os.path.relpath(dst, rootfs))
                        shutil.rmtree(dst)
                    shutil.copytree(spath, dst, copy_function=_copy_no_xattr)
                else:
                    dst = target if dest.endswith("/") else target
                    if dest.endswith("/") or os.path.isdir(dst):
                        dst = os.path.join(target, os.path.basename(spath))
                    if os.path.lexists(dst):
                        os.remove(dst)
                    _copy_no_xattr(spath, dst)
                copy_changed.append(os.path.relpath(dst, rootfs))
                emit(f"  {s} -> {dest}")
                copied += 1
            emit(f"  build-profile {instr.lower()}-copy: {time.perf_counter() - copy_start:.3f}s sources={copied}")
            new_did = snapshot_layer(
                instr, prev_diff_ids=diff_ids,
                changed_paths=copy_changed, deleted_paths=copy_deleted,
            )
            diff_ids.append(new_did)
            rematerialize_build_rootfs()
            record_layer(f"{instr} {args}", size_delta=last_snapshot_size[0])

        elif instr == "WORKDIR":
            workdir = args.strip()
            if not workdir.startswith("/"):
                workdir = "/" + workdir
            os.makedirs(os.path.join(rootfs, workdir.lstrip("/")), exist_ok=True)
            emit(f"Step: WORKDIR {workdir}")
            record_layer(f"WORKDIR {workdir}", empty_layer=True)

        elif instr == "ENV":
            # ENV KEY=VALUE [KEY=VALUE ...]  or  ENV KEY VALUE
            if "=" in args:
                for part in shlex.split(args):
                    if "=" in part:
                        k, v = part.split("=", 1)
                        env[k] = v
            else:
                k, _, v = args.partition(" ")
                env[k] = v
            emit(f"Step: ENV {args}")
            record_layer(f"ENV {args}", empty_layer=True)

        elif instr == "ARG":
            k, _, default = args.partition("=")
            k = k.strip()
            if k not in args_dict and default:
                args_dict[k] = default.strip()
            emit(f"Step: ARG {args}")
            record_layer(f"ARG {args}", empty_layer=True)

        elif instr == "CMD":
            cmd = parse_json_or_shell(args)
            emit(f"Step: CMD {args}")
            record_layer(f"CMD {args}", empty_layer=True)

        elif instr == "ENTRYPOINT":
            entrypoint = parse_json_or_shell(args)
            emit(f"Step: ENTRYPOINT {args}")
            record_layer(f"ENTRYPOINT {args}", empty_layer=True)

        elif instr == "EXPOSE":
            for port_spec in args.split():
                if "/" not in port_spec:
                    port_spec = f"{port_spec}/tcp"
                exposed_ports[port_spec] = {}
            emit(f"Step: EXPOSE {args} (recorded in config; Android userspace runtime has no netns)")
            record_layer(f"EXPOSE {args}", empty_layer=True)
        elif instr == "LABEL":
            for part in shlex.split(args):
                if "=" in part:
                    k, v = part.split("=", 1)
                    labels[k] = v
            emit(f"Step: LABEL {args}")
            record_layer(f"LABEL {args}", empty_layer=True)
        elif instr == "USER":
            user = args.strip()
            emit(f"Step: USER {args} (uid mapping limited in Android userspace runtime)")
            record_layer(f"USER {args}", empty_layer=True)
        elif instr == "VOLUME":
            vol_args = args.strip()
            if vol_args.startswith("["):
                try:
                    for v in json.loads(vol_args):
                        volumes[v] = {}
                except Exception:
                    pass
            else:
                for v in shlex.split(vol_args):
                    volumes[v] = {}
            emit(f"Step: VOLUME {args}")
            record_layer(f"VOLUME {args}", empty_layer=True)
        elif instr == "SHELL":
            try:
                parsed_shell = json.loads(args.strip())
                if not isinstance(parsed_shell, list) or not parsed_shell:
                    raise ValueError("SHELL must be a non-empty JSON array")
                shell = [str(x) for x in parsed_shell]
            except Exception as exc:
                emit(f"ERROR: invalid SHELL instruction: {exc}")
                return fail_build()
            emit(f"Step: SHELL {args}")
            record_layer(f"SHELL {args}", empty_layer=True)
        elif instr == "HEALTHCHECK":
            hc_args = args.strip()
            if hc_args.upper() == "NONE":
                healthcheck = {"Test": ["NONE"]}
            else:
                parts = shlex.split(hc_args)
                while parts and parts[0].startswith("--"):
                    parts.pop(0)
                if not parts or parts[0].upper() != "CMD":
                    emit(f"ERROR: invalid HEALTHCHECK instruction: {args}")
                    return fail_build()
                command = hc_args[hc_args.upper().find("CMD") + 3:].strip()
                if command.startswith("["):
                    try:
                        healthcheck = {"Test": ["CMD"] + json.loads(command)}
                    except Exception as exc:
                        emit(f"ERROR: invalid HEALTHCHECK JSON command: {exc}")
                        return fail_build()
                else:
                    healthcheck = {"Test": ["CMD-SHELL", command]}
            emit(f"Step: HEALTHCHECK {args}")
            record_layer(f"HEALTHCHECK {args}", empty_layer=True)
        elif instr == "STOPSIGNAL":
            stop_signal = args.strip()
            emit(f"Step: STOPSIGNAL {args}")
            record_layer(f"STOPSIGNAL {args}", empty_layer=True)
        elif instr == "ONBUILD":
            onbuild.append(args.strip())
            emit(f"Step: ONBUILD {args}")
            record_layer(f"ONBUILD {args}", empty_layer=True)
        elif instr == "MAINTAINER":
            author = args.strip()
            emit(f"Step: MAINTAINER {args}")
            record_layer(f"MAINTAINER {args}", empty_layer=True)
        else:
            emit(f"ERROR: unknown Dockerfile instruction: {instr}")
            return fail_build()

    # Store built image under tag
    if tag and rootfs:
        # Normalize tag
        norm_tag = normalize_image(tag)
        dest = image_dir(norm_tag)
        if os.path.exists(dest):
            shutil.rmtree(dest)
        os.makedirs(dest)
        shutil.move(rootfs, os.path.join(dest, "rootfs"))
        # Write image config with diff_ids (real Docker config shape —
        # `rootfs.diff_ids` is what's needed for docker save/push to work
        # in Phase 5 without re-digesting).
        img_config = {
            "architecture": "arm64",
            "os": "linux",
            "config": {
                "Env": [f"{k}={v}" for k, v in env.items()],
                "Cmd": cmd if isinstance(cmd, list) else (cmd and [cmd] or None),
                "Entrypoint": entrypoint if isinstance(entrypoint, list) else (entrypoint and [entrypoint] or None),
                "WorkingDir": workdir,
                "User": user,
                "Labels": labels or None,
                "ExposedPorts": exposed_ports or None,
                "Volumes": volumes or None,
                "Shell": shell,
                "Healthcheck": healthcheck,
                "StopSignal": stop_signal,
                "OnBuild": onbuild or None,
            },
            "author": author,
            "created": time.strftime("%Y-%m-%dT%H:%M:%SZ", time.gmtime()),
            "rootfs": {
                "type": "layers",
                "diff_ids": [f"sha256:{d}" for d in diff_ids],
            },
            "history": [
                {"created": l.get("created"),
                 "created_by": l.get("created_by"),
                 **({"empty_layer": True} if l.get("empty_layer") else {})}
                for l in layers
            ],
        }
        with open(os.path.join(dest, "config.json"), "w") as f:
            json.dump(img_config, f, indent=2)
        _save_image_manifest(dest, diff_ids, img_config)
        with open(os.path.join(dest, "image_ref"), "w") as f:
            f.write(norm_tag)
        with open(os.path.join(dest, "pulled_at"), "w") as f:
            f.write(time.strftime("%Y-%m-%dT%H:%M:%SZ", time.gmtime()))
        with open(os.path.join(dest, "layers.json"), "w") as f:
            json.dump(layers, f, indent=2)
        if os.environ.get("PDOCKER_AUTO_PRUNE_UNREFERENCED_LAYERS", "0") == "1":
            pruned = prune_unreferenced_layers(min_age_seconds=0)
            deleted = len(pruned.get("Deleted") or [])
            if deleted:
                emit(
                    "  build-profile prune-unreferenced-layers: "
                    f"deleted={deleted} reclaimed={pruned.get('SpaceReclaimed', 0)}"
                )
        shutil.rmtree(build_dir, ignore_errors=True)
        return norm_tag
    return fail_build()


# ---- Server setup ----

class ThreadingUnixHTTPServer(socketserver.ThreadingMixIn, socketserver.UnixStreamServer):
    daemon_threads = True
    allow_reuse_address = True


class ThreadingTCPHTTPServer(socketserver.ThreadingMixIn, socketserver.TCPServer):
    daemon_threads = True
    allow_reuse_address = True


def main():
    parser = argparse.ArgumentParser(description="Docker Engine API-compatible daemon for PRoot")
    parser.add_argument("--socket", default="/var/run/docker.sock",
                        help="Unix socket path")
    parser.add_argument("--host", default=None,
                        help="TCP host:port (in addition to socket)")
    parser.add_argument("--no-socket", action="store_true",
                        help="Don't listen on Unix socket")
    args = parser.parse_args()

    servers = []

    if not args.no_socket:
        # Ensure dir exists
        os.makedirs(os.path.dirname(args.socket), exist_ok=True)
        if os.path.exists(args.socket):
            os.unlink(args.socket)
        srv = ThreadingUnixHTTPServer(args.socket, DockerAPIHandler)
        os.chmod(args.socket, 0o666)
        servers.append(("unix://" + args.socket, srv))

    if args.host:
        host, _, port = args.host.rpartition(":")
        host = host or "127.0.0.1"
        srv = ThreadingTCPHTTPServer((host, int(port)), DockerAPIHandler)
        servers.append((f"tcp://{host}:{port}", srv))

    for addr, _ in servers:
        log(f"Listening on {addr}")
    log(f"PDOCKER_HOME: {PDOCKER_HOME}")
    log("Use DOCKER_HOST=" + servers[0][0])

    threads = []
    for _, srv in servers:
        t = threading.Thread(target=srv.serve_forever, daemon=True)
        t.start()
        threads.append(t)

    try:
        while True:
            time.sleep(1)
    except KeyboardInterrupt:
        log("Shutting down...")
        for _, srv in servers:
            srv.shutdown()


if __name__ == "__main__":
    main()
